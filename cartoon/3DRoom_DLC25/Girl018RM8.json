    {
        "Key": "page1.7",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "好像还真没看过。"
    },
    {
        "Key": "page1.8",
        "Speaker": "H薇蒂雅",
        "WwiseEventID": "",
        "zh_CN": "我最近对朔州武侠电影非常感兴趣，总觉得分析员简直就是侠客的化身！"
    },
    {
        "Key": "page1.9",
        "Speaker": "H薇蒂雅",
        "WwiseEventID": "",
        "zh_CN": "所以我熬了一周做这个短片的剧本、分镜。"
    },
    {
        "Key": "page1.10",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "怪不得前段时间你都赖在房间里。遇到什么难题了？"
