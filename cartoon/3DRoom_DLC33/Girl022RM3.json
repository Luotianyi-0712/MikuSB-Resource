        "Speaker": "H克罗瑞娜",
        "WwiseEventID": "",
        "zh_CN": "真是好神奇呀！",
        "disable": 0
    },
    {
        "Key": "page1.10",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "我很好奇你以前是怎么喝咖啡的。",
