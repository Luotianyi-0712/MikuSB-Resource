[
    {
        "Key": "page1.1",
        "Speaker": "H安卡希雅",
        "WwiseEventID": "",
        "zh_CN": "亲爱的，你已经对多诺有了深厚的羁绊！",
        "disable": 0
    },
    {
        "Key": "page1.2",
        "Speaker": "H安卡希雅",
        "WwiseEventID": "",
        "zh_CN": "让我们开始进入正式的对决吧！",
        "disable": 0
    },
    {
        "Key": "page1.3",
        "Speaker": "旁白",
        "WwiseEventID": "",
        "zh_CN": "安卡希雅双手平举，郑重地捧着一把“空气大剑”，等着我的配合。",
        "disable": 0
    },
    {
        "Key": "page1.4",
        "Speaker": "旁白",
        "WwiseEventID": "",
        "zh_CN": "我们早已深刻了解彼此，我自然明白她的意思。",
        "disable": 0
    },
    {
        "Key": "page1.5",
        "Speaker": "旁白",
        "WwiseEventID": "",
        "zh_CN": "我将手放在胸前，半跪在地，郑重地回应了她的“仪式”。",
        "disable": 0
    },
    {
        "Key": "page1.6",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "为了命定的恒约之人，我早就做好了战斗的觉悟。",
        "disable": 0
    },
    {
        "Key": "page1.7",
        "Speaker": "旁白",
        "WwiseEventID": "",
        "zh_CN": "安卡希雅满足地笑着，随后就又扑在了我的身上，蹭来蹭去。",
        "disable": 0
    },
    {
        "Key": "page1.8",
        "Speaker": "旁白",
        "WwiseEventID": "",
        "zh_CN": "再次抬起头时，她头顶软软的发丝布满静电而全部飞起来，活像是炸毛的小动物。",
        "disable": 0
    },
    {
        "Key": "page1.9",
        "Speaker": "旁白",
        "WwiseEventID": "",
        "zh_CN": "闹闹腾腾但是温馨的瞬间，也让我再次想起那些事。",
        "disable": 0
    },
    {
        "Key": "page1.10",
        "Speaker": "旁白",
        "WwiseEventID": "",
        "zh_CN": "她和我一起喝老式奶茶时，弯弯眼角露出的甜蜜。",
        "disable": 0
    },
    {
        "Key": "page1.11",
        "Speaker": "旁白",
        "WwiseEventID": "",
        "zh_CN": "我们并排而坐，在街机店奋力地拍着按键时，她瞥向我的瞬间。",
        "disable": 0
    },
    {
        "Key": "page1.12",
        "Speaker": "",
        "WwiseEventID": "",
        "zh_CN": "在柔软的暖光照射的漫画屋里，我们一起嗦泡面时，她的神情……",
        "disable": 0
    },
    {
        "Key": "page1.13",
        "Speaker": "旁白",
        "WwiseEventID": "",
        "zh_CN": "原来和她在一起的每一刻，都在不断地给我的世界带来新的东西。",
        "disable": 0
    },
    {
        "Key": "page1.14",
        "Speaker": "旁白",
        "WwiseEventID": "",
        "zh_CN": "而她也一直在期待我会满意、喜欢这一切……",
        "disable": 0
    },
    {
        "Key": "page1.15",
        "Speaker": "H安卡希雅",
        "WwiseEventID": "",
        "zh_CN": "亲爱的……亲爱的？想什么呢？",
        "disable": 0
    },
    {
        "Key": "page1.16",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "在想，我喜欢多诺卡，但更喜欢和你一起玩多诺卡。",
        "disable": 0
    }
