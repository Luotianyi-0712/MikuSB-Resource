        "zh_CN": "谢谢……"
    },
    {
        "Key": "page1.4",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "只是兑换一句感谢吗？"
    },
    {
        "Key": "page1.5",
        "Speaker": "H安卡希雅",
