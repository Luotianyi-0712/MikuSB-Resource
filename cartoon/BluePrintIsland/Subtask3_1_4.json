    {
        "Key": "page1.7",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "你在惊吓那些“员工”的时候，有没有想过会有今天？",
        "disable": 0
    },
    {
        "Key": "page1.8",
        "Speaker": "T尖尖耳",
        "WwiseEventID": "",
        "zh_CN": "没错！恶有恶报！你必须要付出代价！",
        "disable": 0
    },
    {
        "Key": "page1.9",
        "Speaker": "T卡比",
        "WwiseEventID": "",
        "zh_CN": "呜呜呜我错啦，放过我吧……",
        "disable": 0
