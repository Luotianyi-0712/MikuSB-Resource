[
    {
        "Key": "page1.1",
        "Speaker": "H奈莉德",
        "WwiseEventID": "",
        "zh_CN": "分析员，我刚才餐厅回来，捎带给你打包了一些。"
    },
    {
        "Key": "page1.2",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "奈莉德怎么知道我没吃饭？"
    },
    {
        "Key": "page1.3",
        "Speaker": "H奈莉德",
        "WwiseEventID": "",
        "zh_CN": "我不知道。"
    },
    {
        "Key": "page1.4",
        "Speaker": "H奈莉德",
        "WwiseEventID": "",
        "zh_CN": "小时候，奶奶每次出门，都会给我带些零嘴回来。"
    },
    {
        "Key": "page1.5",
        "Speaker": "H奈莉德",
        "WwiseEventID": "",
        "zh_CN": "有时候是一个苹果，有时候是一根烤香肠。"
    },
    {
        "Key": "page1.6",
        "Speaker": "H奈莉德",
        "WwiseEventID": "",
        "zh_CN": "不过这都不重要，重要的是这种被人记挂着的感觉很好。"
    },
    {
        "Key": "page1.7",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "看来莫罗佐娃女士真的很疼爱你呢。"
    },
    {
        "Key": "page1.9",
        "Speaker": "H奈莉德",
        "WwiseEventID": "",
        "zh_CN": "嗯，奶奶还告诉我，打猎回家是人类潜藏在基因里的本能。"
    },
    {
        "Key": "page1.10",
        "Speaker": "H奈莉德",
        "WwiseEventID": "",
        "zh_CN": "我现在也算有个家了，所以我想学着奶奶一样，做个合格的猎手。"
    },
    {
        "Key": "page1.11",
        "Speaker": "H奈莉德",
        "WwiseEventID": "",
        "zh_CN": "让你也感受到……我的……我的记挂。"
    },
    {
        "Key": "page1.12",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "有趣的“耶洛沙式”比喻。"
    },
    {
        "Key": "page1.13",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "我不仅感受到了，还觉得很幸福哦。"
    },
    {
        "Key": "page1.14",
        "Speaker": "H奈莉德",
        "WwiseEventID": "",
        "zh_CN": "那……那就赶紧享用“猎物”吧，少说这些让人脸红的话。"
    }
]