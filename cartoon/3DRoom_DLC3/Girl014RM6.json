[
    {
        "Key": "page0.1",
        "Speaker": "H姬辰星",
        "WwiseEventID": "",
        "zh_CN": "……"
    },
    {
        "Key": "page0.2",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "你在这里啊，看你一脸凝重的样子，有什么不对吗？"
    },
    {
        "Key": "page0.3",
        "Speaker": "H姬辰星",
        "WwiseEventID": "",
        "zh_CN": "安卡希雅管这台机器叫“抓娃娃”机。"
    },
    {
        "Key": "page0.4",
        "Speaker": "H姬辰星",
        "WwiseEventID": "",
        "zh_CN": "如果我没记错的话，这是几十年前流行的一种娱乐设备。"
    },
    {
        "Key": "page0.5",
        "Speaker": "H姬辰星",
        "WwiseEventID": "",
        "zh_CN": "通过支付一定代价获取操控机械爪的次数，然后看准时机找准位置放下机械爪。"
    },
    {
        "Key": "page0.6",
        "Speaker": "H姬辰星",
        "WwiseEventID": "",
        "zh_CN": "因为机械爪的抓力故意被设计的很弱，因此想要抓到娃娃技巧和运气缺一不可。"
    },
    {
        "Key": "page0.7",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "你想要试试吗？"
    },
    {
        "Key": "page0.8",
        "Speaker": "H姬辰星",
        "WwiseEventID": "",
        "zh_CN": "这台只是复刻了抓娃娃机外形的室内装置，并不具备实际功能。"
    },
    {
        "Key": "page0.9",
        "Speaker": "H姬辰星",
        "WwiseEventID": "",
        "zh_CN": "我只是在脑内模拟如果让我操作真正的抓娃娃机会怎样……"
    },
    {
        "Key": "page0.10",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "辰星的话一定没有问题。"
    },
    {
        "Key": "page0.11",
        "Speaker": "H姬辰星",
        "WwiseEventID": "",
        "zh_CN": "不，感觉抓娃娃和推沙雕有些类似，需要微妙的手感。"
    },
    {
        "Key": "page0.12",
        "Speaker": "H姬辰星",
        "WwiseEventID": "",
        "zh_CN": "我虽然能够理解原理，但缺乏实践，恐怕要反复练习才能掌握技巧。"
    },
    {
        "Key": "page0.13",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "……"
    },
    {
        "Key": "page0.14",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "（看来她还是在意雅卢岛上堆沙雕的事情。可见，记性太好，有时候确实不是一件好事。）"
    }
]