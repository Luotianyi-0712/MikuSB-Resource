[
    {
        "Key": "page1.1",
        "Speaker": "",
        "WwiseEventID": "",
        "zh_CN": "伊切尔的心情似乎不太好。"
    },
    {
        "Key": "page1.2",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "伊切尔？"
    },
    {
        "Key": "page1.3",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "伊切尔你今天怎么不理我呀？"
    },
    {
        "Key": "page1.4",
        "Speaker": "",
        "WwiseEventID": "",
        "zh_CN": "伊切尔翻了个身，没有理会我"
    },
    {
        "Key": "page1.5",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "怎么办才好呢？"
    },
    {
        "Key": "choice01",
        "Speaker": "",
        "WwiseEventID": "",
        "zh_CN": "用食物吸引她"
    },
    {
        "Key": "page2.1",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "给你带了好吃的牛肉饼哦，满满全是肉，一点蔬菜都没有哦！"
    },
    {
        "Key": "page2.2",
        "Speaker": "H伊切尔",
        "WwiseEventID": "",
        "zh_CN": "伊切尔今天不想吃肉……"
    },
    {
        "Key": "choice02",
        "Speaker": "",
        "WwiseEventID": "",
        "zh_CN": "用游戏吸引她"
    },
    {
        "Key": "page3.1",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "伊切尔，我们一起来玩游戏怎么样？"
    },
    {
        "Key": "page3.2",
        "Speaker": "H伊切尔",
        "WwiseEventID": "",
        "zh_CN": "伊切尔突然不喜欢游戏了……"
    },
    {
        "Key": "choice03",
        "Speaker": "",
        "WwiseEventID": "",
        "zh_CN": "用人格魅力吸引她"
    },
    {
        "Key": "page4.1",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "伊切尔，我来陪你聊天了。"
    },
    {
        "Key": "page4.2",
        "Speaker": "H伊切尔",
        "WwiseEventID": "",
        "zh_CN": "伊切尔不想说话……"
    },
    {
        "Key": "page5.1",
        "Speaker": "",
        "WwiseEventID": "",
        "zh_CN": "伊切尔好像在……生闷气？"
    },
    {
        "Key": "page5.2",
        "Speaker": "",
        "WwiseEventID": "",
        "zh_CN": "过了许久她才从帐篷里爬起来，看向我的目光里居然带着些小委屈。"
    },
    {
        "Key": "page5.3",
        "Speaker": "H伊切尔",
        "WwiseEventID": "",
        "zh_CN": "分析员参加了大人的派对，没有带上伊切尔。"
    },
    {
        "Key": "page5.4",
        "Speaker": "H伊切尔",
        "WwiseEventID": "",
        "zh_CN": "伊切尔很羡慕……"
    },
    {
        "Key": "page5.5",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "什么大人的派对？我怎么不知道？"
    },
    {
        "Key": "page5.6",
        "Speaker": "H伊切尔",
        "WwiseEventID": "",
        "zh_CN": "就是那种大人们一起发生快乐事情的派对。"
    },
    {
        "Key": "page5.7",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "？？？"
    },
    {
        "Key": "page5.8",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "等等，是不是有人教了你什么奇怪的东西？"
    },
    {
        "Key": "page5.9",
        "Speaker": "H伊切尔",
        "WwiseEventID": "",
        "zh_CN": "安卡希雅是这么告诉伊切尔的。"
    },
    {
        "Key": "page5.10",
        "Speaker": "H伊切尔",
        "WwiseEventID": "",
        "zh_CN": "她说她经常在晚上和分析员一起参与大人的派对。"
    },
    {
        "Key": "page5.11",
        "Speaker": "H伊切尔",
        "WwiseEventID": "",
        "zh_CN": "她在派对上会和分析员进行激烈的、绵延不绝的、令人倍感愉悦的“战斗”。"
    },
    {
        "Key": "page5.12",
        "Speaker": "H伊切尔",
        "WwiseEventID": "",
        "zh_CN": "战斗至精疲力尽，体态疲软后，就会得到分析员充满情感的奖励。"
    },
    {
        "Key": "page5.13",
        "Speaker": "H伊切尔",
        "WwiseEventID": "",
        "zh_CN": "那是什么战斗啊？伊切尔也想参加！"
    },
    {
        "Key": "page5.14",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "我总觉得你的描述有什么问题……不对，应该是安卡希雅的描述有问题。"
    },
    {
        "Key": "page5.15",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "她还有说什么细节吗？"
    },
    {
        "Key": "page5.16",
        "Speaker": "H伊切尔",
        "WwiseEventID": "",
        "zh_CN": "她还说，大人的派对里必须要用到神奇的小道具，可用于增添情趣。"
    },
    {
        "Key": "page5.17",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "你这个用词是不是不太对劲？"
    },
    {
        "Key": "page5.18",
        "Speaker": "H伊切尔",
        "WwiseEventID": "",
        "zh_CN": "她一个，分析员一个，这个小道具能显著增加“战斗”的激烈程度！"
    },
    {
        "Key": "page5.19",
        "Speaker": "H伊切尔",
        "WwiseEventID": "",
        "zh_CN": "那个小道具好像是叫……手柄？"
    },
    {
        "Key": "page5.20",
        "Speaker": "",
        "WwiseEventID": "",
        "zh_CN": "突然间我好像明白她在说什么了。"
    },
    {
        "Key": "page5.21",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "等等……你说的派对，是不是还有个名字叫做“打游戏”？"
    },
    {
        "Key": "page5.22",
        "Speaker": "H伊切尔",
        "WwiseEventID": "",
        "zh_CN": "嗯嗯！就是那个！打游戏！她好像有提到过！"
    },
    {
        "Key": "page5.23",
        "Speaker": "H主角",
        "WwiseEventID": "",
        "zh_CN": "好吧……咳咳，如果是打游戏的话，带着你一起玩，倒也没什么问题。"
    },
    {
        "Key": "page5.24",
        "Speaker": "",
        "WwiseEventID": "",
        "zh_CN": "接下来我和伊切尔一起打了一下午的游戏，顺带一提，她的技术实在是一言难尽。"
    }
]