[
    {
        "Key": "Loading001_01",
        "zh_CN": "棚户区",
        "disable": 0
    },
    {
        "Key": "Loading001_02",
        "zh_CN": "缓冲区居民自发组织形成的聚落，主要由罹患成年病无法医治的青少年及其家庭、因人工智能技术革命沦落底层的数据矿工、失业者、违法分子和进入隔离区掘金泰坦物质的投机客等社会底层构成。",
        "disable": 0
    },
    {
        "Key": "Loading001_03",
        "zh_CN": "郊狼",
        "disable": 0
    },
    {
        "Key": "Loading001_04",
        "zh_CN": "主要活跃在缓冲区的武装团体，由大部分患成年病而无力医治的下层青少年，和挣扎求生的拾荒者自发组成。传闻身为郊狼领导者之一的“叶”，是唯一未用药而自愈的成年病患者。",
        "disable": 0
    },
    {
        "Key": "Loading001_05",
        "zh_CN": "布里希嘉曼",
        "disable": 0
    },
    {
        "Key": "Loading001_06",
        "zh_CN": "降临团用于扩散泰坦污染的机械装置，降临团的用意尚且不明。",
        "disable": 0
    },
    {
        "Key": "Loading001_07",
        "zh_CN": "降临团",
        "disable": 0
    },
    {
        "Key": "Loading001_08",
        "zh_CN": "被社会抛弃，失去希望，或者找不到自身价值的人，自发的集结起来形成的民间组织。降临事件之后，他们也渐渐建立起了自己的武装力量。",
        "disable": 0
    },
    {
        "Key": "Loading001_09",
        "zh_CN": "尤弥尔",
        "disable": 0
    },
    {
        "Key": "Loading001_10",
        "zh_CN": "在零区中出没的强大泰坦，似乎与首次降临事件中现身的原初泰坦有极为相似的外观，没有更多证据前被认定为同一个存在。",
        "disable": 0
    },
    {
        "Key": "Loading001_11",
        "zh_CN": "缓冲区",
        "disable": 0
    },
    {
        "Key": "Loading001_12",
        "zh_CN": "零区最外围的区域，泰坦污染相对较少，尚有大量居民滞留其中，是郊狼和降临团都非常活跃的区域。",
        "disable": 0
    },
    {
        "Key": "Loading001_13",
        "zh_CN": "污染城区",
        "disable": 0
    },
    {
        "Key": "Loading001_14",
        "zh_CN": "原本的废弃城区中出现泰坦物质堆砌，并弥漫着泰坦污染的区域。居民已经全部撤离，无人居住。当初仓促撤离时留下的混乱和破坏痕迹依旧清晰可见。",
        "disable": 0
    },
    {
        "Key": "Loading001_15",
        "zh_CN": "深水区",
        "disable": 0
    },
    {
        "Key": "Loading001_16",
        "zh_CN": "距离零区中心最近的区域，泰坦污染极其严重，街道遍布巨大的泰坦物质，甚至出现了失重区域。",
        "disable": 0
    },
    {
        "Key": "Loading001_17",
        "zh_CN": "槲寄生空间站",
        "disable": 0
    },
    {
        "Key": "Loading001_18",
        "zh_CN": "世界树公司名下的私人空间站，曾经作为巴德尔试剂的主要生产基地，目前已与地球断开联系，原因不明。",
        "disable": 0
    },
    {
        "Key": "Loading001_19",
        "zh_CN": "尤克特拉希尔",
        "disable": 0
    },
    {
        "Key": "Loading001_20",
        "zh_CN": "零区的最中心，不知何时出现了宛如植物一般的巨大泰坦物质集合体，由于泰坦污染浓度过高，目前无人能涉足其中进行调查。",
        "disable": 0
    },
    {
        "Key": "Loading001_21",
        "zh_CN": "瓦尔基里游戏",
        "disable": 0
    },
    {
        "Key": "Loading001_22",
        "zh_CN": "由世界树主办，曾是全球最受欢迎的竞技节目。主角们是健康且充满活力的少女们，在后疫情时代，她们的出现填补了人们精神世界的空虚。",
        "disable": 0
    },
    {
        "Key": "Loading001_23",
        "zh_CN": "逐光者",
        "disable": 0
    },
    {
        "Key": "Loading001_24",
        "zh_CN": "由追求刺激和冒险的中上阶层青少年组成，将自己闯进隔离区的行为称为“逐光冒险”，并自行在网上直播。",
        "disable": 0
    },
    {
        "Key": "Loading001_25",
        "zh_CN": "第五研究所",
        "disable": 0
    },
    {
        "Key": "Loading001_26",
        "zh_CN": "世界树公司在降临事件前建立的研究所，位于如今的深水区内。在降临事件后的一次事故后，第五研究所及周边地区被封锁，至今仍被黄色雾霭笼罩。",
        "disable": 0
    },
    {
        "Key": "Loading001_27",
        "zh_CN": "临时营地",
        "disable": 0
    },
    {
        "Key": "Loading001_28",
        "zh_CN": "位于第五研究所外围的临时营地，周边污染较轻，使用各种设备隔绝了剩余的污染，后勤和研究人员得以驻扎于此。",
        "disable": 0
    },
    {
        "Key": "Loading001_29",
        "zh_CN": "共振器",
        "disable": 0
    },
    {
        "Key": "Loading001_30",
        "zh_CN": "位于第五研究所最深处的大型设备，能引发大范围的共振，受到共振冲击的人会转变为信息态幽灵，融入意识海洋之中。",
        "disable": 0
    },
    {
        "Key": "Loading001_31",
        "zh_CN": "黄色雾霭",
        "disable": 0
    },
    {
        "Key": "Loading001_32",
        "zh_CN": "弥漫在第五研究所周边的特殊雾霭，有目击者宣称，他们亲眼见到了同伴消失在雾中，同时又有诡异的陌生人突然出现……",
        "disable": 0
    },
    {
        "Key": "Loading001_33",
        "zh_CN": "瓦尔哈拉",
        "disable": 0
    },
    {
        "Key": "Loading001_34",
        "zh_CN": "由意识和能量构成的空间，埃达口中“人类的最终归宿”，其存在本身就称得上是奇迹。",
        "disable": 0
    },
    {
        "Key": "Loading001_35",
        "zh_CN": "芬布尔之冬",
        "disable": 0
    },
    {
        "Key": "Loading001_36",
        "zh_CN": "由埃达引发的世界范围的灾难，在各地区都出现了类似“树”的泰坦结晶，并持续散发泰坦污染。",
        "disable": 0
    },
    {
        "Key": "Loading001_37",
        "zh_CN": "海滨沙滩",
        "disable": 0
    },
    {
        "Key": "Loading001_38",
        "zh_CN": "游轮码头附近的海滩，能满足对海岛的大部分幻想，是平日里游客最多的地方。",
        "disable": 0
    },
    {
        "Key": "Loading001_39",
        "zh_CN": "度假区",
        "disable": 0
    },
    {
        "Key": "Loading001_40",
        "zh_CN": "临近拉美西斯酒店的区域，小吃摊和冷饮店随处可见，供电和网络设施也一应俱全。",
        "disable": 0
    },
    {
        "Key": "Loading001_41",
        "zh_CN": "雅卢遗迹",
        "disable": 0
    },
    {
        "Key": "Loading001_42",
        "zh_CN": "基本没有被开发过的区域，最大程度保留了原住民的生活痕迹。",
        "disable": 0
    },
    {
        "Key": "Loading001_43",
        "zh_CN": "遗迹内部",
        "disable": 0
    },
    {
        "Key": "Loading001_44",
        "zh_CN": "长满蓝色花朵的昏暗通道，花朵如同幽焰一般，映照着刻有文字和图案的石壁。",
        "disable": 0
    },
    {
        "Key": "Loading001_45",
        "zh_CN": "永磁铁道",
        "disable": 0
    },
    {
        "Key": "Loading001_46",
        "zh_CN": "在前耶洛沙联邦期间大量修建的铁道，连通了耶洛沙的东部和西部，并辐射至各大城市。至今仍是世界上首屈一指的长程铁路设计范例。",
        "disable": 0
    },
    {
        "Key": "Loading001_47",
        "zh_CN": "货运专列",
        "disable": 0
    },
    {
        "Key": "Loading001_48",
        "zh_CN": "隶属于巴伦支仪器公司永磁铁道部的列车，名义上是货运专列，但从内部装潢来看，显然也会运送一些特别的客人。",
        "disable": 0
    },
    {
        "Key": "Loading001_49",
        "zh_CN": "耶洛沙冰原",
        "disable": 0
    },
    {
        "Key": "Loading001_50",
        "zh_CN": "耶洛沙大部分领土位于北方冰原之上，只有西部和东部的沿海地区是温暖的海湾，北部海域则常年冰封。",
        "disable": 0
    },
    {
        "Key": "Loading001_51",
        "zh_CN": "钢铁厂楼群",
        "disable": 0
    },
    {
        "Key": "Loading001_52",
        "zh_CN": "耶洛沙人惯以用钢铁抵御苍白，一座座工业城是冰原上跳动的心脏，铁路则作为血管将其连接。",
        "disable": 0
    },
    {
        "Key": "Loading001_53",
        "zh_CN": "奥斯维尔钢铁厂",
        "disable": 0
    },
    {
        "Key": "Loading001_54",
        "zh_CN": "钢铁厂，煤钢复合体的核心，在耶洛沙众多的工业城中，高耸的钢铁厂便是城市的名片。",
        "disable": 0
    },
    {
        "Key": "Loading001_55",
        "zh_CN": "耶洛沙黑街",
        "disable": 0
    },
    {
        "Key": "Loading001_56",
        "zh_CN": "鱼龙混杂、暗流涌动之地，物资，军火，情报，乃至是人，都在这里明码标价。",
        "disable": 0
    },
    {
        "Key": "Loading001_57",
        "zh_CN": "地堡",
        "disable": 0
    },
    {
        "Key": "Loading001_58",
        "zh_CN": "地堡是耶洛沙一系列地下防御工事的统称。早在一个世纪前，地堡就是耶洛沙人民和军队惯用的防御手段。",
        "disable": 0
    },
    {
        "Key": "Loading001_59",
        "zh_CN": "地堡会议室",
        "disable": 0
    },
    {
        "Key": "Loading001_60",
        "zh_CN": "位于地堡深处的会议室，在室内布局和设计上参考了联邦时代古斯塔夫青睐的风格。",
        "disable": 0
    },
    {
        "Key": "Loading001_61",
        "zh_CN": "无名英雄纪念碑",
        "disable": 0
    },
    {
        "Key": "Loading001_62",
        "zh_CN": "用于纪念两次联邦战争中牺牲的耶洛沙战士，随着战争的继续，数量也在不断增加。",
        "disable": 0
    },
    {
        "Key": "Loading001_63",
        "zh_CN": "北风航天中心车站",
        "disable": 0
    },
    {
        "Key": "Loading001_64",
        "zh_CN": "曾经是永磁轨道上平平无奇的一站，在北风航天中心出现树之后，这里成为了唯一进入航天城的入口。",
        "disable": 0
    },
    {
        "Key": "Loading001_65",
        "zh_CN": "军方",
        "disable": 0
    },
    {
        "Key": "Loading001_66",
        "zh_CN": "秩序的维护者，规则的缔造者，真正意义上的世界级强权，也是悬在巨型企业头上的达摩克里斯之剑。",
        "disable": 0
    },
    {
        "Key": "Loading001_67",
        "zh_CN": "苏兹达尔火箭基地",
        "disable": 0
    },
    {
        "Key": "Loading001_68",
        "zh_CN": "航天城内的核心区域，从第一颗人造卫星，到第一次载人航空，都在这里展开征途。",
        "disable": 0
    },
    {
        "Key": "Loading001_69",
        "zh_CN": "指挥中心",
        "disable": 0
    },
    {
        "Key": "Loading001_70",
        "zh_CN": "火箭基地内的指挥中心，可以在这里监控整个基地的情况。录音设备中记录下了数次激动人心的倒计时。",
        "disable": 0
    },
    {
        "Key": "Loading001_71",
        "zh_CN": "发射塔",
        "disable": 0
    },
    {
        "Key": "Loading001_72",
        "zh_CN": "前耶洛沙联邦斥巨资打造的发射塔，时至今日仍是大陆上首屈一指的航天设施。",
        "disable": 0
    },
    {
        "Key": "Loading001_73",
        "zh_CN": "耶洛沙之“树”",
        "disable": 0
    },
    {
        "Key": "Loading001_74",
        "zh_CN": "已经与发射塔融为一体、互相交叠的“树”。从塔顶长出的枝芽宛如新生，亦是埃达嘲讽的微笑。",
        "disable": 0
    },
    {
        "Key": "Loading001_75",
        "zh_CN": "星盘徽记",
        "disable": 0
    },
    {
        "Key": "Loading001_76",
        "zh_CN": "耶洛沙航天事业的象征，循此苦旅，以达天际。",
        "disable": 0
    },
    {
        "Key": "Loading001_77",
        "zh_CN": "树内空间",
        "disable": 0
    },
    {
        "Key": "Loading001_78",
        "zh_CN": "触碰耶洛沙之“树”后看到的空间，瓦尔哈拉的一部分，能感受到大量顽抗与不屈的意识。",
        "disable": 0
    },
    {
        "Key": "Loading001_79",
        "zh_CN": "航空航天博物馆",
        "disable": 0
    },
    {
        "Key": "Loading001_80",
        "zh_CN": "设立于苏兹达尔火箭基地内的博物馆，在过去免费开放给耶洛沙民众，如今已关闭许久。",
        "disable": 0
    },
    {
        "Key": "Loading001_81",
        "zh_CN": "赐福集市",
        "disable": 0
    },
    {
        "Key": "Loading001_82",
        "zh_CN": "由赐福团组织的集市，不知为何不会被泰坦袭击，为零区内的难民提供了大量物资。",
        "disable": 0
    },
    {
        "Key": "Loading001_83",
        "zh_CN": "污染区地下",
        "disable": 0
    },
    {
        "Key": "Loading001_84",
        "zh_CN": "曾经城市内的地下仓库，如今已经满是泰坦物质和“树”的根芽。",
        "disable": 0
    },
    {
        "Key": "Loading001_85",
        "zh_CN": "赐福之地",
        "disable": 0
    },
    {
        "Key": "Loading001_86",
        "zh_CN": "赐福团口中前往永恒乐土的入口，似乎已经有许多人到过这里。",
        "disable": 0
    },
    {
        "Key": "Loading001_87",
        "zh_CN": "？？？",
        "disable": 0
    },
    {
        "Key": "Loading001_88",
        "zh_CN": "现实与虚幻的缝隙，花朵盛开的地方。",
        "disable": 0
    },
    {
        "Key": "Battle001_01",
        "zh_CN": "实用技巧·其一",
        "disable": 0
    },
    {
        "Key": "Battle001_02",
        "zh_CN": "在挑战敌方首领时，合理利用各种控制效果，可以一定程度地降低难度！",
        "disable": 0
    },
    {
        "Key": "Battle001_03",
        "zh_CN": "实用技巧·其二",
        "disable": 0
    },
    {
        "Key": "Battle001_04",
        "zh_CN": "非战斗状态下，场下队员可以自动补充弹药，场上队员冲刺不消耗耐力。",
        "disable": 0
    },
    {
        "Key": "Battle001_05",
        "zh_CN": "实用技巧·其三",
        "disable": 0
    },
    {
        "Key": "Battle001_06",
        "zh_CN": "提升和队员的好感度也可以提高队员的最终伤害！",
        "disable": 0
    },
    {
        "Key": "Battle001_07",
        "zh_CN": "实用技巧·其四",
        "disable": 0
    },
    {
        "Key": "Battle001_08",
        "zh_CN": "瞄准状态会降低移动速度，但能有效提升准确度和稳定性！",
        "disable": 0
    },
    {
        "Key": "Battle001_09",
        "zh_CN": "实用技巧·其五",
        "disable": 0
    },
    {
        "Key": "Battle001_10",
        "zh_CN": "选择合适的伤害类型，可以让战斗更加轻松。",
        "disable": 0
    },
    {
        "Key": "Battle001_11",
        "zh_CN": "实用技巧·其六",
        "disable": 0
    },
    {
        "Key": "Battle001_12",
        "zh_CN": "不同枪种拥有不同的最佳作战距离。",
        "disable": 0
    },
    {
        "Key": "Battle001_13",
        "zh_CN": "实用技巧·其七",
        "disable": 0
    },
    {
        "Key": "Battle001_14",
        "zh_CN": "进入掩体后，前进的同时使用战术闪避或者冲刺，均可直接翻越掩体。",
        "disable": 0
    },
    {
        "Key": "Battle001_15",
        "zh_CN": "实用技巧·其八",
        "disable": 0
    },
    {
        "Key": "Battle001_16",
        "zh_CN": "冲锋枪、突击步枪在低弹量时射击的音效会有轻微差异哦！",
        "disable": 0
    },
    {
        "Key": "Battle002_01",
        "zh_CN": "可破坏部位",
        "disable": 0
    },
    {
        "Key": "Battle002_02",
        "zh_CN": "某些目标的一些部位，在承受一定伤害或者物品破坏力后，会被破坏掉。",
        "disable": 0
    },
    {
        "Key": "Battle002_03",
        "zh_CN": "不可破坏部位",
        "disable": 0
    },
    {
        "Key": "Battle002_04",
        "zh_CN": "某些目标的一些部位，作为部位是可以被部分技能单独命中的，但无法被破坏。",
        "disable": 0
    },
    {
        "Key": "Battle002_05",
        "zh_CN": "弱点部位",
        "disable": 0
    },
    {
        "Key": "Battle002_06",
        "zh_CN": "某些目标身上存在弱点部位，常规射击的普通子弹命中此类部位时，必定造成暴击且不会跳弹。",
        "disable": 0
    },
    {
        "Key": "Battle002_07",
        "zh_CN": "低效部位",
        "disable": 0
    },
    {
        "Key": "Battle002_08",
        "zh_CN": "某些目标身上存在低效部位，此类部位受到的直接伤害都会有不同程度的减少。",
        "disable": 0
    },
    {
        "Key": "Battle002_09",
        "zh_CN": "外甲",
        "disable": 0
    },
    {
        "Key": "Battle002_10",
        "zh_CN": "目标身上的外甲，有概率使常规射击的普通子弹发生跳弹而无法造成伤害。",
        "disable": 0
    },
    {
        "Key": "Battle002_11",
        "zh_CN": "通常护盾",
        "disable": 0
    },
    {
        "Key": "Battle002_12",
