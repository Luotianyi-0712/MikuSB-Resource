        "disable": 0
    },
    {
        "Key": "EndingDes2",
        "zh_CN": "你让誓死战斗的甲胄得到解脱，那些迷失在黄沙中的士兵终于得以安息。",
        "disable": 0
    },
    {
        "Key": "EndingDes3",
