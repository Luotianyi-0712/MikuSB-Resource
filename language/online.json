    {
        "Key": "Forbidzone_WeaponDesc25",
        "zh_CN": "布置1台自动射击台，存在一定时间后会自动撤除",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponName26",
        "zh_CN": "无人机护卫",
