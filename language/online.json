    {
        "Key": "Forbidzone_WeaponName1",
        "zh_CN": "轨道光束",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponDesc1",
        "zh_CN": "引导巨大激光束射向指定坐标，持续对敌方目标造成伤害，具备一定追踪能力，<span color=\"#d68238\">但也会对我方队员造成一定伤害</>",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponName2",
        "zh_CN": "重烈爆破",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponDesc2",
        "zh_CN": "空投1枚重型炸弹，产生1次大范围爆炸，对敌方目标造成大量伤害，<span color=\"#d68238\">但也会对我方队员造成一定伤害</>",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponName3",
        "zh_CN": "集束爆破",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponDesc3",
        "zh_CN": "往一定范围随机多次投放小型炸弹，造成多次小范围爆炸，<span color=\"#d68238\">但也会对我方队员造成一定伤害</>",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponName4",
        "zh_CN": "广面爆破",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponDesc4",
        "zh_CN": "从信号点向前，按排投放小型炸弹，造成多次小范围爆炸，<span color=\"#d68238\">但也会对我方队员造成一定伤害</>",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponName5",
        "zh_CN": "模拟重力",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponDesc5",
        "zh_CN": "在信号点持续制造模拟引力，对敌方目标施加眩晕效果，每2秒对其造成1次真实伤害，<span color=\"#d68238\">但也会对我方队员造成一定伤害</>",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponName6",
        "zh_CN": "机枪塔",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponDesc6",
        "zh_CN": "布置1台拥有一定弹药数量的可操控机枪塔，存在3分钟后会自动撤除",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponName7",
        "zh_CN": "榴弹发射台",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponDesc7",
        "zh_CN": "布置1台拥有一定弹药数量的可操控榴弹发射台，存在3分钟后会自动撤除",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponName8",
        "zh_CN": "综合补给瓶",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponDesc8",
        "zh_CN": "布置1台综合补给器，每名队友均可使用1次综合补给瓶：回复一定生命和50爆发能量，并重置爆发技使用间隔",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponName9",
        "zh_CN": "能量",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponDesc9",
        "zh_CN": "布置1台能量瓶补给器，存在3分钟后会自动撤除，每名队友均可使用1次能量瓶",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponName10",
        "zh_CN": "弹药补给",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponDesc10",
        "zh_CN": "布置1台弹药补给装置，范围内队员射击不消耗子弹且射击伤害提升，持续一定时间",
        "disable": 0
    },
    {
        "Key": "Forbidzone_WeaponName11",
        "zh_CN": "无缝防护",
        "disable": 0
