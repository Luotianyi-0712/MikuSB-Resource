        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 6,
        "Speaker": "患病的少女",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "呜——",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 6,
        "Speaker": "拾荒者",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "想拿药就自己去给赫瓦雷纳的人干活儿！",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 6,
        "Speaker": "拾荒者",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "隔离区的污染早就控制不住了，没人会因为你是小孩子就可怜你！",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "有人说它满是贫穷，苦难，人与人之间从不懂得分享，只会掠夺。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 6,
        "Speaker": "赫瓦雷纳士官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "根据耶洛沙军事占领区，赫瓦雷纳后勤与治安总部，<orange>流民安置委员会</>第四号政令……",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 6,
        "Speaker": "赫瓦雷纳士官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "把他们都吊起来，就吊在月台上。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 6,
        "Speaker": "赫瓦雷纳士官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "让所有进入北风航天中心的人都睁大眼睛好好看看……",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 6,
        "Speaker": "赫瓦雷纳士官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "忤逆赫瓦雷纳司令部的下场是什么。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "也有人说，它因崇尚暴力而招来了残忍。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "粗鲁的，没有敬畏之心的原住民们，正被武装到了牙齿的野兽们奴役……",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 4,
        "Speaker": "情报掮客",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我不信你的神，我只信我自己的口袋，还有我脸上这张嘴。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 4,
        "Speaker": "情报掮客",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "说好了的价码，一个子儿都不能少。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 5,
        "Speaker": "降临团会员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……我只是圣神的代行者，你的亵渎言辞必将招致圣神的责罚！",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 4,
        "Speaker": "情报掮客",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "行了行了快滚吧。你的圣神早就在“责罚”我们了！等隔离区里的那棵“树”把所有人都害死，你们就称心如意啦！",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "蝇营狗苟，邪祟横行……",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这样一个在他人口中如此混乱，如此不堪的国度……",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "却是我的家乡。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "它赐给我生命，赐给我爵位，赐给我悠久历史所孕育出的文化，知识，眼界和雄心。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而迄今为止，我却没有任何能够回报它的东西。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "它用苦寒雕琢了它的子民，让他们生来高傲，倔强，绝不向任何有形之物低头！",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "然而我却眼见着这些骄傲的战士们将他们的矛头指向同胞，在各自的理想和主张的碰撞下两败俱伤……",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "英雄和战士们倒下，站起来的，爬上来的却是外邦的吸血鬼！无耻的蛀虫！",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "霸占我们的果实，毁弃我们的家。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "掠夺我们，囚禁我们，奴役我们……从里到外，侮辱我们的每一寸身体，每一缕灵魂。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "甚至还把这世间最邪恶的种子……播撒在了它的土地上……",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "以至于我的子民们会在绝望和苦痛中变成这种扭曲恐怖的怪物！",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛夫公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但只凭这些……还不足以让耶洛沙人跪地屈服！",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "寒风在碎裂的冰面上留下刻痕，从那些缝隙里反射而出的每一缕光，都是冷的。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一袭白衣的女性迎着不知晨暮的太阳，伫立在空无一人的月台上。",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她的名字是塔季亚娜·奥尔洛娃。她是巴伦支仪器的现任首领，也是前耶洛沙联邦解体后留下的最后一位公爵。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "生于和平，长于战乱，空有头衔的她在耶洛沙遭到军方管制，蒙受泰坦污染的这段苦闷岁月里，把自己活成了一块招牌。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一块危险的，蛊惑人心的招牌。",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "现在，这块招牌就横悬在北风航天中心的门户所在——沙钦列车站的站台上……",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "静静等候着她的客人，以及她挖空心思谋求而来的那份“礼物”。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "尽管多年的沉浮已让她身具出神入化、收放自如的演技。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "尽管黎民的苦难，军阀的暴虐，对她而言都事不关己。",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但今天，她还是忍不住要在心里一次次地演练着……用无声控诉的方式提醒自己去扮演一位合格的耶洛沙统治者。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在她的长袖善舞之下，那位从零区远道而来的尊贵客人将会成为她最好的助力……",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "替她对抗一切，消灾解厄，却也蒙在鼓里。",
        "disable": 0
    },
