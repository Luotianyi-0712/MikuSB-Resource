        "Flag": "",
        "Pos": 0,
        "Speaker": "患病的少女",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "呼……呼……咳咳，嗬啊——！",
        "disable": 0
    },
    {
