    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "泰古通达分部的建筑在明灯节的特殊装饰下，显得更加壮观。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "无人搬运车在空中穿梭，链接天楼的每个角落。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "人群聚集吵闹着，游动的无数灯火让这里显现出一种旧日的安宁。这浓浓的节味似乎能让人忘却被围在隔离区内已近三年的事实。",
        "disable": 0
