        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "芭洛玛",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你来了。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "芭洛玛",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "谢谢你遵守约定……",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "少女的声音随着身形消散，花田深处便多了一朵盛放的类思念体之花。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "肴拾起那朵花，仔细观察着这片被污染的大地上唯一能盛开的花种。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "阳光从方才因战斗被破坏的房顶洒下。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "晶体质感的类思念体反射着七彩的光，将连同肴在内的周遭的一切包裹在缺乏真实感的迷幻氛围里。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我不知此时头盔下的肴是什么表情，只隐约听到一声呢喃。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 6,
        "Speaker": "肴冬至",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "变成这样一朵假花，一点都不美……",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "距离上次事件已经过了一个星期，我来到天台，看到晒太阳的肴。",
        "disable": 0
