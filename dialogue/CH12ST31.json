        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛娃公爵",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc6ep8_orlova_12",
        "zh_CN": "我的爸爸，当着我的面，哭出来了。",
        "disable": 0
