        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛娃公爵",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc6ep8_orlova_10",
        "zh_CN": "耶洛沙的女人可不可以过那种自在的生活，按自己的意愿去做很多选择……",
