    {
        "Key": 3,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奥尔洛娃公爵",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc6ep8_orlova_03",
        "zh_CN": "就好像如果不去战斗的话，耶洛沙人就失去了存在的意义。",
