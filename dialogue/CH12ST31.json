    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛娃公爵",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc6ep8_orlova_06",
        "zh_CN": "他翘着胡子，瞪着眼睛，半张着嘴，说不出话。",
        "disable": 0
