        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛娃公爵",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc6ep8_orlova_13",
        "zh_CN": "一个战争英雄，一个将军，一个公爵，一个……铁打的男人，哭得比我还像个小孩子。",
        "disable": 0
