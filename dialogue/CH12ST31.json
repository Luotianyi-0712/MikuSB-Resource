        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛娃公爵",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc6ep8_orlova_11",
        "zh_CN": "我其实还有很多很多问题想问他，但我……没有再问下去。",
        "disable": 0
