    {
        "Key": 4,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奥尔洛娃公爵",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc6ep8_orlova_04",
        "zh_CN": "就好像……没有那么一个目标的话，耶洛沙……",
