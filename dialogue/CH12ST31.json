    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奥尔洛娃公爵",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc6ep8_orlova_05",
        "zh_CN": "呵……我还记得我问住他了。",
        "disable": 0
