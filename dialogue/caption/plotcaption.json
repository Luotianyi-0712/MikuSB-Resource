        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "阻止我跨越现实与梦境的边界，",
        "disable": 0
    },
    {
        "Key": "TxtCH11EP1K03",
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
