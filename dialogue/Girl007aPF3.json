    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我伸出右手食指，轻轻敲了敲自己的太阳穴。"
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "锚定装置不变，对我的大脑动一点手脚。"
    },
