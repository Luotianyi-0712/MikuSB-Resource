[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "空旷幽深的场馆里，只有我和芬妮的脚步声在回荡。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "偶尔驻足，或迟疑地拐过转角，向着光亮的源头走去。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "雨已经停了，阳光透过穹顶，在恒温恒湿的场馆中映出一道隐约的霁虹。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "起初，只看见一只毛茸茸的爪。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "大部分属于“它”的身体都隐没在了漆黑的山洞中。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "也许是察觉到陌生生物的靠近，那只露在外面的爪舒展了一下。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "锋利又漂亮的爪尖一闪而过，随即收回，山洞里的黑影慢悠悠地踱步出来。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "随着阳光倾泻，终于显露出那一身闪耀的金色毛发。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那是一头雌狮。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哈……",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我听见芬妮倒吸了一口气。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这难道是……",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "狮、狮子？",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮的脸有些涨红，语言组织似乎有点跟不上眼前突增的信息量。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她语气中的震撼甚至盖过了疑问的语调，使这句话听起来更像是某种感叹。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "隔着隐形的防护屏障，那狮子先走向一处雾气蒸腾的清泉石台，秀气地啜饮了几口。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而后迈开四足，从我们面前经过，巡视着它的领地。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "漫不经心甩甩尾巴，留下尾尖上一抹嫣红的残影。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "倘若借用那些资料片中的描述，此刻站在我们面前的应该是——",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "被称为“百兽之王”、狩猎能力卓越、现实中基本无处得见的大型猛兽，狮子。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "然而……",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "等一下，先、先不管这里为什么会有狮子。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "真正的狮子原来是长这个样子的吗？！这不太对吧！",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……然而，此刻真实地出现在我们眼前的，分明是一只体型娇小、胖嘟圆滚的生物。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "纵使和纪录片里的“狮子”有七八分相像，但这副样子与其说威武霸气，不如说呆呆地透着一股憨萌。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "肯定是哪里搞错了吧！",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在芬妮的想象中，狮子应该很高大、很威风，毛发像黄金一样闪耀，吼一声能震天撼地。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这倒不是因为那些有关狮子的纪录片，也不全是因为她拥有着“狮子”的外号。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而是因为…她最爱的达令，会用这个词来称呼她。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "能配得上用来比喻自己的动物，就该是荣耀和勇气的象征，是全世界最闪耀的存在！",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而不是眼前这个动物，虽然可爱……但与一直以来所相信的形象相去甚远。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 9,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哪怕没有那么完美也没关系，偏偏差得这么多……",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 9,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那“黄金狮子”究竟算什么啊？",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮辉耀",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……他曾经答应我，说早晚要找一头真的狮子来让我动手摸一摸。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮辉耀",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "说什么……只要见过了，我就会知道自己在他人眼里到底是个什么样子。还说那样就能让我更坚定自己的本心本性，从小女孩儿变成……",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮辉耀",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "真是胡说八道……本小姐怎么可能会在乎别人的眼光！更何况，我难道还需要从一个已经灭绝了的动物身上学到点什么吗……",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那是气话。",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "事实上，他将她比作“黄金狮子”，会用“小狮子”这样亲昵的称呼来唤她。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "于是她也早已认可这个代号，甚至只要听到他这样叫自己，她就开心得不行。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "算什么呢……还有一直以“狮子”自居的我……",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮的声音渐渐低下去。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "b-1-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "摸摸芬妮的头。",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮就是芬妮。",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "“黄金狮子”的象征与意义，并不会因为任何事情而改变。",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮怔怔地抬起头看向我，眼睛里似乎有什么重新开始悸动。",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "可……达令还记得吗？很久以前你对我说过……",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "只要见过了真正的狮子，我就会知道自己在他人眼里到底是什么样，我会更坚定……",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哼，那时候你还说我是小女孩儿来着……",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "久远的记忆珍藏至今，再度提起，当初的一丝别扭竟酿出了淡淡的甜味。",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是啊，从那时算起，到现在已经过去很久了。",
        "disable": 0
    },
    {
        "Key": "b-2",
        "Flag": "b-2",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "b-2-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "拉起芬妮的手。",
        "disable": 0
    },
    {
        "Key": "b-3",
        "Flag": "b-3",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "b-3-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "吻住她的无名指指尖。",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "当初那个小女孩儿早已蜕变成现在自信又强大的芬妮了，不是吗？",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮眼睛睁大，一眨不眨地看着我。",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "当我们看到影像资料中的狮子，那只是一个画面，一个隔着屏幕的动物。",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "所有的投射，其实只来源于内心对某个品质的想象与渴望。",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而那个想象与渴望的寄托之处。",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "对我来说，是你，芬妮。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是在战斗中倔强又骄傲的你。",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是在我身边自信又闪耀的你。",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是在平凡幸福的日子里，也会偶尔有纠结、有困惑的你。",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你的表现、你的蜕变，还有你为我的付出，一点一滴都是我亲眼所见。",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮所做的一切，不会因为区区一头狮子就被否定。",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "反倒在我眼里，是芬妮在给“狮子”这个名词赋予新的荣耀。",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这才是我所喜欢的芬妮……",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不等我说完，嘴唇已被柔软的触感堵住。",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮紧紧环住我的腰，像是要把整个人都埋进我的怀抱里。",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "周身被她散发的香甜包裹，嘴角却尝到浅浅的咸。",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "过了好一会儿，芬妮才终于松开搂着我的双臂。",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "少女浓密的睫毛上还沾着点点泪珠，眼眸中的失落却已经一扫而空，恢复了往日骄傲的样子。",
        "disable": 0
    },
    {
        "Key": 71,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "达令，我想在这里留下一张照片。",
        "disable": 0
    },
    {
        "Key": 72,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哦？想和这只胖嘟嘟的狮子合影吗？我来帮你拍。",
        "disable": 0
    },
    {
        "Key": 73,
        "Flag": "",
        "Pos": 6,
