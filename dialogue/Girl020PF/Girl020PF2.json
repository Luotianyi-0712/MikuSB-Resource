    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这只大猫做出来，要花不少工夫吧。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "什么大猫，这个是朔州的神兽，叫貔貅，貔貅！",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好吧，貔貅。所以……它的作用是用来招呼客人的？",
        "disable": 0
    },
