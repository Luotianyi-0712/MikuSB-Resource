        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是啊，绩效奖金，最后被我手拿把掐，虽然我刚入队的时候，成绩还是垫后的。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
