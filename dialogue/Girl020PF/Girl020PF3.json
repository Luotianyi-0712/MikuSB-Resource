        "Key": 30,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "后来我又向干娘许愿，我想要长高两厘米……",
        "disable": 0
