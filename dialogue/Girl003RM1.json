        "Key": 70,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "人饿了就得吃饭，渴了就得喝水，困了就要睡觉……",
        "disable": 0
    },
