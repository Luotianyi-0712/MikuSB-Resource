    {
        "Key": 52,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这样一来，我的心中反而生出了些许愧疚感。",
        "disable": 0
    },
