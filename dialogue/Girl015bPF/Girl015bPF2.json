        "Key": 31,
        "Flag": "",
        "Pos": 5,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "太久了。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 4,
        "Speaker": "研究员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这……",
        "disable": 0
