    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "研究员有些为难地看向我，而凯茜娅随即笑了笑，将她的机枪拿到了身前。",
        "disable": 0
