[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "清晨。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "规律作息养成的生物钟准时地将我唤醒，恍惚了片刻后，我轻轻掀开被子一角，走下了床。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在我的床上，凯茜娅正伴随着均匀的呼吸声，沉沉熟睡着，嘴角还挂着一抹浅笑。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "虽然我们已经恒约，但比起去她的房间共度春宵，她倒是一如既往的，更喜欢在晚上突然出现在我的房间里，昨天也不例外。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我没有打搅她的好梦，而是走到了一旁的桌前，打开终端开始浏览今天要处理的文件和报告。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一小时后，在我手头的工作告一段落的同时，我也听到身后传来翻身的声音。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "凯茜娅？",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 9,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……嗯。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "带着半梦半醒的声音，她回应了我的呼唤。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我随手关掉终端，走回床边，抓住了她伸来的手。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我记得，你是不爱睡懒觉的那种类型吧。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "按她自己的说法，把时间花在睡觉这件事上实在太过浪费。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "偶尔多睡一会儿，也挺不错的。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我得提醒一下，你这样可不能算是“偶尔”了，也并不是“多睡了一会儿”。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "从恒约之后，你就越来越嗜睡了吧，每天睡眠时间已经快到12个小时了。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这都多亏了你……对吧，亲爱的？",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "凯茜娅慵懒地打了个哈欠，随即侧过身子，用一只手撑着脑袋，玩味地看向我。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "起初我还担心这种嗜睡症状会不会是新的战术套装所导致，但我带着她去医疗部检查后，并没有发现任何异常。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "所以，原因就只有一个了。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我的目光投向了凯茜娅身下凌乱的床铺。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "从卫城学院返回后，凯茜娅与我待在房间里的时间越来越久。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在反复的拉扯中，凯茜娅终究在体能方面输给了我。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "到最后，她就越来越需要靠睡眠来恢复精力了。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你说得没错。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "所以我觉得，我们应该节制一些……",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我的话还没说完，她忽然扑了过来，修长的双腿像蛇一样紧紧缠住了我的腰肢。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那可不行。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她吻了上来，烈焰般的红唇与蓝色的双瞳交相辉映着，如之前的无数次那样，不由分说地将我拽入了本能的深渊之中。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "回过神时，已是日上三竿。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "望着房间中熟悉的天花板，我不由得下定了决心。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "今天，至少今天，我一定要把凯茜娅带出门才行。",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我一边思考着，一边看向正在梳理头发的凯茜娅。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "凯茜娅，你有什么想去的地方吗？",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "亲爱的，这座城市里有意思的地方可不剩多少了。",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但出远门的话，你的时间应该不太够吧？",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "毕竟，你可是肩负海姆达尔和整个世界树的男人呢~",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "虽然听起来像是在揶揄我，不过事实的确如此。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "先前和凯茜娅的蜜月旅行就已经花掉了不少时间，就算我心中再怎么想陪她，公司里积压着的大量文件也不愿意放过我。",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "更何况，还有那么多的天启者们在瓜分着我的空余时间。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "所以说，在房间里缠绵反而是最好的娱乐方式，对吧？",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "对，对吗？",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "有那么一瞬间，我似乎真的认同了凯茜娅的观点。",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "所幸在现在这空当，我的大脑还算清醒。",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "任何事情都讲究一个适度，不能再这样放纵下去了。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "眼见计划没有得逞，凯茜娅倒也不生气，反而眯起眼睛，笑着看向我。",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好啊，那亲爱的觉得，我们今天应该去哪玩呢？",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "起码，先去填饱肚子吧。",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "公司外，虚数餐厅。",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这家豪华餐厅原本属于前董事派，后来陶不由分说地将其转赠给了我。",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在那之后，我既没有过问，也没有再来过这里。不过，既然凯茜娅想体验些新花样，那这里倒是不错的选择。",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "提前和替我打理餐厅的店长打过需要包场的招呼后，我便带着凯茜娅来到了餐厅。",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这家店有什么特别的地方吗？",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯，这里的特色是<orange>分子料理</>。",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "分子料理？",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "简单来说，就是用各种现代科技去处理食材，创造出新奇的口感和菜品形式。",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "比如，把各种饮品和汤汁做成由薄膜包裹的小球，或是在低温真空环境中处理肉类，做出嫩滑的口感。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在成年病危机前的黄金年代，这种烹饪方式风靡过一段时间。但在那之后，就和很多东西一样，逐渐无人问津了。",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "有趣，没想到你还钻研过这种东西。",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "实际上，这些信息都是转述自陶。",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "每当聊起黄金年代的事情，她总是如数家珍。",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "总之，就按照你的喜好来点菜吧。",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我将用于点餐的终端递了过去，凯茜娅扫视了几眼后，又轻笑着将其推了回来。",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我有一个，更好的想法。",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "黑暗。",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "黑暗的来源自然是蒙在我眼前的布条。准确来说，那是我的领带。",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "几分钟前，凯茜娅将它解下，又蒙在了我的眼前。",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 9,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "准备好了吗？",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我的耳边传来她的声音，我则点了点头。",
        "disable": 0
    },
    {
        "Key": 71,
        "Flag": "",
        "Pos": 9,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "啊~",
        "disable": 0
    },
    {
        "Key": 72,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我张开嘴，一颗金桔大小的球体随即被放入了我的口中。",
        "disable": 0
    },
    {
        "Key": 73,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "牙尖轻而易举地刺破了薄膜，我的口中随即充满了复杂的香气。",
        "disable": 0
    },
    {
        "Key": 74,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "尝起来，既有水果的清香，又似乎带着海洋的厚重，还隐约藏着牛奶的味道。",
        "disable": 0
    },
    {
        "Key": 75,
