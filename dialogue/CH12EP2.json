    },
    {
        "Key": 78,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在一列火车的车厢连接处，在昏暗又狭小的缝隙里，我和晴两个人正以一种十分暧昧的方式抱在一起。",
        "disable": 0
