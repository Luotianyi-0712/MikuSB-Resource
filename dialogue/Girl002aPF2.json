        "Flag": "",
        "Pos": 5,
        "Speaker": "队员乙",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "只是一次训练行动而已，为什么……为什么我要遭遇这种事情！？",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 4,
        "Speaker": "队员甲",
        "RealSpeaker": "",
        "WwiseEventID": "",
