    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "半晌，她似乎是下定了什么决心一样，深吸了一口气，重新抬起头看向了我。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 6,
        "Speaker": "瑟瑞斯",
        "RealSpeaker": "",
        "WwiseEventID": "",
