[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "深夜。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "躺在陌生的床上，过往的记忆如电影一般在我眼前掠过。俱卢、耶洛沙、雅卢岛、第五研究所……",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "最终，画面定格在这一切发生之前。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那是我和里芙的故事。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 1,
        "Speaker": "芙提雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "大家辛苦啦！都别客气，今天芙提雅老师请客！",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 3,
        "Speaker": "芬妮",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "分析员快说说，我今天的表现是不是很不错？",
        "disable": 0
    },
    {
        "Key": "b-1",
        "Flag": "b-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "b-1-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "确实",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "b-1-2",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你和里芙配合得很好",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在今天的任务中，海姆达尔部队发挥出色，给予了突然出现的泰坦海拉重创。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "虽然没有完全将其消灭，但队伍中没有人受伤，也顺利完成了预定目标，可以说是接近满分的战果了。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 3,
        "Speaker": "芬妮",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "就不能单独夸我吗？分析员真小气。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 2,
        "Speaker": "里芙",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 2,
        "Speaker": "里芙",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "因为我的失误，才放走了那只海拉。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你当时站在它的正前方，受到的攻击最多，瞄准失误也在所难免，别给自己太大压力。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 2,
        "Speaker": "里芙",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但那时海拉已经重伤，附近也没有其他泰坦出现的迹象，如果我打中的话，消灭它的希望很大……",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "说到一半，里芙扫视了一眼众人的表情，又重新低下了头。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 2,
        "Speaker": "里芙",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "抱歉，我想一个人待一会。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没有留给任何人说话的机会，她低着头快步走出了大厅。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……还是老样子啊。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "海姆达尔部队中的所有队员，连同我在内，都或多或少被降临事件改变了人生的轨迹。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而在我们之中，里芙大概也是受到影响最大的一类。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她作为冠军的一切，都在本属于她的比赛中，被摧毁殆尽。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "所以，每当她对泰坦流露出那种森冷的仇恨、每当她对自己的要求高到近乎苛责的程度，我都很难去劝阻她。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "即使知道她一向很把我的话放在心上，但这种刻在骨子里的执念，并不是言语所能简单改变的。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 3,
        "Speaker": "芬妮",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "星期三这家伙，真不让人省心。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 1,
        "Speaker": "芙提雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "到吃饭的时候应该就会回来了吧。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "又不是流浪猫……",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我盯着里芙离开的大厅门口，最终还是摇了摇头。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这样放着不管也不是办法。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "庆功宴……暂且允许我放一次鸽子吧。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好说歹说哄好了芬妮和芙提雅，我终于得以走出基地，寻找方才离开的里芙。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "大致估了个方向后，我在公司的走廊中快速穿行着。行至拐角，险些和忽然出现的人撞到一起。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "？？？",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "呀！",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "伴随着惊呼，白色的文件纸从面前的人手中飞出，散了个满天。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "幸好，对方是熟人。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "分析员，在走廊里跑步可是很危险的！",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "抱歉抱歉……",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我帮卡罗琳捡起散落了一地的文件，目光却忍不住往她身后瞟。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你在找什么吗？",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "里芙。",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那你直接问她在哪不就好了，搞得和家里的猫丢了一样。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "情况有点复杂，总之你看到她了吗？",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你等等啊……",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "卡罗琳打开了手中的平板，快速戳了几下，随即抬起头看向我。",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "找到了，喏，她一路出了公司，朝庚号大门的方向去了。",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "平板上是公司的监控画面，如卡罗琳所说，里芙的确离开了公司。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你还能调取公司的监控？",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我可是情！报！官！不要小看我的情报网！",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这是什么情报网……",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "总之，要追她就快去吧，老板那边我会帮你打招呼的。",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "谢了，你是全天下最好的情报官。",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "将手中的文件塞给卡罗琳后，我扭头便朝着电梯跑去。",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "还有，别忘了现在尤克特拉希尔正在活跃期！别乱来！",
        "disable": 0
    }
]