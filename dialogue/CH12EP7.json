        "Key": 30,
        "Flag": "",
        "Pos": 4,
        "Speaker": "苔丝",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……我是个魔术师，而那个人……是我最重要的观众。",
