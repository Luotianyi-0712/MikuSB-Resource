        "Key": 61,
        "Flag": "",
        "Pos": 6,
        "Speaker": "琴诺悖谬",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "今天要给分析员讲的是，莫尔索和我被关禁闭的事……"
