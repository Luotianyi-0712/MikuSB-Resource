        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我抱起她，她一时间没反应过来，离开键盘的手还在机械地敲动着。",
        "disable": 0
