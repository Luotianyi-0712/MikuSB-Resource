    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她呆滞地望着我，眼里已经没有了往日的神采。",
        "disable": 0
