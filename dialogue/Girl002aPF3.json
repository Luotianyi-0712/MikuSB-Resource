        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "女武神那名副其实的英姿在我的想象中翻腾，幻化成另外一个更加伟岸的形象。",
        "disable": 0
