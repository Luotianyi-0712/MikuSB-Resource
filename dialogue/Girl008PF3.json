        "Key": 7,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "有话等会儿路上再说。",
        "disable": 0
    },
