[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "等我和瑟瑞斯回到水上乐园，这里的气氛依旧火热。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "少女们在海边搭起了灯光和舞台，开始轮番上阵，大展歌喉。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "此时在台上拿着话筒的，正是陪伴了我们一天的主持人米娅。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "虽然刚才经历了不少波折，不过她看上去倒是一点害怕的模样都没有。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "甚至一副自来熟的样子，感觉已经完美融入了海姆达尔部队。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "大家就着有活力的曲子，摇动着手上的灯带，仿佛要将所有的快乐都注入这个夏夜。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "沙滩上交错着各种颜色的光线，但我却敏锐地察觉到那抹金色又悄然消失了。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "循着感觉，我从热闹的沙滩上退场，来到了芬妮的房间门口。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "按下门铃后，很快屋子就为我敞开，沐浴露的香气涌出，温热而诱人。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "水汽在灯光下形成朦胧的光晕，而芬妮就站在那光晕之中。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意泳装",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep11_girl008_01",
        "zh_CN": "就知道达令一刻也离不开我~只是回来洗个澡，都让你这么不放心？",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她的声调微微上扬，尾音还带着几分撒娇的意味。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "“只是洗个澡”而已吗？",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "虽然芬妮说得简单，但实际上她浑身上下都只能用精致来形容。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "小到恰到好处的妆容，大到……",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她换上了一件新泳衣。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "和我之前预计的一样，这件泳衣好看极了，将她衬得明艳动人。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "每一处剪裁都贴合着她的身形，勾勒出令人屏息的曲线。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "被我戳穿后，芬妮也不好意思起来，脸颊上蔓延出淡淡的绯色。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意泳装",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep11_girl008_02",
        "zh_CN": "好吧~我承认，确实不是“只洗了个澡”那么简单。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她转了个圈，光着脚踩进了房间里面，眼中的神情明亮而迷人。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我关上门跟着她走了进去，房间里明明开着冷气，温度却似乎比外面更加暖。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "几步之后，脚底传来了特别的触感。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "往下一看，原来是几片玫瑰花瓣。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她面向我，砰地一下坐在了床上，更多的玫瑰花瓣从床上落到了地上。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意泳装",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep11_girl008_03",
        "zh_CN": "房间里的所有，都是我特别准备过的哦~",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "少女小声笑了起来，带着几分得意。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "环视了一圈房间，确实每个角落都有精心布置痕迹。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "蜡烛的光芒在墙上投下摇曳的影子，空气中弥漫着淡淡的香氛气味。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
