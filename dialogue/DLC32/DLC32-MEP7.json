[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "海边的殿堂、神圣的誓言、彼此的约定，这一切仿佛还在昨日。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮的问题让我忽然意识到，原来距离我们恒约，已经过去了那么多个日日夜夜。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "正因为现在很幸福，所以她才会为未来如何延续这份甜蜜，而感到不安吧。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我一边思考着如何回答，一边用指尖轻轻叩着椅子的边缘。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一成不变的人是什么样，重复单调的生活又是什么样？",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我好像……有点想象不出。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我的回答让她有些愣住，眸中闪过一丝意外，随即支支吾吾地开始解释描述起来。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep7_girl008_01",
        "zh_CN": "一成不变的人就是……",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep7_girl008_02",
        "zh_CN": "你对她了如指掌，从她身上已经挖掘不出任何惊喜和新鲜感。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep7_girl008_03",
        "zh_CN": "和她在一起的生活更是……",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮在脑中搜寻着合适的词汇，但相处的日日夜夜却慢慢浮现于脑海中。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "每天早晨，明亮的光线都会毫不留情地透过玻璃涌进房间，洒在自己的脸上。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没办法，他们在夜晚纠缠到沉沉睡去前，总记不得要拉起窗帘这件事。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但达令还是尽力用自己的身体挡住那些强烈的光线，营造出一片温柔的阴影。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "往身下看去，被子早就被踢得乱七八糟，一半无辜地拖到了地上。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "自己的腿更是放肆地搭在达令的身上，两人的身体紧紧贴合着。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "虽然眼睛带着倦意，完全睁开还有些困难……",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但自己还是喜欢在这个时刻，半眯着眼观察着最爱的人。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "达令睡觉的时候总是很安静，眉目格外舒展，没有平时工作时的紧绷和严肃。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "想到这是因为自己待在身边而流露出的安心，芬妮就忍不住捏住被角偷笑。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她会小心翼翼地伸出手，用指尖轻抚他的眉毛、鼻梁，感受着每一寸肌肤的温度。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "当指尖滑到嘴唇的时候，芬妮就会不自觉地想起昨晚的狂风骤雨。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "还没等太阳将房间晒得暖烘烘，她先感受到一阵燥热，脸颊也染上了绯红。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "为了报复达令昨晚让自己那般失态，少女会对小分析员做些手脚……",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "再眼中满是狡黠地欣赏达令在半梦半醒中微微皱眉。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "等他稍微有些醒来的征兆，将手牢牢环在自己腰间时，调皮的小狮子才会心满意足地放弃自己的“报复”。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在达令即将睁眼时，自己会悄悄贴近他的耳畔，用那种格外娇软的语调轻声问候。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "芬妮病号服",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep7_girl008_04",
        "zh_CN": "早安，亲爱的~",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而醒来后的达令一定会伸手揉揉自己的头发，动作熟练而宠溺。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "然后用略带沙哑的嗓音回答。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "早安，小狮子。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "阳光会慢慢移动，房间里的光线越来越明亮，提醒着新的一天已经开始。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但芬妮总舍不得起床、离开二人温暖的小世界。",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "直到某人用特别的“手段”，彻底唤起自己的精神。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这样的日子……几乎是每天如此。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一成不变的人是什么样，重复单调的生活又是什么样？",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮发现自己根本回答不了这个问题，因为它从根本上就是个伪命题。",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "和达令度过的每一天，都鲜活得只要自己想起，嘴角就会带着笑意。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "腰间仿佛还能感受到他环抱自己时的力度，指尖还残留着触碰他皮肤时的温热质感。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "习惯也许会催生厌倦，但这些真切的感觉提醒着自己，这份感情远比习惯深刻得多。",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "日复一日的爱意，已经成了自己生命中无法抽离的一部分。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "像空气、像呼吸、像心跳一样自然而必需。",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "少女眼中聚起水光，却迟迟没有落下。",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "仿佛回忆中的晨曦融化在了眼底，闪烁着动人的光泽。",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我知道，此时此刻我们想着同样的画面。",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这是独属于相爱之人的心灵感应。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "告诉小狮子一个秘密。",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep7_girl008_05",
        "zh_CN": "嗯？什么？",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "大多数时候的早晨，都是我先醒来哦。",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep7_girl008_06",
        "zh_CN": "怎……怎么会呢！",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮瞪大了眼睛，一脸不敢置信的表情。",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "直到对上我确信的眼神，她才知道原来自己那些小动作，都被我知道得清清楚楚。",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "红晕瞬间从脸颊蔓延到耳根，连她的脖颈都染上了淡淡的粉色。",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep7_girl008_07",
        "zh_CN": "是我睡相太差，把亲爱的吵醒了？",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她有些懊恼地问道，声音中带着歉意和担心。",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不是。",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我只是……",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "迫不及待地迎来每一个有你的早晨。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那时的天空还未褪去夜的深蓝，房间里笼罩着一层朦胧的灰色薄纱。",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "借着窗外透进的那一点点微光，也能将芬妮微微红肿的唇瓣看个清楚。",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她颈间和锁骨处还留着浅浅的痕迹，如同夜色中绽放的花朵。",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我想，这些印记大概和我背后的抓痕一样，都残留着火热的温度。",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "往往在这个时候，怀中的小狮子就会开始轻声说起梦话。",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 0,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep7_girl008_08",
        "zh_CN": "唔……达令，不要了，不要了。",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 0,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep7_girl008_09",
        "zh_CN": "明天还得出勤呢，会起不来的……",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我知道她睡觉时喜欢贴近我的心口，把腿搭在我身上。",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "所以即使手臂酸麻，我也保持着令她睡得安稳的姿势。",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "知道她总是喜欢在我醒来前“动手动脚”。",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "因而我总是刻意装睡，享受着她以为我还在梦中时那些大胆的亲昵举动。",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我对她的了如指掌，不是因为她一成不变。",
        "disable": 0
    },
    {
        "Key": 71,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而是两个灵魂，在无数个日日夜夜中磨合，才沉淀下最醇厚的爱意。",
        "disable": 0
    },
    {
        "Key": 72,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "回到那个问题。",
        "disable": 0
    },
    {
        "Key": 73,
