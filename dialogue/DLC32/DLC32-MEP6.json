[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "演绎桌团距离走向结局只差最后一步。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "按照“龙舌兰”笔记所示，只要在酒店大厅用银粉画出法阵，再配合咒语就能将怪物彻底驱逐。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "米娅在前面带着路，边走边翻阅着剧本，嘴里还不停地念念叨叨。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 9,
        "Speaker": "米娅",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_npc098_01",
        "zh_CN": "唔……马上就要进战斗了，BOSS的属性……",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "意识到自己的声音在空旷的走廊里显得过于清晰，她又连忙捂上嘴，回头打量着我们。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "见我们神色平常，她放下心来，松了一口气。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米娅",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_npc098_02",
        "zh_CN": "还好，还好，差点剧透了。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一时间，走廊里又只剩米娅哗啦啦翻阅剧本的声音。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 9,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_girl008_01",
        "zh_CN": "诶？",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "身后忽然传来一声芬妮的惊呼，清脆而突兀。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我转过身，但眼前只是空荡荡的走廊，顶上的灯光闪烁不定，明暗交替间塑造出令人不安的氛围。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一小簇微风滑过我的手掌，带着异样的凉意。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "仿佛有什么看不见的存在正扰动着空气的流动，在我们察觉不到的维度里悄然穿行。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "米娅和奈莉德也意识到了气氛的微妙变化，后者更是带着警惕的神色，敏锐地环顾四周。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米娅",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_npc098_03",
        "zh_CN": "唔……怎么少了一个人？",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "米娅歪着脑袋，朝我身后望去。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在确定芬妮没有藏在视线盲区后，她的表情更加困惑，眉头也蹙了起来。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "叮咚~叮叮咚~叮叮咚咚~",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "截取自流行歌曲的铃声响起，曲调分外元气有活力，显然不是我和奈莉德的风格。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "只看到米娅慌慌张张地摸到终端的一个角，在拿出口袋时，又牵扯出一大串五花八门的挂坠。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "除了那些可爱的挂坠，终端本身的粉红色外壳和上面各式各样的贴纸也足够惹眼。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在看了一眼来电显示之后，她尴尬地笑了笑，利落地按下了挂断键。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不接吗？",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "米娅摇了摇头，表情也变得认真起来。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米娅",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_npc098_04",
        "zh_CN": "我可是专业的主持人，怎么能在游戏进行的时候，接私人电话呢？",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "可没过几秒，铃声又再度响起。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "带着为难的神色，米娅的手指在屏幕上犹豫了片刻，最终还是再度按下了挂断。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不如，我们中场休息一下吧？",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我猜芬妮大概是玩累了，所以半路找了个地方休息。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我去看看她的情况，你们就先去大厅等我们吧。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这样，米娅也不会错过重要的来电了。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我递给奈莉德一个眼神，她立刻心领神会，不动声色地点了点头。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米娅",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_npc098_05",
        "zh_CN": "中场休息吗？完全没问题~",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米娅",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_npc098_06",
        "zh_CN": "那我和奈莉德就先去大堂等你们，要快点过来哦~",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "米娅挥挥手，动作轻快，转而抱着厚厚的故事剧本和奈莉德继续向前。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她们的身影刚消失在走廊的转角处，我就收到了奈莉德发来的简讯。",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德泳装",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_girl021_01",
        "zh_CN": "这座酒店有古怪？",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "\\n现在还不能确定，只是瑟瑞斯的话和芬妮突然消失让我有些在意。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "把这些告诉克罗瑞娜，这家酒店是吉诺拉家族投资建设，她说不定会有头绪。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德泳装",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_girl021_02",
        "zh_CN": "那我们为什么不直接离开，再找人来调查清楚？",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "\\n至少现在看来，并没有什么威胁到了我们的安全。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "兴师动众前，我想先证实我的猜测。",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "其实除了目前这个理由，我还有个小小的私心。",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅病号服",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32st1_girl001_08",
        "zh_CN": "作为幕后小队，我们肩负着将背景故事演绎得生动鲜活的重任！",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅病号服",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32st1_girl001_09",
        "zh_CN": "所以我的计划是，大家一起从老恐怖片里汲取灵感，提升演技~",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她为我们能玩得开心而忙前忙后，如果可以，我不希望游戏就这么草草结束……",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德泳装",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_girl021_03",
        "zh_CN": "嗯。",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "终端屏幕又短暂地闪烁了一下，上面是奈莉德最后简短的回复。",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "虽然只有一个字，但却透露着十足的相信和支持。",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "处理好一切，奈莉德稍稍转身看向不远处的米娅。",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "虽然她半捂着嘴，也刻意压低了声音，但毕竟奈莉德是天启者，敏锐的听力还是将通话内容听了个清楚。",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 0,
        "Speaker": "米娅妈妈",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_npc099_01",
        "zh_CN": "米娅，怎么刚才不接电话？夏令营玩得还开心吗？",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米娅",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_npc098_07",
        "zh_CN": "很开心啦~",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米娅",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_npc098_08",
        "zh_CN": "不过妈妈，我这会和同学在逛商店街，不太方便接电话啦……",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德泳装",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_girl021_04",
        "zh_CN": "（原来……是家人打来的电话吗？）",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不知不觉间，奈莉德朝米娅的方向挪了几步，处在一个既能提供保护、又不显得冒犯的距离。",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "如果真有什么意外发生，至少不要让普通人卷入其中。",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "奈莉德这么想着。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而正在庄园内和小姨一起享受悠闲下午茶时光的克罗瑞娜，在看到消息后，蹭地一下从椅子上跳了起来。",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "金褐色的茶水倾洒了出来，落在克罗瑞娜繁复的裙子上，很快晕成水渍。",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "米拉刚想厉声说些什么，但看到克罗瑞娜越发自如的情态，她还是抿了抿唇，把想说的咽了下去。",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "只是在优雅地喝下一口茶后，轻飘飘地念叨了一句。",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_npc096_01",
        "zh_CN": "这才去了世界树几天，一惊一乍可不是淑女的……",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "话还没说完，一阵迅风吹过，克罗瑞娜已经没了人影，只剩桌布下摆还在摇晃。",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "恍惚间，米拉似乎还看见克罗瑞娜的背后出现了一双小翅膀，扑腾着助力。",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep6_npc096_02",
        "zh_CN": "这么着急，一定又是为了那个男人……",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "米拉无奈地叹了一口气。",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在复杂的酒店回廊中穿行几圈后，我总算找到了芬妮。",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她坐在可以被称为整座酒店风光最美的角落。",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 0,
