        "Key": 23,
        "Flag": "",
        "Pos": 6,
        "Speaker": "瑟瑞斯悠游",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep2_girl013_07",
        "zh_CN": "因为它的操控方式和冲浪很相似，所以我就想到了这个一边度假，一边加快适应的好办法。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 6,
        "Speaker": "瑟瑞斯悠游",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep2_girl013_08",
        "zh_CN": "不过……",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她低头看了看自己腿上沾满的细沙，不好意思地笑了笑。",
        "disable": 0
    },
