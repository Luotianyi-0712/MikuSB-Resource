        "Key": 26,
        "Flag": "",
        "Pos": 6,
        "Speaker": "瑟瑞斯悠游",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep2_girl013_09",
        "zh_CN": "因为不太记得住诀窍，所以每次都失败呢。",
        "disable": 0
    },
