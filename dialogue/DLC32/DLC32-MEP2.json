[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "阳光如细碎的金箔洒向海面，舒爽的海风掠过椰林时发出沙沙的私语声。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "悠闲平静之际，造浪机的声势突然大了起来，一股巨浪涌现在海面上。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "浪花翻腾着白色的泡沫，而瑟瑞斯宛如海中精灵般出现在了波涛的顶端。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在晃晃悠悠起伏几秒后，汹涌的潮水开始一次又一次地将她吞没。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "最后，海浪裹挟着她，以势不可挡的架势朝着岸边袭来。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 9,
        "Speaker": "瑟瑞斯悠游",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep2_girl013_01",
        "zh_CN": "啊——！让开让开，呀——！",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "眼看着她就要用脸着陆，并在沙滩上翻滚几圈时。我及时张开双臂接住了她。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "巨大的冲击力将我撞在还算软的沙地上。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 6,
        "Speaker": "瑟瑞斯悠游",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep2_girl013_02",
        "zh_CN": "啊呜……",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "怀里传来一声可爱的轻吟，瑟瑞斯显然还没从这场意外中回过神来。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没事吧？",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她晃了晃脑袋，甩开糊了一脸的沙粒。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在看清眼前的现状后，她慌乱地从我身上爬起来。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 6,
        "Speaker": "瑟瑞斯悠游",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep2_girl013_03",
        "zh_CN": "唔……对不起，分析员！我没想到会冲到这里来，还把你扑倒了。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没关系，偶尔被瑟瑞斯扑倒也是一种享受。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我慢悠悠地站起身，近距离之下，我才注意到瑟瑞斯身上穿的是研发部门刚为她定制的战术套装。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "晴朗的天气下，装甲的表面呈现出微妙的色彩变化，从浅蓝到银白，像流动的海水一般。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员泳装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "瑟瑞斯是在学习冲浪吗？",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 6,
        "Speaker": "瑟瑞斯悠游",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep2_girl013_04",
        "zh_CN": "嘿嘿，算是吧。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "瑟瑞斯嘴角挂着笑意，小手挠了挠微红的脸颊，然后指了指怀中抱着的浪板。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 6,
        "Speaker": "瑟瑞斯悠游",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep2_girl013_05",
        "zh_CN": "分析员还不知道吧~",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 6,
        "Speaker": "瑟瑞斯悠游",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc32ep2_girl013_06",
        "zh_CN": "这个看起来像浪板的东西，其实是研发部门为战术套装配备的动力翼板。",
        "disable": 0
    },
