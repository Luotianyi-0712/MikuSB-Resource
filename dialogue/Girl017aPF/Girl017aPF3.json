[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一天的工作终于处理完毕。正在考虑休息时间如何消遣的时候，一封信从半空中飘了下来。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不用想也知道是苔丝。拆开信，如下写着——",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "亲爱的分析员：",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "请于今晚八点准时来到我的宿舍。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "——魔术师要偷走你的心。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不来也偷！",
        "disable": 0
    },
    {
        "Key": 61.0,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "最后一行画了一个爱心。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "抬头看了看时间，也差不多到了。她应该是算好了时间，确定我一定有空能去找她。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她之前似乎有想说的话，我一直记在心里。看来，就在今晚了。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我打开抽屉，从里面拿出一枚宝石袖扣。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "原本有一对，现在只剩下一枚。今天大概要派上用场了。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "苔丝？是我。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "门自动弹开了，里面漆黑一片。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我进来了？",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没有人回应。我走了进去，门在背后自动关上了。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "脚下软软的，似乎是踩在了厚厚的地毯上。周围传来玫瑰的香气。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 9,
        "Speaker": "苔丝病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "魔术开始！",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "灯光亮起，一个橘红色的身影撞进了我的怀里。我低头看，苔丝正把头埋在我的胸口——",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这算什么魔术？",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 6,
        "Speaker": "苔丝病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嘿嘿……",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她笑着抬起头，打了个响指。一束烟花在窗外升空，嘴唇被苔丝吻住了。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 9,
        "Speaker": "苔丝绮幻",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "心跳加快了！分析员！",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她松了口，手正放在我的胸口，感受着我的心跳。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "令我惊讶的是，手上衣物的触感不对——她身上的衣服不知道什么时候变了。但眼睛却被蒙住了。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……原来是换装魔术。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 9,
        "Speaker": "苔丝绮幻",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "还没完呢！",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她身上那种古灵精怪的舞台气质突然褪去，转而用一种认真、严肃的表情看着我。我眨了眨眼，等她说想说的话。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她打了个响指，房间又暗了下来。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 9,
        "Speaker": "苔丝绮幻",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "呼……",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她没开口，而是又一次抱住了我。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "黑暗中，她的心跳格外清晰。越来越快，呼吸也慢慢急促。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我张了张口，但还是没有说话。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我相信她。相信她能自己做到。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 9,
        "Speaker": "苔丝绮幻",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "分析员。",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我在听。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 9,
        "Speaker": "苔丝绮幻",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你……最喜欢什么样子的我？",
        "disable": 0
    },
