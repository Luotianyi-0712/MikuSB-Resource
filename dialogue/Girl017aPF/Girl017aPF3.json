        "Key": 49,
        "Flag": "",
        "Pos": 9,
        "Speaker": "苔丝绮幻",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "准备好了吗？",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯。",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 9,
        "Speaker": "苔丝绮幻",
        "RealSpeaker": "",
        "WwiseEventID": "",
