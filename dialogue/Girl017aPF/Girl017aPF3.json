        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "眼前还是一片黑暗。下一刻，房间的灯光亮起——",
