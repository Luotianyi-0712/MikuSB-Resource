    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "耶洛沙的寒风中，那个脱下郊狼头盔，冲我傻笑的女孩。",
