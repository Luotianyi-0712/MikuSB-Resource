[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这个好吃。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你尝尝。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她认真地举起勺子，送到我的嘴边。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这家餐厅很难订，每张桌子都坐着客人。我下意识扫了一眼周围，赶快把甜品吃进了嘴里。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "怎么样？",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没来得及尝味道……不过还不错，不太甜。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那再尝一口吧。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她又盛起一勺。我只好探了探身，赶快把甜品接进嘴里。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "感到难为情吗？",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她放下了勺子，歪了歪头。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你这么一说，也是。没什么可难为情的。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我没有谈过恋爱，很多事情不清楚。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "如果有哪里做得不对，你告诉我就好。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "挺好的。跟甜品一样。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哪有那么多对不对的。没必要都按照书上说的来吧？",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "恋爱是那两个人之间的事，干嘛要听别人的。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "想怎么做就怎么做。反正我是这么干的。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那我试试。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "说完，她站起身，弯下腰，一手扶着餐桌，一手捧起我的脸颊。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她闭着眼，我也下意识闭上了眼。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嘴唇轻轻印在嘴角，奶油的香气顺着鼻子钻进身体，和嘴里的甜味一模一样。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "再睁开眼时，她已经坐回了位置上，抿着嘴角，满足得像是实现了什么愿望。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哇哦。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "真甜。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我抬起了双手，又放回了桌子上。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "想要说点什么，但还是只能发出内心的声音。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……哇哦。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你说得对——想怎么做就怎么做。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我现在很开心。很高兴。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "很……",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她努力思索着，想要形容内心的情绪。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我握住她的手。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "手有点麻。这正常吗？",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我掂了掂——没有一点力道，软软地躺在我手心里。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我也不知道。但我现在很想拥抱你。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那就抱我。",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "（我可不见得能克制住……）",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我站起来，轻轻抱了她一下，然后回到了座位。她低着头，没有看我。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "唔……吃好了吗？我们去散散步吧？",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯。",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我牵着她的手往外面走去。她个子够高，手垂下的位置很近，谁也不用迁就谁。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "天气真不错。",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我们在一只长椅上坐下。她抬起头，看向云彩和飞鸟。",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在想什么？",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我在想，我好像都没怎么注意过。",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "下午的风吹过她的头发，道路两旁盛开的花也跟着摆动。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "实在是难得的风景。",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是啊。",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她安静地感受着，丝毫没察觉到我的目光。",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "阳光透过树叶的间隙碎在地上。饭后的慵懒和着手心的安稳，她慢慢合上眼睛。",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我心里的那些悸动和冲动也慢慢沉默，只剩下安宁。",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她的头靠在我的肩膀。在这种被依靠、被信赖的爱中，我也渐渐困了。",
        "disable": 0
    },
    {
        "Key": "b-1",
        "Flag": "b-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "b-1-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "闭上眼睛",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "于是，我也睡着了。",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "…………",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不知道过去了多久。一股香味幽幽地钻进了鼻子。",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "听见了很轻微的脉搏跳动的声音。同时，身上的一些肌肉有些酸痛，大概是因为长时间维持一个姿势。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我睁开眼——大概是睡着的时候，我把头靠在了奈莉德的肩膀上。我连忙坐起身，活动了一下脖子。",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她已经醒了，正看着远处的路灯。察觉到我也醒了，她微微笑了一下。",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "怎么不叫我……几点了？",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Mo_girl021_happy01_052",
        "zh_CN": "我也不知道。凭温度感觉的话，大概九点吧。",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没有叫你是因为，觉得这样很舒服。",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "天完全暗了下来。远处依稀看得见一两盏灯，没有月亮，但星星和蝉鸣一闪一闪的。",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她看着夜空，眨着眼睛。",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你之前的话，我有点明白了。",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "——不用面对阳光，不用被找到，也不用被看见。",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "很轻松，对吧？",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我动了动脖子，顺势抬起头，和她一起看着天上的星星。",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯。",
        "disable": 0
    },
    {
        "Key": 71,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 72,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "playername。",
        "disable": 0
    },
    {
        "Key": 73,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯？",
        "disable": 0
    },
    {
        "Key": 74,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你说过，更喜欢看见我在黑夜里……对吗？",
        "disable": 0
    },
    {
        "Key": 75,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我看向她。灰白色的头发泛着星光，暗红色的眼睛看着我，等待我去理解。",
        "disable": 0
    },
    {
        "Key": 76,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "像世界上最珍贵的宝石那样摄人心魄。片刻后，那些光芒全都消失不见了——",
        "disable": 0
    },
    {
        "Key": 77,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她闭上了眼睛。",
        "disable": 0
    },
    {
        "Key": 78,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "于是我也闭上了眼睛。",
        "disable": 0
    },
    {
        "Key": 79,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "发丝混着鼻息拂过脸庞。沉睡的情欲又被唤醒，她笨拙地探寻着，我温柔地回应着。脖颈交错，一点一点消磨着理智和矜持。",
        "disable": 0
    },
    {
        "Key": 80,
        "Flag": "",
        "Pos": 0,
