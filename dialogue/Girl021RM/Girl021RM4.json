    {
        "Key": 55,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "明明难以启齿，却有一种强烈的冲动，想要把心里话说个痛快。",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她摸了摸自己的嘴唇，回味着亲吻时的心情。",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "（不。）",
        "disable": 0
    },
    {
