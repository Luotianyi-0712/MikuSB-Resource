[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "夜深了。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "奈莉德的房间里黑着灯。水族箱成了唯一的光源，能看见水母泛着浅浅的光。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "奈莉德闭着眼睛，却并没有睡着。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这是她的第一次约会。和他吃了饭，散了步，一同小憩了一会儿，还有一个长吻。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她很好。她觉得哪里都很好。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "水族箱泛起的气泡声很好，电箱低沉轻盈的运转声很好。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "水母漂浮的节奏很好，房间暗得也正好。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "回来时洗澡的水温刚好。擦拭身体时房间的温度也刚好。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "再往前——那更美妙了。她感到前所未有的满足。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "——世界上原来有这么多值得开心的事。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嘴唇触碰嘴唇时，心里会像融化了一样柔软。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "头靠着头互相依偎时，未来和过去都会忘掉，只剩下永远停驻此刻的愿望。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在他眼里，自己一定很大胆、很直接吧？她想起餐桌上的那个吻。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "面对他的时候，也不全是自信与从容。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "——仍然是需要勇气与冲动的，这个吻。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是对在意的迟疑犹豫，毫无来由，毫无理由。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这种被称之为爱与喜欢的情绪，大概就是在一次又一次跨越退意时牢固的。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "退意凭空产生。从由衷的信任和唯一与注定中产生。又被无穷尽的勇气和冲动击溃。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "如此反复。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "想到这里，她翻了个身，抱紧了被子。她嗅到洗衣液的清淡味道。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她对味道很敏感。医疗部是消毒水的味道，基地大厅有咖啡和草木的气息。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "调查区往往有一股锈味，外面的街道则是阳光和花的味道。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而他——playername，则无法形容。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "风吹得头发擦过脸庞，闻见洗发水的味道。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "头靠在他的肩膀。皮肤混着衣服的气味钻进鼻子，让心率慢慢放缓。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而后又被风吹散了。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "就这样睡去，就这样醒来。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "天上闪烁着星星，他靠着她的肩膀。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她轻轻张口。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Mo_girl021_happy01_052",
        "zh_CN": "我爱你。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "声音比树叶摇曳的声音更轻，他当然没有醒过来。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她微微笑，就这么注视着他。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "突然有很多想说的话。",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不知道说哪一句。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "——你真好。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你睡着的样子真可爱，和平时一点儿都不一样。",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我原来也会这么说话啊。",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "来到你身边，我都快不认识我自己啦。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "也没什么不好。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我以前不相信有什么神明。",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "天启者什么的，我一直觉得是集体潜意识之类的东西。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "可大概是有的吧？",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "感谢祂，把你送到我身边来。",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这大概是过去的日子里所有的幸运了。",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她握住他的手，用脸颊摩挲着手掌心。",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "他动了动，好像马上就要醒过来了。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她放下他的手，抬起头，假装什么也没发生过。",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "坐起身，看着窗外的夜星。",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她能听见自己的心跳。",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "回想着晚上发生的事，心跳的频率也慢慢加快了。",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不知缘由，就对着熟睡的他说出了那些话。",
        "disable": 0
    },
