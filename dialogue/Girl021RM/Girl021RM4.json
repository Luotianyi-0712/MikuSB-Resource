        "Key": 53,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "（如果他听见了……那也太难为情了。）",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她感到复杂——",
        "disable": 0
