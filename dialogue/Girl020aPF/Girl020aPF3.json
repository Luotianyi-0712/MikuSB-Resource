[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那之后，就是我们在耶洛沙的故事了。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "米德加尔特，初冬。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我记得抵达耶洛沙没多久，好像是谁坐在车上大喊着什么“我好紧张啊”之类的？",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜灵鉴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哇——那种有损本天师勇敢稳重机敏聪慧形象的事情就不要再提了吧！",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜灵鉴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "求求分析员了哇！让卜卜干什么都可以的——",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嘴上说着让我不要再提，卜卜自己倒是将脸埋进我怀里，作闭目塞听状。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "耶洛沙的经历在脑海中快速掠过，种种千钧一发的瞬间，还有在我背后那些可靠的坚守。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "回忆中的北国寒风已不再刺骨。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "现在吹到脸上的，只有混合着温暖的轻柔凉意。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "“啪！”地一声，一簇活泼的火苗跃起，山洞里最后一丝寒冷也随即消融。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是卜卜刚才支起的火堆。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "先前和卜卜在山林里正走着，不知何时天空竟飘起了小雪。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "雪花只有米粒般大小，还没等落到地上就已融化。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "反正不急着返程，我和卜卜便找了这一处山洞，稍事休息。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "卜卜捡来了不少干净的枯叶铺在一处，又不知从哪儿变出来一匹绒毯垫了上去。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她熟练地生起火堆，山洞中很快暖意融融。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "埋在我怀中的卜卜过了好半天才重新鼓起勇气，抬起头来面对那段回忆。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜灵鉴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "其实，在车里忍不住大喊的时候，我好像就已经没有那么那么紧张了。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "坐在软软的绒毯上，卜卜将身体往我怀里挪了挪，我抬手将她揽住。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "两个人就这样静静地贴在一起说话，旁边是温暖的篝火，洞外是轻飘的雪花。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜灵鉴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "现在回想起来，最慌乱的时候……除了在迷宫一样的疗养中心里寻找你的那一次。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜灵鉴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "其次就是我们飞往耶洛沙的时候了。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "原来是这样吗？",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜灵鉴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯。因为那个时候完全不知道接下来会发生什么，不知不觉就将未知幻想得无比可怕。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜灵鉴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不过，好在playername当时来到我身边，对我说了那些话。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜灵鉴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "等真的踏上耶洛沙，反而发现其实一切并没有自己想象得那么恐怖。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哎呀呀，后来又是谁趴在我背上哭鼻子来着？",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜灵鉴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那可不一样。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜灵鉴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "害怕的情绪当然还是会有咯，就像分析员说过的嘛，它愿意留在这就在好了。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜灵鉴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但是只要在分析员身边，卜卜就会有勇气去做自己认为应该做的事情。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜灵鉴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "只要去做，一切难题也就有了解法。",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "按照卜卜的说法，初雪下得早，今年冬天便不会太冷。",
