        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "对。不想做和不去做是两回事。",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 6,
        "Speaker": "里芙",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "只要有你在，就没有什么身不由己的。",
        "disable": 0
    },
    {
