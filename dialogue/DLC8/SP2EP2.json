    {
        "Key": "88-2",
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "掌心中恰如其实地传来的紧握感让我忍不住歪过头，但此刻瑟瑞斯的脸上却没有什么异样……",
        "disable": 0
    },
    {
        "Key": 89,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
