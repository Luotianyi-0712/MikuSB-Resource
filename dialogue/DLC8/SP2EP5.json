    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "艾尔莎",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你擅自中止我的研究，解散我的团队，现在说是为了我？！",
        "disable": 0
    },
