    {
        "Key": 2,
        "Flag": "",
        "Pos": 5,
        "Speaker": "瑟瑞斯瞬刻",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "看起来，这些由程序控制的敌人并没有主动攻击的欲望，只是守在固定的地方。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 5,
        "Speaker": "瑟瑞斯瞬刻",
        "RealSpeaker": "",
        "WwiseEventID": "",
