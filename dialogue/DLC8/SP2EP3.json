        "Key": 26,
        "Flag": "",
        "Pos": 4,
        "Speaker": "望",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哼哼，说到这个，这就是小世界神奇之处了，分析员阁下应该也很想知道吧？",
        "disable": 0
    },
