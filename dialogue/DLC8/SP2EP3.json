    {
        "Key": 25,
        "Flag": "",
        "Pos": 5,
        "Speaker": "瑟瑞斯瞬刻",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "从进入这里以后，我们似乎就只是沿着道路一直走而已。",
