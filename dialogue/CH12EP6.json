    },
    {
        "Key": 88,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "士兵们在巡查官的命令下鱼贯而入，直至最后一人也走进车厢里。他们端着武器，将那团小小的身影围在正中间。",
        "disable": 0
    },
    {
        "Key": 89,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
