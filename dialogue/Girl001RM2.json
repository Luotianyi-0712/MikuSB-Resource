[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "社团？",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一个令我有些意外的答案。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在我的设想中，当一个许愿的机会摆在面前，多数人往往会希望得到更实际的东西。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "比如金钱、物品，或者某种切实受益的地位。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "三十年的沉睡让安卡希雅的生命得以延续，但代价是她被丢进一个全然陌生的时代。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "匮乏的时代归属感之下，看得见摸得着的东西才最叫人安心。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "——通常的思路应当是这样的。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "安卡希雅伸手想拿自己的杯子，却发现里面的可乐已喝完。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她朝着我晃了晃她的空杯子，接着拿起我的杯子一饮而尽。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好吧，不同于寻常，也许才是安卡希雅。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "怎么不说话了，该不会这个时代已经进化到没有“社团”这种概念了吧？",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那倒不是。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "如果这是你想做的事的话……",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "明天吧，我叫个人来，这方面她肯定比我清楚。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "加入社团？这倒没什么难的，世界树公司内部就有不少兴趣社团。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你们也知道，现在的公司都会被要求必须有这种东西，为了保证员工心理健康嘛。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "卡罗琳摊了摊手。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "扯远了，总之，只要是获得公司承认的内部社团，公司会定期提供活动场地和经费。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "所以换个角度来说，加入社团也可以享受到公司更多资源哦。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 5,
        "Speaker": "安卡希雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这个“社团”是我想象中的那个社团吧？",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 4,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "如果你想象的是具有某些共同爱好的人相聚而成的互益组织，那么是的。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 4,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我发一份社团名单给你吧，种类应有尽有，不妨仔细看看有没有你感兴趣的。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 5,
        "Speaker": "安卡希雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "直接发给playername好了，反正我们也是要一起加入的。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "安卡希雅对着卡罗琳指指我。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 4,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哦？哦~",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "卡罗琳飞快收起惊讶神色，向我抛出了个“不愧是你”的眼神。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……她到底恍然大悟了什么啊。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "打开卡罗琳发来的社团名单，上面的名称五花八门。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "械兽驭行社、神经潜泳俱乐部、人工智能研究小组、重力舞蹈社……",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "安卡希雅凑到我身边，和我一起浏览那份清单。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "挺丰富的嘛，看来这里的员工都不怎么加班？企业文化不错。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "未必全都不加班……",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "咳，你们继续看，继续看，有疑惑的地方可以随时问我。",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "忽略在一旁负重前行的卡罗琳，我和安卡希雅认真分析起了现有的社团。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我猜舞蹈烹饪类的不太适合你，机械研究和人工智能方面倒是可以试一试。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "怎么样，这里面有你中意的吗？",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "械兽驭行需要具备A类驾驶资格证，人工智能研究需要具有参赛经历。",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这么高的准入要求，想进个社团还真不容易。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不用太担心，有些社团的要求也不高，我们可以现在学。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我像是会专门学那些东西的人吗？",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "看来，她对于不感兴趣的事情是一点都不会做的。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "安卡希雅继续浏览名单，手指快速滑动，名单却已经到了最后一页。",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这里就是全部的了？",
