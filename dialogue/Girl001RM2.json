        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "人们在游戏内就可以缔结联系，所以现实世界中的“社团”反而就显得没那么必要了。",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……怎么这样。",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "安卡希雅喃喃自语道。",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这样一来，那些经典的游戏和漫画作品不就越来越无人问津了吗？",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我没回答她的话，因为确实如此。",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "永远有更抓人眼球的新作品诞生，更酷炫的技术，更宏大的制作，更精彩的呈现。",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这个时代的游戏玩家大概永远不会觉得孤单。",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "除了安卡希雅。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好吧，我决定了。",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "安卡希雅抬头冲我一笑，眼神中闪过一丝狡黠。",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "凭我对她快速积累起来的了解，她绝对是想到了新点子。",
