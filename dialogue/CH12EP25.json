    {
        "Key": 7,
        "Flag": "",
        "Pos": 6,
        "Speaker": "抵抗军士兵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "呃，这个……",
        "disable": 0
