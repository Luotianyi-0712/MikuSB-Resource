    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我收回目光时，转头看到辰星眸光亮晶晶地望着她们。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我们也过去玩玩吧。",
        "disable": 0
    },
