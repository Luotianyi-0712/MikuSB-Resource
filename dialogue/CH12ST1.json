        "Key": 22,
        "Flag": "",
        "Pos": 2,
        "Speaker": "勤务军官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "可以不相信。我们也可以现在就把武器还给你们。",
        "disable": 0
