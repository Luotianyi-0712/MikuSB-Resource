    {
        "Key": 19,
        "Flag": "",
        "Pos": 2,
        "Speaker": "勤务军官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这里是耶洛沙军占区的后方城市。我是李秋雪少校的勤务官。",
        "disable": 0
