    {
        "Key": 11,
        "Flag": "",
        "Pos": 3,
        "Speaker": "郊狼士兵2",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你以为光凭你一句话，你们就能跟那个畜生撇清干系吗？！",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 2,
        "Speaker": "勤务军官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嘿！把枪放下。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 2,
        "Speaker": "勤务军官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……我重复一遍。米尔伍德对你们做出的暴行并非出自军方的意愿。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 2,
        "Speaker": "勤务军官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "纪律部队正在搜索米尔伍德的下落，一旦找到他，我们会送他上军事法庭。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 2,
        "Speaker": "勤务军官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "他对你们犯下的是战争罪，反人类罪，还有其他各项严重违反军纪和道德的恐怖罪行。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 2,
        "Speaker": "勤务军官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没有人会包庇他，你们可以放心。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 2,
        "Speaker": "勤务军官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "他死定了。所以，不要再这么害怕，放下紧张和戒备，配合我们的工作，好吗？",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 1,
        "Speaker": "拾荒者",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我们……我们会怎么样？这，这是哪儿啊？！",
        "disable": 0
