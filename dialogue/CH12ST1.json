    {
        "Key": 7,
        "Flag": "",
        "Pos": 2,
        "Speaker": "勤务军官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "请你们不要紧张，这里没有人会受到伤害。",
