        "Key": 68,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我在走廊上与芙提雅四目相对，相顾无言。",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芙提雅",
