        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没有，也不需要。我会等芙提雅主动告诉我的，在你准备好之后。",
        "disable": 0
    },
