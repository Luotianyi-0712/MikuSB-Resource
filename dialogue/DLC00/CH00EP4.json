[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "雪停了。一切都结束了。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "泰坦的身形崩解，随着渐渐弱下的风消失不见。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "少女们欢呼着扑了上来。往上看，“树”消失的地方没有云彩。即使是白天，也能看见零落的星光。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "通讯开始恢复。边境的飞行载具正往这边飞来，通讯终端里也全是队员们的关心和问候。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "紧绷着的心终于松了下来。往后躺下，被里芙接住了。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮辉耀",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_girl008_01",
        "zh_CN": "达令！达令？！",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我没事。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "就是有点累。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一起躺会儿吧？飞机过来还要一会儿呢。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮辉耀",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_girl008_02",
        "zh_CN": "啊，你吓死我啦！没事就好……",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她松了一口气，在我旁边躺下。里芙侧坐着，让我的头可以枕在她的大腿上。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "安卡希雅则枕着我的肚子，闭上了眼睛。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "云层开始闭拢，就像伤口在愈合。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "什么心思都没有，却感觉到很充实。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "坐上飞机。透过舷窗，看着下面的大地。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "有些积雪已经化掉了，露出黄绿的底色。有些山上还覆着雪，偶尔能看见一堆一堆的雪往下滑落。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 9,
        "Speaker": "芬妮辉耀",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_girl008_03",
        "zh_CN": "哎，看——",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "顺着芬妮指着的方向，我看见第一天晚上建筑的临时营地。哨塔似乎是被雪压塌了。这会儿雪化了不少，帐篷却不知道被吹到哪去了。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "远远地，看见灰突突的隔离带。飞机却没有停下，继续往霍尔姆飞去。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "回到基地。换了身衣服，冲了个澡。宿舍的温控系统送来宜人的风，床也松软。紧绷了许久的神经终于能放松下来。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "止不住地感到乏力。窗台上摆着花儿，向着阳光。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "连拉上窗帘都懒得伸手，用手臂盖着眼睛，睡着了。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "朦胧之中，呼吸变得有点紧迫。先是怀里似乎钻进来一个软乎乎的家伙，然后是背后似乎也有了一道均匀的呼吸。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "再醒来时，房间已经黑漆漆的了，只有一道黯淡的光线从窗帘缝里洒出来。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "怀里是芬妮。她枕着我的手臂睡得正香。半边身子都压在我的身上，怪不得有点上不来气。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "看了看表，睡得有些久了。我低下头，抵着她的额头。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 9,
        "Speaker": "芬妮病号服",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_girl008_04",
        "zh_CN": "唔……",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "呼吸交错，她也慢慢醒了过来。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "怎么上我这儿来了？",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮病号服",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_girl008_05",
        "zh_CN": "想找你，看你睡着了还没拉窗帘。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮病号服",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_girl008_06",
        "zh_CN": "帮你拉上之后……也困了。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她哼哼着，扬起腿，压在我的身上。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "总这么睡觉，把我当抱枕一样抱着。",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮病号服",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_girl008_07",
        "zh_CN": "不喜欢吗？",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "喜欢。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮病号服",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_girl008_08",
        "zh_CN": "哼~",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是不是该去吃饭了——",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我翻了个身——",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅病号服",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_girl001_01",
        "zh_CN": "呃啊——",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "背后还躺着个人，刚好压到了。我和芬妮都吓了一跳。",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 4,
        "Speaker": "芬妮病号服",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_girl008_09",
        "zh_CN": "安卡希雅？又是你！什么时候来的！",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "压坏了没？",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 5,
        "Speaker": "安卡希雅病号服",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_girl001_02",
        "zh_CN": "哎，还好……",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮从我胸口抬起头，虎视眈眈地看着安卡希雅。后者则缩起头来装听不见。",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "敲门声忽然响了起来。门开了一条缝，里芙的声音传了进来——",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 9,
        "Speaker": "里芙病号服",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_girl002_01",
        "zh_CN": "晚饭准备好了。你们三个，醒了就来吃。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "三个人你看看我，我看看你。气氛有种恰到好处的尴尬。于是穿上衣服，一同往餐厅去了。",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不知是有意还是无意，今晚恰好所有队员都回到了基地。",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "算是庆祝，也算是团聚。没有蛋糕和葡萄汁，但却有一句句关心和思念。",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "饭吃得差不多的时候，余光看见情报官卡罗琳走了过来。",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "怎么了？",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_npc002_01",
        "zh_CN": "老板找你。",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "知道了，我现在就过去。",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "站起身，却突然被她拉住了手。",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_npc002_02",
        "zh_CN": "哎——",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "还有事吗？",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_npc002_03",
        "zh_CN": "唔……",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_npc002_04",
        "zh_CN": "欢迎回家。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我笑了笑。她张开手，红着脸，给了我一个拥抱。",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "办公室里，我坐在陶的对面，她正皱着眉头，看着这次的任务报告。",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_npc003_01",
        "zh_CN": "是我的疏忽。朔州的“树”比想象中要更强大、更特殊。",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_npc003_02",
        "zh_CN": "现在看来，这次行动还是过于冒险了。",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "谁也没办法未卜先知。我们已经做了足够多的前期铺垫，发生这种意外也是没办法的事。",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_npc003_03",
        "zh_CN": "总之——辛苦了。",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_npc003_04",
        "zh_CN": "那边都在等你呢，去好好休息一晚上。别让她们等太久。",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我还有件事。",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_npc003_05",
        "zh_CN": "你说。",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "触摸“树”的时候……我看见了过去的事情。",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "舍塔。派。第五研究所。",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "埃达。海拉。尤弥尔。",
        "disable": 0
    },
    {
        "Key": 71,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "甚至有一些……好像缺失、遗忘过的记忆。",
        "disable": 0
    },
    {
        "Key": 72,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep4_npc003_06",
        "zh_CN": "……比如呢？",
        "disable": 0
    },
    {
        "Key": 73,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "陶的眼睛好像眯了一下，坐姿也正了起来。语调却好像很轻松平常。",
        "disable": 0
    },
    {
        "Key": 74,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "槲寄生空间站。",
        "disable": 0
    },
    {
        "Key": 75,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
