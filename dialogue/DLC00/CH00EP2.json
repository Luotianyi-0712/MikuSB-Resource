    {
        "Key": 45,
        "Flag": "",
        "Pos": 3,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep2_girl001_06",
        "zh_CN": "芬妮……芬妮对战局的洞察能力更强，能够补足队伍的短板。",
        "disable": 0
