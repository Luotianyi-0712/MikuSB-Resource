        "Key": 44,
        "Flag": "",
        "Pos": 3,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep2_girl001_05",
        "zh_CN": "留在你身边的话，你就不用担心下达的指令完成不了。",
