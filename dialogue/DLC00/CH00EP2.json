        "Key": 40,
        "Flag": "",
        "Pos": 3,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep2_girl001_03",
        "zh_CN": "我！",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "安卡希雅也应了一声。三个人都期盼地看着我。",
