        "Flag": "",
        "Pos": 3,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep2_girl001_08",
        "zh_CN": "机械操作这一块儿，我也略懂……",
        "disable": 0
    },
