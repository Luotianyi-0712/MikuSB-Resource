        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep2_girl001_07",
        "zh_CN": "而我，我以前是特种兵！",
        "disable": 0
    },
    {
