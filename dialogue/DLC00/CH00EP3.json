[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep3_girl001_01",
        "zh_CN": "听得到吗？喂？能听见吗？",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "现在好多了。泰坦物质的浓度已经到临界点了，这应该是最后一次通讯。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep3_girl001_02",
        "zh_CN": "噢……知道了。你们打得怎么样？",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "还算顺利。清除了泰坦之后，直到现在都没再遇见过敌人。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好了，坐标已经传给你了。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep3_girl001_03",
        "zh_CN": "好。我这边的雪也很大了，发射之后我就出发。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep3_girl001_04",
        "zh_CN": "收到了。正在校准位置。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep3_girl001_05",
        "zh_CN": "空投物资已发射，预计五分钟后到达。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯。我们会就地补给，你到达目标位置之后发射信号弹，我们会就地扎营，然后回应信号弹。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep3_girl001_06",
        "zh_CN": "收到。预计……当地时间晚上六点到达坐标位置。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "略微迟疑，但还是挂掉了通讯。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "上一场遭遇战之后，就几乎没再看见过异化人和泰坦了。雪时深时浅，乌云却始终横在前头，怎么绕也绕不过去。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "“树”好像收缩起了所有力量。大风渐起，远远看去，“树”的外围正凝聚着一道风暴。如果前进，走哪条路也都一样了。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "降落伞挂着空投箱慢慢落下。原地补给好物资，我们继续前进。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "雪没过了小腿。走在最前面的人用身体分开一条道路，后面的人搭着肩膀，沿着走出的路前进。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "每过一个小时，最前面的人就要退下来休息。等雪没过膝盖，这个时间就又缩短了。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "深一脚浅一脚。雪埋住了地形，每一脚都要坚定无比地踏下去，踩实、踩死，然后才能迈出下一步。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "风更大了。时而迎面而来，要伏着身子才不会被掀翻过去。时而背后袭来，要躺在风里，用上百斤的装备来压住身形。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "想交谈都成了困难。一张嘴，风便混着雪灌进嘴里。喊出声，也会在半米内便淹没在怒号的风声中。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "“树”凛然站在终点，奋力挥舞着它的雪连枷，一圈又一圈加快，不知疲倦。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "站在最前面的我停了下来，回过头。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "满眼都是白，连脚下的雪的轮廓都几乎看不清了。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "解下包，丢在地上。一瞬间几乎要被狂风吹走。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "里芙和芬妮立刻凑了过来，把耳朵凑在我嘴边——如果不这样，根本没办法听清我要说的话。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "停——下——！不——走——了——！",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 9,
        "Speaker": "芬妮辉耀",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep3_girl008_01",
        "zh_CN": "还——没——到——！",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "安——卡——希——雅——！",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮马上理解了我的意思。她和里芙一起解下背上的包裹。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "取出包里的放热棒，拧动后丢进雪地里。被放热棒融化的雪，在放热结束后又被严寒冻成了冰。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "顶着要把人刮走的风，我们把地上的冰切成一块一块的，再一圈一圈地垒起来。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "每垒一圈，就要再取些雪水来加固，不然马上就会被吹倒。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "天要黑了。临时营地也终于建好了。我们又取出防潮垫铺在地面，再把墙上都钉上防潮布。这个临时住所终于建成了。",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "可，已经七点半了，我们还是没有看到安卡希雅的信号弹。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "风雪太大了。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 4,
        "Speaker": "芬妮辉耀",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep3_girl008_02",
        "zh_CN": "要不要往回去接她？",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一个人留下，两个人回去。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "里芙，你留下准备晚饭。如果直到明天我们都没有回来，你就原路返回。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮，你跟我回去找安卡希雅。",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "里芙点了点头。我和芬妮对视了一眼，又一头扎进了风雪中。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "万幸的是，风雪没有白天那么站不住人了。天完全黑了下来。芬妮打开了身上的探照灯，我则走在几米之外，时时观察着周围的信息。",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "每过十分钟，我就会发射一颗信号弹。走到现在，只剩下最后一颗了。",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不管往前走多久，都是一样的景色。无尽的黑，无尽的雪，无尽的风。",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "永远也走不完。永远也找不到。看不到一点希望。",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮的头垂了下来。她关了灯，走到我身边，胸口起伏着，一句话也不说。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我知道她在想什么。拉起她的手，隔着厚厚的手套，用力攥紧。",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她深吸了一口气，重新打开了探照灯。我们手挽着手，继续往前走去。",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "比来时的路更难走些。又走了很久很久，我停下脚步，把最后一颗信号弹填进枪膛。",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "举枪，发射。曳着红色的焰尾，斜飞出去，隐没在远处的覆着雪的山丘之后。",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没有回应。",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮辉耀",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep3_girl008_03",
        "zh_CN": "……怎么办。",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮的语气很平静。但她很少有这样平静的表情。平静之下压抑着愤怒和焦躁，似乎想要把眼前的暴风雪完全轰散——那样，安卡希雅就能看见我们的位置了。",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "再等等。",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "风还是扯着耳朵。雪还是像流沙一样倾盆而下。黑夜还是让人分不清四面八方。",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但一缕红光仍是挤破夜幕，从山丘对面跃起，逶迤着落了下来。",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 9,
        "Speaker": "芬妮辉耀",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep3_girl008_04",
        "zh_CN": "是信号弹——信号弹！！",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一颗星星爬上了山丘。那是探照灯的光，被雪压得像星星一样闪烁。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "它走得很慢，但很均匀、很坚定地往这边走着。星星越来越亮，延伸成一道光。",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在光的下面，是安卡希雅覆着雪的眉毛和睫毛。",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我抱住她，她晃了晃，拍了拍我的后背，咧了咧嘴。",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep3_girl001_07",
        "zh_CN": "嘿嘿。",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "脚步轻快。顺利——情不自禁想用这个词。同样的黑夜和风雪，心情却完全不同了。",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在伸手不见五指的黑白世界里，我们终于回到了临时营地里。",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "掀开遮风的布，热腾腾的香气顿时裹住了人。头上湿漉漉的，里芙接过我解下的衣服，搭在旁边的暖炉上。",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "又禁不住抱住了安卡希雅。",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "怎么这么迟？",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep3_girl001_08",
        "zh_CN": "我发了信号弹，但是那会儿雪太大了。",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_chp0ep3_girl001_09",
        "zh_CN": "信号弹飞上天，连我自己都看不见，更别提你们了。",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
