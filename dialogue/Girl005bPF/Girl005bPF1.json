        "Key": 41,
        "Flag": "",
        "Pos": 4,
        "Speaker": "研究员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不……不好意思，情报官小姐。",
        "disable": 0
    },
