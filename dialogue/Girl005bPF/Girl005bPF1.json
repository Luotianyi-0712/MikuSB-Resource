        "Key": 42,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没什么。不过，你这是在干嘛？",
        "disable": 0
    },
