    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "然后，她就在走廊尽头的拐角跟人撞了个满怀。",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 6,
        "Speaker": "研究员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "呜啊——",
