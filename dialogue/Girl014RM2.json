    },
    {
        "Key": 89,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我递去一张纸巾，不过辰星看起来没什么反应，于是我干脆用纸巾替她擦掉了嘴角沾着的冰淇淋。",
        "disable": 0
    },
