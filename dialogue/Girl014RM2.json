[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我和辰星赶在阳光还很惬意的时候出了门。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我推着辰星，漫步在宽阔的街道。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这是临时起意的出行，虽然是准备带辰星体验生活，但我并没有明确的目的地。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "可生活的意义正在于此。如果什么事都需要有意义、需要安排完才要去做，未免也过得太累了一些。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "辰星有在这座城市好好散过步吗？",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星云篆",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "…没有。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "辰星回答的语气有些呆呆的。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她加入世界树已经有一段时间，在这座城市里……也生活了许久。可明明是熟悉的城市光景，她居然觉得有种陌生感。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "真的……好奇怪啊。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "和记忆里一般无二的城市，为什么会带来如此不同的体验呢。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "过去你都是路过这些风景，今天你才身在其中。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星云篆",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "身在其中……",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "少女轻轻呢喃，脸上带着似懂非懂的表情。她睁大眼睛，看着路边的风景。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "湛蓝的天空，",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "悠闲的鸟群，",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "广场里飞跃的喷泉，",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "孩童们嬉笑打闹，老人在悠闲地喝茶打牌。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "小猫懒洋洋地趴在阳光晒暖的高台上，睥睨着底下被吆喝着追着飞盘跑来跑去的大狗。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "听不清楚的音乐，鼎沸的人声，那些欢闹的，或者悲苦的，那些美好的，或者嘈杂的，共同交织成这座都市生命的旋律。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星云篆",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "原来如此……",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "大量的信息第一次如此清晰的进入脑中。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在记忆里苍白的影像，好像重新有了光影与声音。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "微风吹过，树叶连同新开的花一起摇曳着，然后她闻到了空气中弥漫着淡淡的幽香。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "恰好她就被推到一片开满淡黄色花朵的篱笆边，她下意识伸手去触碰小小的一朵。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "只是在即将触碰那朵小花的时候，辰星像是忽然记起什么，转头小心翼翼看向我。我瞬间猜出了她的心思。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "放心，我不会让你去摘花的。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星云篆",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "辰星点了点头，我看到她低下头的时候悄悄吐了吐舌头。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这时，一对母女从我和辰星的身边路过，小女孩的手上正拿着一支吃了大半的冰淇淋。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 6,
        "Speaker": "小女孩",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "妈妈，我还想再吃一支。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "小女孩妈妈",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "只能吃一支，小孩子吃两支冰淇淋可是会被妖怪抓走的。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 6,
        "Speaker": "小女孩",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那我第二支不吃完，就不算吃了两支了，或者我可以在妖怪来之前吃掉三支或者更多！",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "女孩蹦蹦跳跳跟着母亲离开，我看向不远处的冰淇淋车，又看了一眼辰星有些意动的模样。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "要试试吗？",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "辰星努力掩藏着脸上的红晕，认真点头。",
        "disable": 0
    },
