        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "刚刚发烫的心脏才平复了一些，忽然旁边有声音响起。",
        "disable": 0
