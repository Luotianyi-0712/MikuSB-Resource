    {
        "Key": 14,
        "Flag": "",
        "Pos": 5,
        "Speaker": "妮塔",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没啥不能给的，你等着，我拆了给你！",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "妮塔……没有包装的话……",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我本想提醒几句，但见妮塔干脆利落地将香水从包装中取出，眼里没有丝毫不舍，到嘴边的话便只能咽了回去。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
