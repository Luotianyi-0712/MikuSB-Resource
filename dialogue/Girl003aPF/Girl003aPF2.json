        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她轻声呢喃着，手指不自觉地探向口袋里的好运水晶，感受着那冰凉的触感。",
        "disable": 0
