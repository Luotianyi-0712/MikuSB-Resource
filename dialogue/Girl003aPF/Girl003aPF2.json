    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "恍惚间，妮塔仿佛看到了记忆中的自己与眼前的小女孩重叠在了一起。",
        "disable": 0
