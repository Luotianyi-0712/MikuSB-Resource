        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "火焰、浓烟在此刻仿佛被一只无形的手拨开，少女迷迷糊糊地坐在了一张柔软的红丝绒椅子上。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哗啦——！",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
