        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我拿出终端在她眼前晃了晃，熟悉的店名和诱人的菜色让她立刻来了精神，迫不及待地爬了起来。",
        "disable": 0
    },
