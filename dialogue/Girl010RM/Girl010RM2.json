        "Key": 7,
        "Flag": "",
        "Pos": 6,
        "Speaker": "肴病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "真的假的？",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 6,
        "Speaker": "肴病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那我要香菇肉酱汤面、卤凤爪……",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "还有咸烧白、酸菜鱼、少糖的冰粉对吧？",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 6,
        "Speaker": "肴病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "记性挺好啊你？",
        "disable": 0
    },
