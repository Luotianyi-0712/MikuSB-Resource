        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 6,
        "Speaker": "肴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "眼睛里怎么全是血丝……",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她又伸手探了探我因为疲惫而微微发烫的额头。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 6,
        "Speaker": "肴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "别对自己这么狠啊，分析员……",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 6,
        "Speaker": "肴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "越是累，就越应该吃点好的，泡面这种东西，连安慰都算不上。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "还没等我回过神，我的泡面已经被她移到一旁，下一秒，她就拉着我的手臂往外走。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "肴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我知道一家特好吃的地方，跟我来。",
        "disable": 0
    },
