        "Flag": "",
        "Pos": 9,
        "Speaker": "肴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "明白。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
