        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "干净利落，一如既往的精准。但这不是计划好的节奏。",
