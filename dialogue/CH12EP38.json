[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "苔丝",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "分析员大懒虫，起！床！啦！",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "睁开眼睛的时候，苔丝正骑坐在我身上，俯身压着我。她看见我醒过来，才把原本捏着我鼻子的手缩了回去。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 6,
        "Speaker": "苔丝",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "真是的……难得借着公务的机会出来度假，怎么一到地方就躲起来睡觉呀。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "公务？度假？",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "头脑混沌，我搞不懂她在说什么。或许我真的是躺了太久，浑身上下的每一个关节都酸痒难耐。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我本能地一翻身，几张魔术卡牌就簌簌地从我的脸上身上掉落下去，落在躺椅旁边奢华而厚重的地毯上。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 6,
        "Speaker": "苔丝",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哎嘿嘿，我刚刚跟她们打赌，说到底要在分析员身上贴多少张牌你才会醒过来。结果我都贴满了你也不醒！",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她们？",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 4,
        "Speaker": "芬妮咎冠",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "他想睡就让他睡个够吧。本小姐可是准备要下楼去参加舞会了。得让耶洛沙的本地人好好见识一下……",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "耶洛沙……耶洛沙？！",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 5,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你们要去就赶快去，吵吵嚷嚷的我都没法专心打速通啦。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 4,
        "Speaker": "芬妮咎冠",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "都到这儿了你还要躲在房间里打游戏？",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 5,
        "Speaker": "安卡希雅辉夜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我是老人家嘛，腰腿不好……哪像你们那么爱动弹。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不，不对。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 6,
        "Speaker": "苔丝",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯？怎么了吗分析员？什么不对？",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "什么都不对。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我忍着周身关节的痛楚，努力站起身来——环顾四周，我记得这里，这是奥尔洛夫公馆二楼的会客室。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我……不应该在这里。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 6,
        "Speaker": "赫瓦雷纳士官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "对，你不应该在这里。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 6,
        "Speaker": "赫瓦雷纳士官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你们世界树的人，从一开始就不应该插足耶洛沙的事情。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 6,
        "Speaker": "赫瓦雷纳士官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我们花了那么久的时间，做好了所有准备，只差一步就能把奥尔洛娃公爵和受她鼓动的叛党们一网打尽。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 6,
        "Speaker": "赫瓦雷纳士官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "都是因为你！你很喜欢杀人吗？海姆达尔的分析员？！",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米尔伍德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "他当然喜欢。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米尔伍德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这是他的本性……一旦开始，就只会愈演愈烈。杀了第一个，就会有后面的无数个。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米尔伍德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "他会踩着这些尸骨，一步一步向上攀爬，直到顶点，然后坠落。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米尔伍德",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "就像我一样。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "呵，原来是这么回事吗。",
        "disable": 0
    },
    {
        "Key": "b-1",
        "Flag": "b-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "b-1-2",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "拔枪射击",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "尽管我的身体现在像是一堆老旧生锈的零件，尽管只是动一动手指都会觉得难耐，但我还是用最快的速度拔出配枪，对准了面前那张脸。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "然后毫无犹豫地扣动了扳机。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "谁**的……跟你一样，啊？",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一枪，又一枪，再一枪……似乎是要发泄某种无名怒火，又似乎是在已经明了现状却无计可施之下的挣扎……",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "面前的米尔伍德已经倒在地上，脸上却依旧挂着令人生厌的狞笑——我的子弹一颗颗穿过他的身体，没进了我脚下那一团浓得化不开的黑影里。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 6,
        "Speaker": "真埃达",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嘻嘻嘻，看来这些小伎俩只能吓着你，气着你，却不能真的让你忘了自己是谁呢。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "无聊的恶作剧。",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 6,
        "Speaker": "真埃达",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯。无聊的恶作剧。",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "果然，我仍然置身于瓦尔哈拉的世界里。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 6,
        "Speaker": "真埃达",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但是因为是你在陪我玩儿，只有你有资格陪我玩儿，所以我很开心。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你到底想干什么？！",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 6,
        "Speaker": "真埃达",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我想干什么？嘻嘻，别问这么傻的问题。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 6,
        "Speaker": "真埃达",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我是造物，我想干什么可由不得我自己说了算。你真想知道答案的话，为什么不去问问那边那个始作俑者？",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她顶着一张乖巧至极的脸，但语气腔调却是说不出的冰冷怨毒。我顺着她的视线看过去，看向她所谓的那个“始作俑者”。",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 0,
        "Speaker": "？？？",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不要听她说的任何话，分析员。",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 0,
        "Speaker": "？？？",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你已经战胜她了。你……已经成功地解决掉耶洛沙这里的树了。",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "？？？",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你迈出了人类战胜泰坦的第一步，也找到了对抗她的方法。只要有你在，她就会永远地停留在造物的阶段，不可能再进一步了。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 4,
        "Speaker": "真埃达",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "真是恶毒的“母亲”啊……有了新欢，就连自己的“女儿”都肯出卖，连自己的理想都肯背弃。",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 4,
        "Speaker": "真埃达",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "啊……我明白，你还是过去的那副样子，满脑子想的都是造神。现在，你是想把他也打造成神吗。",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 4,
        "Speaker": "真埃达",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但你不要忘了，是我先选中他的。他能从死亡的际遇里生还，能驾驭这股新的力量……这一切都只会证明我比你更有眼光！",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 4,
        "Speaker": "真埃达",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我不会眼睁睁看着你把他夺走，让他堕落……",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "够了。",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我喝止了她们的对话，挺身拦在了她们中间。",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你不是陶。至少你不是我所认识的那个陶。",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 0,
        "Speaker": "？？？",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而你……也不是真正的“埃达”。",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 4,
        "Speaker": "真埃达",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嘻嘻……",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你们只是残存在这即将崩解的瓦尔哈拉世界一角里，最后的两个独立意志而已。",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是的，她们是虚妄的……这个所谓的精神世界，也是虚妄的。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我会来到这里是因为我有必须要完成的事情。我不属于这里，人类……不属于这里。",
        "disable": 0
    },
    {
        "Key": "b-2",
        "Flag": "b-2",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "b-2-2",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "扼住她们的咽喉",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 0,
        "Speaker": "？？？",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "呃嗯……",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 4,
        "Speaker": "真埃达",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "呜……嘻嘻嘻，挺聪明的嘛你！",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "要做的事情很简单，也很明确——就像对付那棵树一样，把我自己的身体当做“媒介”，让面前的这两个披着伪装的家伙彻底消失，一切就都会结束了。",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我要回到我自己的世界里。我是playername，我是世界树海姆达尔部队的分析员。",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在那一边，有很多人都在等着我回去。",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 0,
        "Speaker": "？？？",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 0,
        "Speaker": "？？？",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "呜嗯！！",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在我的掌心里，最后的这两道意志残像在不断地扭动挣扎着，我甚至能感受到它们像鲜活的生命一样，有着强烈的心跳脉动。",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不肯就此屈服的它们在我的眼前不停地变化，直至化作了我所关切的人的模样——电光石火的一瞬，我差一点就忍不住要松开我的双手……",
        "disable": 0
    },
    {
        "Key": 71,
        "Flag": "",
        "Pos": 5,
        "Speaker": "狂猎",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "分析员，不要停手。",
        "disable": 0
    },
    {
        "Key": 72,
        "Flag": "",
        "Pos": 4,
        "Speaker": "伊切尔泰坦",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "它们是假的，是坏东西！伊切尔不在那里！",
        "disable": 0
    },
    {
        "Key": 73,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "亲切熟悉的声线在耳畔响起，就像之前一样——我感觉到真正的里芙和伊切尔此刻就在我的身后，环抱着我，保护着我……",
        "disable": 0
    },
    {
        "Key": 74,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "让我更加确信我应该结束这一切，回到她们身边，回到那个有我的队员们所存在的世界里！",
        "disable": 0
    },
    {
        "Key": 75,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "给我……涌进来！然后消失吧！",
        "disable": 0
    },
    {
        "Key": 76,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "睁开眼睛的时候，我立刻认出了自己正身处何地。而映入眼帘的高挑身影更是让我倍感荒诞……",
        "disable": 0
    },
    {
        "Key": 77,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你醒了。",
        "disable": 0
    },
    {
        "Key": 78,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没完没了了是吧？",
        "disable": 0
    },
    {
        "Key": 79,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "半点迟疑都欠奉，我立刻伸出手去摸向枪套，想要拔出武器对着面前的幻象开火。但着手之处空空荡荡，我不禁错愕地低头——",
        "disable": 0
    },
    {
        "Key": 80,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "别说枪套了，我浑身上下的衣服都彻底换了一身。再抬眼看向周遭的时候，却发现除了陶之外，我的队员们此刻也全都站在房间里，满面狐疑地看着我。",
        "disable": 0
    },
    {
        "Key": "b-3",
        "Flag": "b-3",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "",
        "disable": 0
    },
    {
        "Key": 82,
        "Flag": "b-3-2",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "尝试验证",
        "disable": 0
    },
    {
        "Key": 83,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我猛地伸出手去，竖起两根手指恶狠狠地掐住了大腿根上的皮肉。钻心的疼痛让我忍不住咬紧牙齿，从齿缝里倒吸了一口凉气。",
        "disable": 0
    },
    {
        "Key": 84,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嘶……哇！疼疼疼疼疼……",
        "disable": 0
    },
    {
        "Key": 85,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……你干什么。",
        "disable": 0
    },
    {
        "Key": 86,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她那张原本万年不化的冰块脸也因为我的行径而忍不住泛起一丝红晕……在她身后，凯茜娅似乎是第一个反应过来的，当场就笑得前仰后合，毫不遮掩。",
        "disable": 0
    },
    {
        "Key": 87,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哈哈哈……这个笨蛋，怕不是以为自己还在瓦尔哈拉空间里？",
        "disable": 0
    },
    {
        "Key": 88,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她那一双魅蓝色的瞳孔幽光闪烁，直勾勾地盯着我。",
        "disable": 0
    },
    {
        "Key": 89,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "安心吧。你现在身上一点泰坦物质的反应都没有。昏了整整两天，现在你已经……回到这边的世界里了。",
        "disable": 0
    },
    {
        "Key": 90,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我真的……回来了吗？",
        "disable": 0
    },
    {
        "Key": 91,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我把求助的目光看向里芙和伊切尔——作为曾与我一同进入过瓦尔哈拉空间里的两人，此刻，她们的回应会让我更加确信。",
        "disable": 0
    },
    {
        "Key": 92,
        "Flag": "",
        "Pos": 3,
        "Speaker": "狂猎",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯，回来了。",
        "disable": 0
    },
    {
        "Key": 93,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她背靠着墙，抱着双臂，脸上挂着淡淡的笑容，只有微微皱起的眉毛出卖了她，让我立刻就感受到了直到方才，她都心有不安。",
        "disable": 0
    },
    {
        "Key": 94,
        "Flag": "",
        "Pos": 1,
        "Speaker": "伊切尔",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……分析员是大笨蛋！",
        "disable": 0
    },
    {
        "Key": 95,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她把双手放在额头上，比划出长了角的模样，用以提醒我如果眼下并非现实的话，那她应该是另一副模样才对。",
        "disable": 0
    },
    {
        "Key": 96,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "娇憨的腔调和表情惹得屋子里的人都忍不住发笑，看到她们的反应，我悬着的心也终于轰然坠地。",
        "disable": 0
    },
    {
        "Key": 97,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "终于……都结束了啊。",
        "disable": 0
    },
    {
        "Key": 98,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "对。都结束了。但有些事我们得谈谈。",
        "disable": 0
    },
    {
        "Key": 99,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我顺着她的话语抬起头来，迎上了她的眼睛。",
        "disable": 0
    },
    {
        "Key": 100,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "塔妮亚……奥尔洛娃已经不在了。她之所以会变成泰坦，是因为有人一直在她的雾化器里投毒，导致她的身体里积累了过量的泰坦物质。",
        "disable": 0
    },
    {
        "Key": 101,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "事发的当天，军方截获了赫瓦雷纳集团的首领罗赞司令发给刺客们的行动指示，只不过当时没有人能想得到她会是受害者。",
        "disable": 0
    },
    {
        "Key": 102,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我们解决了耶洛沙的树，但我们的对手也带走了耶洛沙最后的主人。",
        "disable": 0
    },
    {
        "Key": 103,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "留给我们的善后工作……可不会比拔树轻松太多。",
        "disable": 0
    },
    {
        "Key": 104,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "后来，我花了点时间才消化干净陶向我同步的所有情况。",
        "disable": 0
    },
    {
        "Key": 105,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "原来在我被迫与化为泰坦的奥尔洛娃作战的同时，前董事会的余孽们就借着舆论攻势打乱了陶的部署。",
        "disable": 0
    },
    {
        "Key": 106,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "如果不是我和海姆达尔的队员们击败了奥尔洛娃，成功解决了这棵树，恐怕此时此刻，世界树将会面临千夫所指，百口莫辩的局面。",
        "disable": 0
    },
    {
        "Key": 107,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "更凶险的是——在我进入瓦尔哈拉空间的同时，军方司令部已经下达了指令，十几枚战术核弹挂在飞行载具上，直扑北风航天中心。",
        "disable": 0
    },
    {
        "Key": 108,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "最后关头，是深入苏兹达尔基地，想要支援我们的妮塔，肴和李秋雪看到了发射塔上的树崩解消散的场景，由李秋雪联络了阿德里安上将……",
        "disable": 0
    },
    {
        "Key": 109,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "后者越级夺过了指挥权，才让整个航天中心免于人祸。",
        "disable": 0
    },
    {
        "Key": 110,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "也因此，军方上下对这次的事件三缄其口，不肯对外公布半点真相。",
        "disable": 0
    },
    {
        "Key": 111,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "作为交涉，抑或是一种……补偿？伊切尔得以离开耶洛沙，以海姆达尔队员的身份，从此之后由我来看护。",
        "disable": 0
    },
    {
        "Key": 112,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "凯茜娅也是如此——她似乎真的对那个与权力有关的问题耿耿于怀，打算就此寸步不离地盯着我……",
        "disable": 0
    },
    {
        "Key": 113,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "真是胡闹。",
        "disable": 0
    },
    {
        "Key": 114,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "什么？",
        "disable": 0
    },
    {
        "Key": 115,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不。没什么……",
        "disable": 0
    },
    {
        "Key": 116,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "此刻，我和她正一起漫步在列车站台上——除了里芙，凯茜娅和伊切尔要留下来陪我做一些善后工作之外，其他的队员们刚刚都乘上了直通世界树总部的列车。",
        "disable": 0
    },
    {
        "Key": 117,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "对耶洛沙的种种情况颇有了解的苔丝本来也该留下，但她和我一样挂念着晴的伤势。于是在得到了陶的默许之后，也忙不迭地踏上了归途。",
        "disable": 0
    },
    {
        "Key": 118,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "说起来，你还没告诉我，为什么你会亲自到这边来？",
        "disable": 0
    },
    {
        "Key": 119,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这地界可不太平。而且……这也不像是你平日里的行事风格。",
        "disable": 0
    },
    {
        "Key": 120,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你……你在明知故问吗？",
        "disable": 0
    },
    {
        "Key": 121,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哈啊？",
        "disable": 0
    },
    {
        "Key": 122,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她正在用我前所未见的语气和表情……埋怨着我？",
        "disable": 0
    },
    {
        "Key": 123,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不是你自己亲口说的么……",
        "disable": 0
    },
    {
        "Key": 124,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "要我……像个……真正的上级一样。",
        "disable": 0
    },
    {
        "Key": 125,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "照……照顾好你们。",
        "disable": 0
    },
    {
        "Key": 126,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我照做了，就这样。",
        "disable": 0
    },
    {
        "Key": 127,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她像是打了什么败仗一样丢下这句话，转身离去，独留我一个人站在月台上。",
        "disable": 0
    },
    {
        "Key": 128,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "夜幕里，极光笼罩下的沙钦车站依旧神秘而美丽。但与初来此地时不同，如今的它在我眼里已不再像个会择人而噬的巨兽了。",
        "disable": 0
    },
    {
        "Key": 129,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "冷风拂面，我瑟缩着身体打了个寒颤。借着站台上星星点点的灯光，我抬起眼睛，望向了黑暗深处的苏兹达尔火箭基地。",
        "disable": 0
    },
    {
        "Key": 130,
        "Flag": "",
        "Pos": 6,
        "Speaker": "伊切尔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "——那边有坏东西盯着我！我不想输给它！",
        "disable": 0
    },
    {
        "Key": 131,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯。我们……没有输给它。",
        "disable": 0
    },
    {
        "Key": 132,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你也没有输给它。",
        "disable": 0
    },
    {
        "Key": 133,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "明天的耶洛沙……一定会是个大晴天。",
        "disable": 0
    }
]