[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "克罗瑞娜觉得很久都没有这么顺利地入睡了。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她一会儿梦见自己像是躺在手术台上。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "安静，冰冷，让她少见地也有些害怕。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但很快，他的手牢牢地握住了她，由他传递过来的温暖，带着她走向真正的新生。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "过了一会儿，她的梦境又回到了和他相拥着从飞机上坠落的那一刻。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她还从没经历过那么慌乱危险的时刻。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但有他一起，即便两个人在飞速坠落，她也只觉得无比地安全。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她还记得在医疗舱里她做的那个梦。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那是她第一次品尝到来自于他的味道。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "梦里，她听见他的声音。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……克罗瑞娜？",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "还是那么好听的声音，充满磁性地呼唤着她的名字。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一轮圆月悬挂在漆黑的夜空，照亮了她心底的另一个世界。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那个世界以前从未存在，在听到他呼唤着她的声音后，顷刻之间便在她的心里落成。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "皎月生出了另一面，绯红诡谲的光倾洒下来，她也生出了两面。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是我，我是playername。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她捧起他的手，吻了上去，像是歉疚，也像是在回味甘醴。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而他却是那样洞察一切又温柔强大的给予者，将自己的手掌贴近她的唇齿。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "克罗瑞娜睁开眼睛，愣愣地看着头顶的天花板。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "住进基地的第一个夜晚，她就再次梦见了分析员。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "靠着梦里的感觉，她对分析员与日俱增的思念终于稍稍缓解了一丁点儿。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但当她彻底醒过来时，她立刻发现那份思念反而变得更强了。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "克罗瑞娜拉过被子蒙住头，试图回味刚才的梦境。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她终究还是慢慢坐起来，热情又难为情地，想为他做点什么。",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一份礼物？一个惊喜？",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "或者是她觉得最能表达心意的，用心培育的花园。",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "洗澡的时候她胡思乱想着礼物的选项，但不论如何，从家里带过来的研究笔记看来要派上用场了。",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "花的形态、习性、气味……找对了基因点位，这些都可以进行更改。",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "假期里她回吉诺拉庄园又查阅了不少研究资料，逐渐心里有了把握，又早早地赶回了基地。",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这一次，克罗瑞娜想尝试一个不一样的方案。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她想把自己的爱意编入这份礼物。",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "如果真有那么一天可以将这份礼物送给他，她希望分析员从这份礼物中，得到他真正喜欢的。",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哪怕只是能闻到令他愉悦的花香，这也是一份有意义的礼物，不是吗？",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她提前结束假期，回到基地，分析员一行人还未归，基地里只有她一个人。",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "除了悉心照料植物，更新研究笔记，剩下的时间，她总是一遍遍看着终端里自己和分析员的聊天记录。",
