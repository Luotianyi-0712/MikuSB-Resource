        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她吐着小舌头，用手不停扇风，刚刚积蓄的睡意顷刻间消散无踪。",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 6,
        "Speaker": "猫汐尔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "呜喵，这具身体还真是脆弱呢……",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 6,
        "Speaker": "猫汐尔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "要是以前的话……",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "回想起以前，少女却又突然愣住。",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是啊，若是从前，她根本不知疼痛为何物。",
