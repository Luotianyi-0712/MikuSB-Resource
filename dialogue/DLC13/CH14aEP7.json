    },
    {
        "Key": 82,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这是我的选择所带来的代价，无论如何，已经比我事前猜想的代价要小得多了。",
        "disable": 0
    },
    {
        "Key": 83,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
