    },
    {
        "Key": 130,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "剧烈的耳鸣声中，我看着医疗部的天花板，只感觉一阵恍惚。",
        "disable": 0
    },
    {
        "Key": 131,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "卜卜……",
        "disable": 0
    },
    {
        "Key": 132,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不可能……不应该是这样……",
        "disable": 0
    },
    {
        "Key": 133,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我……我要去救她……",
