[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 9,
        "Speaker": "芙提雅驰掣",
        "RealSpeaker": 9,
        "WwiseEventID": "",
        "zh_CN": "准备好了吗？",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "三天后，我平躺在医疗部的治疗舱内，朝着监控摄像头另一边的芙提雅微微点了点头。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我朝左边看去，卜卜正躺在离我半步远的另一个治疗舱内。她刚结束了神格神经的移植手术，气色比前几天好了许多。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "但我知道，她现在依然是缺少灵魂的空壳。如果不能将她的意识唤醒，我们先前所做的一切都会是无用功。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 9,
        "Speaker": "芙提雅驰掣",
        "RealSpeaker": 9,
        "WwiseEventID": "",
        "zh_CN": "我们都会在仪器这边盯着分析员的情况，如果有任何变故，我们就会把分析员带回来的！",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "嗯，那就交给大家了。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "治疗舱里的仪器开始嗡嗡作响，随之而来的是强烈的昏睡感。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "闭上眼后，我就会进入卜卜的意识空间中。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "无论如何，也要拯救她。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "？？",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "呃——！",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "率先进入耳中的是一声闷哼。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "还没来得及思考闷哼来自哪里，我便感觉脖颈处一阵凉意，整个人随即毫无阻拦地飞了出去。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "眼前天旋地转，直至后脑像是撞到了石头之类的东西，眼前晃动的世界才堪堪停下。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "意识消失之前，我的眼中满是猩红，以及淹没于猩红之中的瘦小少女——",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "！！！",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我的身体触电般从治疗舱中弹起。姗姗来迟的肾上腺素终于到达了心脏，让我止不住地大口呼吸起空气。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "刚才那是什么？",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "疑惑，夹杂着恐惧和死里逃生的庆幸，充斥了我的大脑，让我几乎忘记了自己身处何处。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 9,
        "Speaker": "芙提雅驰掣",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "分析员！",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "治疗室的大门被推开，天启者们纷纷冲了进来，将我团团围住。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芙提雅驰掣",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "怎么会这样，我……",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我伸手捧住了芙提雅因为焦急而变得苍白的脸，朝她摇了摇头。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "冷静点……起码，先让我喘口气。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芙提雅驰掣",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "好……",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我看到芙提雅深吸了口气，将原本苍白的脸又憋得通红，其他人也纷纷沉默下来。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我先确认一件事，现在离我进入卜卜的意识空间开始过了多久？",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芙提雅驰掣",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "十秒钟，只过了十秒钟。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "……我明白了，看来我们从一开始就弄错了一些事情。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "卜卜根本没有给我留出拯救她的时间——她的记忆停留在了被击倒的前一刻。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "用安卡希雅的话来说，这相当于在一个必死的路线上进行了存档。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 6,
        "Speaker": "猫汐尔溯影",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "数据结果也出来了，大概是因为那个画面对她的冲击力太强，她现在完全没办法想起其他的东西。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "猫汐尔捧着终端快速地汇报了情况，连一贯的口癖都被省略了。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "也就是说，没办法把我送到之前的记忆节点中吗？",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "猫汐尔溯影",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "目前看来是这样的。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我摁住自己剧烈跳动的太阳穴，慢慢舒了口气。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "不过，就算在卜卜的意识中受到重创，我也正常醒过来了。看起来，导致我强制离开意识空间的原因是卜卜的“死亡”……",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "这样的话，还能再多试上几次。",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "芙提雅，帮我重启系统吧，我……",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 6,
        "Speaker": "莫尔索悖谬",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "等等，分析员！",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我转过头去，莫尔索不知何时已经取得了身体的控制，此刻正紧紧抓着我的手。",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 6,
        "Speaker": "莫尔索悖谬",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "我……不同意让分析员再去涉险！",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "在平时，即使莫尔索不控制身体我也能看到她。所以她在这时候站出来说这些话，更像是要说服在场的其他人。",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 6,
        "Speaker": "莫尔索悖谬",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "我知道死亡的感觉……哪怕只有一次我也忘不掉。",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 6,
        "Speaker": "莫尔索悖谬",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "如果一次又一次做这样的事情，我怕分析员会——",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "说到最后，她几乎声嘶力竭，随即便扑到了我的怀中。",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "再看其他人，显然也因为莫尔索的反应产生了或多或少的动摇。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "好啦……莫尔索知道，当时为了找到你，我进行了多少次锚定实验吗？",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 6,
        "Speaker": "莫尔索悖谬",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "琴诺和我说过了……是52次。",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "那我和莫尔索约定，不会超过这个数量的。",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 6,
        "Speaker": "莫尔索悖谬",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "如果我中途坚持不下去了，我也会和大家说的。所以，先相信我好吗？",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 6,
        "Speaker": "琴诺悖谬",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "我……一直相信着分析员。",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "怀中变成了琴诺的声音，看起来，莫尔索似乎默许了我的决定。",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "那我们继续。这一次，把意识监控设备锁定到我这边。",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我要看清，攻击卜卜的到底是什么东西。",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 0,
        "Speaker": "？？",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "呃——！",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "在接入意识空间的下一刻，熟悉的闷哼声便再次传来。",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "但这一次，我算准了声音传来的方向，毫不犹豫地朝那边推了一把。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "紧接着，我便如上一次一样，被巨大的力量拍飞出去。",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "同样的天旋地转，同样的后脑剧痛，只不过，我的意识并没有在同样的地方被切断。",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "原因无他，那个在上一次记忆中倒在血泊中的少女，此时正满脸惊愕地跌坐在地上。",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "果然，只要她还活着，意识空间就还能……",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我的心中刚刚产生些许庆幸，便像断线般失去了意识。",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "看清楚了吗？",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我撑着头痛欲裂的脑袋，从医疗舱中站了起来。",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "监控室里，芙提雅她们正盯着意识监控器发回的画面，逐帧观看着我刚才的记忆。",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "几分钟后，她们走进了医疗室，每个人脸上都带着困惑。",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芙提雅驰掣",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "不太对劲，分析员。",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "怎么了？",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 0,
        "Speaker": "芙提雅驰掣",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "卜卜记忆中的这个黑影，似乎根本不是一个实际存在的东西。",
        "disable": 0
    },
    {
        "Key": 71,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "你的意思是，她被一个不存在的黑影打成了重伤？",
        "disable": 0
    },
    {
        "Key": 72,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "正常时候我一定不会问出这样的傻问题，但在今天，我遇到的怪事已经够多了。",
        "disable": 0
    },
    {
        "Key": 73,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "芙提雅点了点头，将存储了视频的终端递给我，而我很快也露出了和她们一样的表情。",
        "disable": 0
    },
    {
        "Key": 74,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "画面中，我在黑影的攻击到来之前将卜卜推开，而自己被黑影拍飞。",
        "disable": 0
    },
    {
        "Key": 75,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "但奇怪的是，明明在我面前的黑影，在下一个瞬间就出现在了卜卜面前，将她也拍飞出去。",
        "disable": 0
    },
    {
        "Key": 76,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "即使将视频放慢成百上千倍，也根本捕捉不到黑影的速度，甚至连形态都模糊不清。",
        "disable": 0
    },
    {
        "Key": 77,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "有意思……如果她遇到的真是如此强大的怪物，她根本不可能活下来。",
        "disable": 0
    },
    {
        "Key": 78,
        "Flag": "",
        "Pos": 9,
        "Speaker": "芙提雅驰掣",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "那么这东西果然是……",
        "disable": 0
    },
    {
        "Key": 79,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "嗯，这个黑影应该是卜卜想象出来的。或者说，她将自己遇到的敌人夸张化了。",
        "disable": 0
    },
    {
        "Key": 80,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "别忘了，她那时还只是普通人。在她眼中，她完全敌不过那黑影，所以才会觉得对方力大无穷又神出鬼没。",
        "disable": 0
    },
    {
        "Key": 81,
        "Flag": "",
        "Pos": 9,
        "Speaker": "猫汐尔溯影",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "真难办喵。",
        "disable": 0
    },
    {
        "Key": 82,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "也就是说，我要在她“死亡”的前一刻，解决掉那个她认为是“无敌”的敌人……",
        "disable": 0
    },
    {
        "Key": 83,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "说完这句话，我自己都忍不住苦笑出来。",
        "disable": 0
    },
    {
        "Key": 84,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "还真是留了个难题啊，卜卜。",
        "disable": 0
    },
    {
        "Key": 85,
        "Flag": "",
        "Pos": 5,
        "Speaker": "芙提雅驰掣",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "那我们……",
        "disable": 0
    },
    {
        "Key": 86,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "不，还没到放弃的时候。",
        "disable": 0
    },
    {
        "Key": 87,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "归根结底，所谓的“无敌”也是卜卜想象出来的。",
        "disable": 0
    },
    {
        "Key": 88,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "如果我能够让卜卜相信，那东西是可以被打倒的，那它就真的能被打倒，对吧？",
        "disable": 0
    },
    {
        "Key": 89,
        "Flag": "",
        "Pos": 5,
        "Speaker": "芙提雅驰掣",
        "RealSpeaker": 6,
        "WwiseEventID": "",
        "zh_CN": "但是，要怎么做？",
        "disable": 0
    },
    {
        "Key": 90,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我需要一把枪。",
        "disable": 0
    },
    {
        "Key": 91,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "卜卜是持有配枪的外勤队员，一定尝试过对那怪物开枪。",
        "disable": 0
    },
    {
        "Key": 92,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "就算她的攻击最终没有奏效，她也一定会对枪声有反应。",
        "disable": 0
    },
    {
        "Key": 93,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "枪声不需要打倒黑影，只需要让卜卜意识到，有人来救她就足够了。",
        "disable": 0
    },
    {
        "Key": 94,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "如果握着一把枪入睡，是否真的会在梦中梦到自己正握着枪？",
        "disable": 0
    },
    {
        "Key": 95,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我对大脑和梦境都不甚了解，但当我在卜卜的意识空间中睁开眼时，我的手中的确握着一把手枪——一把从现实中被我带进来的手枪。",
        "disable": 0
    },
    {
        "Key": 96,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "同样的闷哼，同样的黑影，我甚至没有刻意瞄准，就凭着记忆朝前方扣动了扳机。",
        "disable": 0
    },
    {
        "Key": 97,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "砰、砰、砰、砰、砰、砰……",
        "disable": 0
    },
    {
        "Key": 98,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "直至一口气倾泻了全部的弹药，我才将手枪收回，转而回头将跌坐在地上的卜卜一把抱起。",
        "disable": 0
    },
    {
        "Key": 99,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "然后，头也不回地向着前方奔去。",
        "disable": 0
    },
    {
        "Key": 100,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "直到身后完全没了声音，我才逐渐停下脚步。",
        "disable": 0
    },
    {
        "Key": 101,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "这地下洞穴的路并不好走，大多都是蜿蜒崎岖的小路，其中又有许多坑洞彼此相连。我只凭着直觉一路前进，到停下时，已经不知道来到了什么地方。",
        "disable": 0
    },
    {
        "Key": 102,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "怀中的卜卜早已昏了过去——她在被黑影逼至绝境之前本就受了伤，现在情况也好不到哪儿去。",
        "disable": 0
    },
    {
        "Key": 103,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我找了片空地将她轻轻放下，自己也就近坐了下去，让她能够靠着我躺下。",
        "disable": 0
    },
    {
        "Key": 104,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "出于意识连接的原因，我现在无法离她太远。而现在又没法和她交流，于是我也抽空打量起这个地下洞穴。",
        "disable": 0
    },
    {
        "Key": 105,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "毫无疑问，这里离地面有不短的距离。相比干燥炎热的地面，这里幽静而潮湿，唯一的光源便是来自上方的洞口，但这些洞口都离我有几十米的距离。",
        "disable": 0
    },
    {
        "Key": 106,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "放眼望去，前方几乎被黑暗笼罩。不过，远处似乎错落分布着一些发着光的特殊矿石和植物，昭示着这个地下空洞的大小相当夸张。",
        "disable": 0
    },
    {
        "Key": 107,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "在此之前，我从未想过北庭卫的地下竟然有着这样一个截然不同的世界。",
        "disable": 0
    },
    {
        "Key": 108,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "另外，在方才跑到这里的路上，我注意到这个地下洞穴有不少人工开凿的痕迹，也许卜卜正是发现了什么才涉险进入这里……",
        "disable": 0
    },
    {
        "Key": 109,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我正这样想着，忽然感觉身边的卜卜动了一下。",
        "disable": 0
    },
    {
        "Key": 110,
        "Flag": "",
        "Pos": 0,
        "Speaker": "卜卜",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "好……好痛……",
        "disable": 0
    },
    {
        "Key": 111,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "意识恢复的刹那，疼痛感随即袭来。身体从上到下似乎都在发出尖叫，让卜卜连呼吸都十分困难。",
        "disable": 0
    },
    {
        "Key": 112,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "她只感觉自己的喉头被什么东西死死堵着，于是猛地咳了出来。",
        "disable": 0
    },
    {
        "Key": 113,
        "Flag": "",
        "Pos": 0,
        "Speaker": "卜卜",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "咳咳咳！",
        "disable": 0
    },
    {
        "Key": 114,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "大口大口的空气涌入肺部，让她触电般直起了身子。",
        "disable": 0
    },
    {
        "Key": 115,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "但下一刻，她又感觉到被一股力量拽了一下，整个人随即扑倒下去。",
        "disable": 0
    },
    {
        "Key": 116,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "奇怪的是，她感觉到的并不是地面的冰冷触感，而是……同样坚硬，却带着温暖的熟悉感觉。",
        "disable": 0
    },
    {
        "Key": 117,
        "Flag": "",
        "Pos": 0,
        "Speaker": "卜卜",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "呃……",
        "disable": 0
    },
    {
        "Key": 118,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "她睁开了眼睛。",
        "disable": 0
    },
    {
        "Key": 119,
        "Flag": "",
        "Pos": 0,
        "Speaker": "卜卜",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "……呃？",
        "disable": 0
    },
    {
        "Key": 120,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我们四目相对，她的闷哼也随即变了个调子。",
        "disable": 0
    },
    {
        "Key": 121,
        "Flag": "",
        "Pos": 0,
        "Speaker": "卜卜",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "你是……playername，海姆达尔的分析员？",
        "disable": 0
    },
    {
        "Key": 122,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "她虚弱的语气中充满了困惑，比起问我，更像是在和自己确认。",
        "disable": 0
    },
    {
        "Key": 123,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "我看着仍在恍惚的卜卜，坚定地点了点头。",
        "disable": 0
    },
    {
        "Key": 124,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": 0,
        "WwiseEventID": "",
        "zh_CN": "是我，卜卜。我们终于见面了。",
        "disable": 0
    }
]