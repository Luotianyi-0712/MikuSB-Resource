        "Flag": "",
        "Pos": 6,
        "Speaker": "奥尔洛娃公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……你们这些外人闯进来，把我的家搞的一团糟，把我们的人民架在火上烤！",
        "disable": 0
