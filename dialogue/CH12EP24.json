    {
        "Key": 73,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而我的另一只手却变得空荡——晴已经甩开了我的手掌，大踏步地走上前去，拦住了女公爵的脚步。",
        "disable": 0
    },
    {
        "Key": 74,
        "Flag": "",
        "Pos": 5,
        "Speaker": "晴藏锋",
        "RealSpeaker": "",
        "WwiseEventID": "",
