    {
        "Key": 75,
        "Flag": "",
        "Pos": 4,
        "Speaker": "抵抗军士兵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "请您让开，那些被污染了的兄弟需要由公爵大人来……",
