    {
        "Key": 16,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奥尔洛娃公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "还指望我会一直把头低下去，对你们予取予求？",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奥尔洛娃公爵",
        "RealSpeaker": "",
        "WwiseEventID": "",
