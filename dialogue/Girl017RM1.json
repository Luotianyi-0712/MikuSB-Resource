    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她是在表演魔术吧。可是为什么是这副表情？她不是最喜欢魔术吗？",
        "disable": 0
