        "Key": 8,
        "Flag": "",
        "Pos": 6,
        "Speaker": "琴诺",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我和莫尔索打个电话，问问她愿不愿意。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "琴诺从她的裤包里拿出自己的终端，捧在耳边。",
