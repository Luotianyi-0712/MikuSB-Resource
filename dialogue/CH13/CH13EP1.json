    },
    {
        "Key": 86,
        "Flag": "",
        "Pos": 6,
        "Speaker": "茉莉安",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "如果有人想利用泰坦物质来影响这里的人的精神状态的话，眼下无疑就是最好的时机——呃，分析员？",
        "disable": 0
    },
    {
        "Key": 87,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她倒吸了半口气，微张着嘴，困惑地看着我推到她面前的餐盘。",
        "disable": 0
    },
    {
        "Key": 88,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "边吃边说吧，放松一点。",
