        "Key": 153,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "可恶——还没完呢，别想从本小姐手里逃走！！",
        "disable": 0
    },
    {
        "Key": 154,
        "Flag": "",
        "Pos": 6,
        "Speaker": "瑟瑞斯瞬刻",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮！冷静点……已经没事了……",
        "disable": 0
    },
