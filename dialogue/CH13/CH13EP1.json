    },
    {
        "Key": 156,
        "Flag": "",
        "Pos": 0,
        "Speaker": "？？？",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……发生什么事了？",
        "disable": 0
    },
    {
        "Key": 157,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "眼前有模糊的人影，但我分不清这究竟是脑内的影像还是现实中的真实场景。",
        "disable": 0
    },
    {
        "Key": 158,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……离远……远一点！别……靠过来，会……危险……",
        "disable": 0
