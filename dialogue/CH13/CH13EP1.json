    },
    {
        "Key": 80,
        "Flag": "",
        "Pos": 6,
        "Speaker": "侍者",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……不。我哪边都不沾。我只是个普通的新恒提罗人。",
        "disable": 0
    },
