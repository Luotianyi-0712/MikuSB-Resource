    },
    {
        "Key": 95,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我抓起一杯气泡水，杯子里的冰块随着我的粗暴举止而发出一连串响动——咬住吸管之后，薄荷与碳酸的刺激立刻在我脑袋里炸开。",
        "disable": 0
    },
    {
        "Key": 96,
        "Flag": "",
        "Pos": 6,
        "Speaker": "茉莉安",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "呵……",
        "disable": 0
    },
    {
        "Key": 97,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她笑什么？",
        "disable": 0
    },
