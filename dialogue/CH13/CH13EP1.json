    },
    {
        "Key": 117,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "日光很足，但我的身体却只感觉到阴冷。",
