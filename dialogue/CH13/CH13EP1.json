    },
    {
        "Key": 108,
        "Flag": "",
        "Pos": 6,
        "Speaker": "茉莉安",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "您之前吩咐我做的事情都已经做好了。",
        "disable": 0
    },
    {
        "Key": 109,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她出声打断了我的思虑，我回过神来看着她，发现她正埋头在一张便笺上写着什么。",
