        "Key": 132,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "本小姐隔着那扇玻璃窗，看你像个傻子一样在这门口晃了快半小时了！",
        "disable": 0
    },
    {
        "Key": 133,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "妮嗦甚麽……",
