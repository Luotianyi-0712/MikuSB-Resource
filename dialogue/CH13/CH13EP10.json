    },
    {
        "Key": 111,
        "Flag": "",
        "Pos": 6,
        "Speaker": "罗赞",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你为了错误的目标拼尽全力的模样……很迷人！",
        "disable": 0
    },
    {
        "Key": 112,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她的确把这样的话语留在了茉莉安的手腕里，用我的方法来向我传递她的态度。",
        "disable": 0
    },
    {
        "Key": 113,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你有话说。",
        "disable": 0
    },
    {
        "Key": 114,
        "Flag": "",
        "Pos": 6,
        "Speaker": "罗赞",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯。我有话说，最后一次说。",
        "disable": 0
    },
    {
        "Key": 115,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我不跟你走。",
