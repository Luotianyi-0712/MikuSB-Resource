    {
        "Key": 14,
        "Flag": "",
        "Pos": 6,
        "Speaker": "茉莉安",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "您拒绝让那名酒保来治疗芬妮小姐，然后……与她动起手来，最终被她杀掉了……",
