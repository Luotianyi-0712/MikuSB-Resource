[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "雷吉乌斯",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "第52次锚定记录。"
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安全部干员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "长官？"
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安全部干员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "长官，这里就是降临团的1号据点了。"
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安全部干员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在外围抵抗的持械危险分子已经按您交代的抓起来了，我们现在准备进去检查一下里面还有没有危险品。"
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安全部干员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这是任务记录，您检查一下，没问题的话我就发给上面了哈。"
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我接过安全部干员递来的终端，上面只有寥寥几行字。"
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "“2056年2月27日，突入危险组织‘降临团’据点，抓捕武装人员12名，头目3名……”"
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没问题，你去发吧，我也进去据点里边看看。"
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安全部干员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好嘞，那您自己小心。"
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "将终端递给对方后，我沿着狭小逼仄的通道走了十来步，来到了降临团据点的内部。"
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "数十个房间整齐排列着，几名干员们正穿行于它们之间，搜寻降临团藏匿的武器和爆炸物。"
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而在走廊尽头，两名干员站在一扇黑色的门前，似乎在争论着什么。看到我走近，他们立刻迎上前来。"
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安全部干员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "长官，这个房间里面好像有人的声音。"
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安全部干员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我们担心里面有埋伏。您知道的，降临团一些暴徒持有利器和炸药……"
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯，谨慎一些是好事。"
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "把防暴盾给我吧，我进去看看。"
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安全部干员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "长官，这……"
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我摇了摇头，从干员手中拿过防暴盾，打开了门。"
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在我开门的同时，房间深处的角落里也传出了衣服摩擦的声音。"
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "房间内一片漆黑，散发着阴冷而带有灰尘的气息。里面似乎完全没有窗户或通风口，与外界唯一的连接就是我身后的门。"
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "借着门外的光，我勉强看清了这个房间的内部构造。房间里只有一张靠墙的小床，一把椅子，似乎是刻意为了让人感到不适而存在。"
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "整个房间都没有能藏人的地方，看来角落里缩成一团，像被遗弃的毛绒玩具般的，就是这个房间里唯一的人。"
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不用担心了，里面只有一个孩子。"
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "帮我准备块毯子，对了，还要个纸袋子。她应该在这个房间待了挺长一段时间了，直接出去的话眼睛会受伤。"
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我蹲下身子，慢慢将黑暗中的女孩抱起。"
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她的身体很轻，呼吸很重，在我怀中不停地颤抖。"
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "接过干员们递过来的毯子和纸袋后，我把她裹了个严严实实。"
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "别怕，很快就能出去了。"
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "接下来你们把这孩子送上救护车吧，我去其他地方看看。"
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我正准备将怀中的女孩交给安全部干员们，她却忽然轻微地动了一下，似乎想抬起自己的手。"
    },
    {
        "Key": "b-1",
        "Flag": "b-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": ""
    },
    {
        "Key": 31,
        "Flag": "b-1-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "朝她伸出手"
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "周围的一切随着我的行动停止，我试图伸出的手突兀地停在空中，任凭我如何努力也无法再靠近半分。"
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "就在这时，我看到那只瘦弱的手在定格的时间中慢慢举起，直至触摸到我的脸颊。"
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "电光石火之间，我的脑中如爆炸般涌出无数记忆。"
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……哈。"
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "找到你了，莫尔索。"
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 0,
        "Speaker": "莫尔索悖谬",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我做了一个漫长的梦。"
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "莫尔索悖谬",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我在冰冷的海洋中不断下沉，落入没有一点光亮的深渊之中。"
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "莫尔索悖谬",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "直到一只手拉住了我，缓慢却又坚决地把我拉了上去。"
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "呼——"
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "从来没有觉得医疗室的灯光这么令人安心过。"
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在睁开眼时，我感觉到先前封存的记忆已经尽数恢复了，这也就意味着……"
    },
    {
        "Key": "b-2",
        "Flag": "b-2",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": ""
    },
    {
        "Key": 43,
        "Flag": "b-2-1",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "成功了吗，琴诺？"
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 6,
        "Speaker": "莫尔索悖谬",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "现在，是莫尔索哦。"
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 6,
        "Speaker": "莫尔索悖谬",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "终于……又见面了。"
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 4,
        "Speaker": "恩雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "所以，算是圆满解决了吧？"
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "难得的休息日，少女们聚集在基地大厅。分析员这些天以来的“小动作”并没有瞒住任何人，但为了不给那个人徒增压力，她们只能将这份担心深藏于心。"
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 5,
        "Speaker": "瑟瑞斯",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "莫尔索顺利回来了，琴诺的身体也没出现问题。分析员的大脑出现了过度使用的后遗症，静养一段时间就好。"
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芙提雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "唯一的受害者是芙提雅老师的锚定装置！它在超负荷运转两周之后，还是光荣牺牲了。"
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 6,
        "Speaker": "肴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不过，在五年前把琴诺从降临团救出来的人，竟然就是还在安全部的playername……"
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "肴",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "最离奇的是，两位，哦不，三位当事人都对这件事一无所知，最后检查了记忆才弄清楚。"
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 5,
        "Speaker": "安卡希雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "playername，总是会遇到这种事。"
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 6,
        "Speaker": "恩雅",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好啦，不管怎样，分析员和小琴诺没事就好。"
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 1,
        "Speaker": "苔丝",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "何止是没事……"
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 0,
        "Speaker": "苔丝",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我今天刚看到莫尔索说，既然她回来了，以后陪她和琴诺的时间得是别人的两倍才行。"
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 3,
        "Speaker": "芬妮",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哈？！"
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 0,
        "Speaker": "琴诺悖谬",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "分析员，这边，前面就是那家卖草莓炒鱼丸的店了。"
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "恢复得差不多以后，琴诺非说要带我去吃她发现的宝藏料理，于是一大早我就被拽出了公司。"
    },
    {
        "Key": "b-3",
        "Flag": "b-3",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": ""
    },
    {
        "Key": 59,
        "Flag": "b-3-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一定要吃这个吗？"
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 0,
        "Speaker": "莫尔索悖谬",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你要是受不了的话，我可以勉为其难帮你吃掉一些哦。"
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在另一边，莫尔索笑盈盈地看着我。"
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "现在，通过接触琴诺，莫尔索能短暂地以信息态的方式独立于琴诺出现——虽然只有我和琴诺能看到。"
    },
    {
        "Key": "b-4",
        "Flag": "b-4",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": ""
    },
    {
        "Key": 63,
        "Flag": "b-4-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你可真得帮帮我。"
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 0,
        "Speaker": "琴诺悖谬",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "莫尔索又让分析员偷跑……"
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "琴诺赌气般地把我往她的方向拉近了些，脸上也浮现出淡淡的红晕。"
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在两人叽叽喳喳的吵闹声中，我们一同朝着远方走去，走向我和她们约定好的每一个地方。"
    }
]