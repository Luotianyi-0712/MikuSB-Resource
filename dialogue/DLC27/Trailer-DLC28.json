    {
        "Key": 32,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "现在卫城学院是有求于我们的那方，本来我们可以更加强势一些，不过嘛……给他们个面子，我们会赚更多。",
        "disable": 0
    },
