[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 6,
        "Speaker": "优格",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_npc084_01",
        "zh_CN": "呼……唔呼……",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 4,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl021_01",
        "zh_CN": "不行，我尝试了所有已知的方法，都没法终止超频，现在，只能继续物理降温了。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 5,
        "Speaker": "妮塔",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl003_01",
        "zh_CN": "我再去接点冷水。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "从后半夜起，优格的身体便出现了问题，她的各个电子模块都不受控制地处于超负荷运转状态，身体也呈现出类似人类发烧般的表现。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "有种不祥的预感在我的心间弥散开来——",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "因为我们而意外苏醒的优格，现在似乎又将回到我们来之前的状态。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 6,
        "Speaker": "优格",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_npc084_02",
        "zh_CN": "playername哥哥……",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我在。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 6,
        "Speaker": "优格",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_npc084_03",
        "zh_CN": "不知道为什么……感觉……记忆混乱……有什么东西……在灼烧……",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 6,
        "Speaker": "优格",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_npc084_04",
        "zh_CN": "不要……不要丢下我……我……我不想再一个人了……",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我们不会丢下你的，昨天晚上我们不是还拉钩了吗？",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 6,
        "Speaker": "优格",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_npc084_05",
        "zh_CN": "唔……",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她将头努力扭向了我，她似乎还能听清我的声音，不过已经没有力气再做出更多的回应了。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "于是，我思索片刻，便又看向了正在不停操控着终端的奈莉德。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "奈莉德，今天你就留在临时营地照顾优格吧。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 9,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl021_02",
        "zh_CN": "嗯？",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "正在敲击键盘的手指悬在了半空，她似乎很意外，我居然将优格交给她独自看管。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "就差一组电池了，我和妮塔去就好。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "随后她的目光缓缓抬起，与我的视线交汇。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl021_03",
        "zh_CN": "我明白了。这里就交给我好了。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "片刻的沉默后，她的眼神逐渐变得坚定。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "见状，我便放下心来，带着妮塔走出了临时营地。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "临时营地外，一个晚上过后，海上平台的天气又变得更加恶劣了。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "天空被厚重的乌云笼罩，云层中不时还传来阵阵雷声，仿佛正酝酿着一场异常的风暴。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而位于平台中心的电梯井下，则传来了一阵阵低沉的异响。那声音像是某种巨大的机械在运转，又像是一头沉睡的钢铁巨兽在发出沉重的鼾声……每一次声响都伴随着平台微微颤动。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl003_02",
        "zh_CN": "看来敌人也开始行动了。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯，接下来，就是最终的对决了。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "妮塔紧张了吗？",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她立刻挺直了背，故作镇定地摆了摆手。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl003_03",
        "zh_CN": "才…才不紧张咧，我有什么好紧张的？",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我笑了笑，没有拆穿她，只是看着她故作镇定地往前走。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "然而，没走几步，她的脚步却慢了下来，声音也低了几分。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl003_04",
        "zh_CN": "好吧，老实说……确实有一点。",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这也是难免的，不过你这么想，迄今为止，我们不是已经出入过无数次险境了吗，这次不过是再多一次罢了。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl003_05",
        "zh_CN": "我明白分析员的意思啦……但有没有一种可能——",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "妮塔叹了一口气，转身看向我，她的脸颊微微泛红，眼神还有些躲闪。",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl003_06",
        "zh_CN": "其实……我每次都担心你担心得要死！",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那这次，就让我待在你身边好了。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "放心，我不会再让你一个人担心了。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl003_07",
        "zh_CN": "分析员……",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她抬起头，盯着我的眼睛，嘴角微微扬起，似乎因为我的话而放松了一些。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "无论是什么样的敌人，我们都一起面对。别忘了，妮塔可是我亲自挑选出的搭档，不是吗？",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl003_08",
        "zh_CN": "嗯，那我可得跟紧你了！",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她深吸一口气，尽管她的声音依旧带着一丝颤抖，但语气已恢复了以往的活力。",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "就这样，我将阴霾暂且抛在身后，跟妮塔并肩走向了电梯井的方向。",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 6,
        "Speaker": "异化人",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "——！",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 9,
        "Speaker": "妮塔",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl003_09",
        "zh_CN": "别挡道！",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "几经周折，我们总算是抵达了最后的电池储备点。",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl003_10",
        "zh_CN": "呵……不愧是深层区域，污染程度比上层严重了好多。",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl003_11",
        "zh_CN": "即便是穿着悸响，还是有种头晕目眩的感觉……分析员还好吗？",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我没问题。",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我点了点头，随后将电池装进了背包。",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "妮塔，我们现在可以撤离了。",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl003_12",
        "zh_CN": "那就好……对了分析员，有一件事我搞不明白。",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我顺着她的目光，看向了倒在一旁的异化人。",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你是指一路上我们遇到的敌人只有异化人吧？",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_girl003_13",
        "zh_CN": "对，明明昨天还有不少泰坦来着的。",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "确实，这可不是什么好事，敌人不可能无缘无故消失。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "难道说……它们被转移了吗？",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "突然间，我的脑海中浮想起那只被我和奈莉德合力击杀的新生泰坦。",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "如果只是一只泰坦被转移了，我姑且还会觉得是拥有特殊能力的大型泰坦所为。",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但想要一次性转移那么多只，能做到这一点的应该只有……",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 6,
        "Speaker": "信息化埃达",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_npc001_01",
        "zh_CN": "……被他察觉到了啊，呵呵呵，不愧是playername。",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "海底试验场内，信息态的埃达正坐在高高的操作台上，摆动着双腿。",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "通过监视器，她正盯着我们的一举一动。",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 6,
        "Speaker": "信息化埃达",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_npc001_02",
        "zh_CN": "但该说不说，还是晚了一步。",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 0,
        "Speaker": "巨大的机械装置",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "天花板上，巨大的球形装置发出了一阵嗡鸣声。",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 6,
        "Speaker": "信息化埃达",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_npc001_03",
        "zh_CN": "哎呀，你也已经想要醒过来了吧。",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 0,
        "Speaker": "巨大的机械装置",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 71,
        "Flag": "",
        "Pos": 6,
        "Speaker": "信息化埃达",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep6_npc001_04",
        "zh_CN": "先别着急，先别着急嘛。难得做了个美梦，再多睡一会儿也不是问题哦。",
        "disable": 0
    },
    {
        "Key": 72,
        "Flag": "",
        "Pos": 6,
        "Speaker": "信息化埃达",
