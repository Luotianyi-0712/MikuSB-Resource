        "Key": 16,
        "Flag": "",
        "Pos": 6,
        "Speaker": "奈莉德",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep1_girl021_04",
        "zh_CN": "生命没有重来的机会，别浪费在这种地方。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "卫城调查员A",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep1_diaochayuanA_03",
