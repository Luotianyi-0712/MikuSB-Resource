[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "几天后，心率实验结束，极限心率最终定格在了215bpm这个数字。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这个数字象征了许多，我们对彼此的了解比往日更甚，浓烈的爱意也终于传递到了对方心中。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但眼前的许多许多也只是两心交融过程中一个小小篇章。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我与妮塔还有很长的路要走，即使以生命为刻度来丈量这段旅程，也毫不夸张。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "得益于模组调试还需要一段时间，我和妮塔难得悠闲起来。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在她的计划中，此时的我们本该一起享受夜晚的微风、璀璨的星夜。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "妮塔？",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "出声呼唤后，我没得到任何的回应。因为身边人早就沉沉睡去，只传来平稳的呼吸声。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "真是的，明明拉我来看星星，居然自己睡着了。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "看着她脸上带着笑，我忍不住轻轻蹭了下她的鼻尖，没想到这么轻微的动作还是惊扰了她。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她的睫毛颤动了几下，如同蝴蝶翅膀般轻柔地扇动，随即缓缓睁开了双眼。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "唔……唔？我这是睡着了？",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "揉了揉惺忪的睡眼，她迷茫地看向四周。过了好一会，清醒的神色才重新浮上她的眸子。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哇！星星都出来这么多了，我这是睡了多久？",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "也没睡多久，好歹在太阳出来前醒了。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我哪有那么能睡！分析员尽乱说。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "带着几分埋怨，妮塔戳了戳我的手臂。我顺势捂住，装出一副疼得龇牙咧嘴的模样。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "啊……好疼，快帮我叫医疗部。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我就轻轻碰了一下，根本没用力啊。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你可是天启者，力道本来就和普通人不一样，嘶……痛死了。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "对、对不起，分析员，不然我给你揉揉好了。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "就在妮塔慌乱间从躺椅上站起，坐到我的身边开始揉捏“伤处”。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "趁此机会，我用手环住她的紧致的腰部，一把就将她捞进了怀里。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "两人就这么躺在了同一张椅子上，她的鼻尖贴着我的脖颈处，呼出的每一分热气，都似乎想钻进我的皮肤中。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "骗你的，我的手臂一点事情都没有。只是觉得这个姿势，更适合看星星。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "分析员，你真是坏透了！",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "妮塔佯装生气，挣扎了两下后就乖乖窝在我身侧。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "群星像洒在黑丝绒上的钻石，散发着纯粹的银色光芒。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "美中不足的是，月亮却被云层笼罩，只能看见淡淡的、模糊的一轮月色。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "或许是为夜空着迷，我们很久都没再说一句话，安静地享受着对方的体温。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "过了好一会，怀抱里才传来一句轻声呢喃。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "海上，也会有这么好看的星星吗？",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我低头看向妮塔，彼此的目光正好对上，无垠夜空的星星点点，此时都落在她的眸中。",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我也不知道，不过我们可以一起去探究这个问题的答案。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这两天……我心里根本静不下来。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一直想着，“悸响”加上模组后会是什么样？霍尔姆南部又是什么样？",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好希望时间过得快一点，再快一点！",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "妮塔在我怀中小幅度的左右乱动着。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "别乱动，有点痒。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在我的手臂稍稍收紧，将她安稳在怀中的那一刻，她的脸颊泛起红晕，眼中溢出满足的光芒。",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但她眼中的满足，连同那份对未来的期待，却勾起了萦绕在我心间的疑问。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "妮塔，虽然心率实验结束了，但我还是有个问题想问问你。",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "见我语气反常得严肃起来，妮塔立刻灵巧转身，轻盈地跨坐在我身上。",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "什么问题？",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你真的对眼下的一切，感到满足了吗？",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "听到我的问题，妮塔凑得离我更近，急切地点点头。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "当然，我觉得很满足，很幸福！",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我的手轻柔地抚过她的头发，指尖在发梢间游走，力度就星辰洒落微光一样轻。",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你说过你是个很贪心的人，贪心着我的一切。",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "或许因为我也是个不知收敛的人，所以我很明白这份心情。",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "对贪心的人来说，哪有“满足”一说呢，索要、占据、私有都会成为我们终身的命题。",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "妮塔怀有这种想法也是理所当然的……",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我没有继续说下去，而是将视线投向远方。",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "目光仿佛能穿透层层雾气，霍尔姆浮现在我眼前，海岸线之后的是浓重而未知的晦暗。",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不知何时，命运就会将我推入其中……",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "想再为妮塔做点什么，想让她再多拥有一些温暖，好对抗注定再度降临的遗憾。",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但她只是缓慢而坚定地摇了摇头，如同平静海面下的暗流，柔和却不失力量。",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "来海姆达尔之前，我过着没有食物、没有住处、没有钱……总之就是什么都没有的日子。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但是也算不上“一无所有”，因为我也有一样自己珍藏的宝贝。",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 6,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哈哈~分析员一定猜不到是什么，我就干脆点说出来好了。",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她重新躺回我的怀抱中，闭上眼睛，任由记忆慢慢涌上。",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 9,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "拾荒过活的那段时间，有个晚上，我发现即使没有路灯，也能看得很清楚。",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 9,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "抬头一望，原来是月亮啊。",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 9,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "月亮是很慷慨的，它没有问我是谁，有没有钱交换，配不配得上。",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 9,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "它只是很温柔地照亮了我，我走到哪里，光就跟到那里。",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 9,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我爱它，爱它多情地眷顾我，爱它愿意被我片刻拥有。",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 9,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而现在，我心里的月亮……就是分析员。",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 9,
        "Speaker": "妮塔病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我不会奢求更多，因为那样月亮就不是月亮了。一点点落在我身上的光就足够了，真的足够了。",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "无声的爱意在我们之间流转着，渐渐形成了风，将乌云吹散。",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一轮弯月就这么显现于我们眼前，借助朦胧柔和的月光，我才看清妮塔眼中的莹莹水色。",
        "disable": 0
    },
    {
        "Key": 71,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "小心蹭过她的眼角，湿润的感觉停留在我的指尖。",
        "disable": 0
    },
    {
        "Key": 72,
