        "Key": 80,
        "Flag": "",
        "Pos": 9,
        "Speaker": "优格",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc16ep10_npc084_16",
        "zh_CN": "我对他的感情，已经成为了我有别于你的证明。",
        "disable": 0
