[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "空间开始碎裂、坍塌，骤起的风暴席卷了里芙的心流内景，一幕幕画面自我的眼前快速闪过——",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "耶洛沙、阿尔斯特、帕特拉……不仅仅是在零区，短时间内全世界各地区都出现了“树”，泰坦污染加剧。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "人们称呼这场事件为——<speed=0.15> </><speed=0.4>芬布尔之冬</>。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在这漫长的季节里，海姆达尔部队经历了一场又一场与泰坦间的激烈战斗。胜利由伤口和牺牲堆砌。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "人们敬佩她们，人们同样也畏惧她们。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "队员们接二连三地出现了神格侵蚀的现象。终于有一日，被神格取代人格的少女，制造了不亚于泰坦的灾难——海姆达尔部队一时之间被推到了舆论的风口浪尖之上。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "其中争议最大的，就是那位有着赫赫战功，手段酷烈的“首席”里芙·贝斯特拉。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "里芙内心仇恨的怒火从没有被熄灭，而是越燃越烈，始终灼烧着她……",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 4,
        "Speaker": "罗赞",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "还是这么能干，真不愧是“首席”里芙·贝斯特拉。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 5,
        "Speaker": "奥丁无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不要再叫我那个名字，我已经将它献祭给了自己。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 4,
        "Speaker": "罗赞",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好吧，真神者“奥丁”，别光只顾着和泰坦玩游戏，还有更刺激的在等着你。",
        "disable": 0
    },
    {
        "Key": "b-1",
        "Flag": "b-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "b-1-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不，我的里芙也不在这里",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "里芙的心流内景又发生了变化，一阵白光过后，眼前出现一条长得仿佛没有尽头的走廊，这是……心流园？",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我再次看到了里芙的背影，毫不犹豫地追上前。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "和现实世界里发生过的情况不同。这一次，我追随着她踏进了那扇通往治疗舱的门。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "纯白的世界仿佛有着永恒的宁静。这里既没有风暴，也没有闪电。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "接着我看到了里芙，以及一团与她有着同样容貌，同样轮廓的阴影。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是你们？",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我原本以为心流内景里残留着奥丁的神格，这段时间持续对我施加影响，让我看到这些景象。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但神格已被我驯服，你们不是奥丁。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 6,
        "Speaker": "恒沙",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "里芙·贝斯特拉女士，请问您……是否……正视过自己。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "当我开始在心流内景中正视自己的时候，我回顾了我过往的人生。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "就好像在照镜子的时候，眼中映出镜像的我，镜像的我眼中又是另一个我……",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你们是过往某个瞬间、某种可能性下诞生的无限的我自己。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你是从没参加过瓦尔基里游戏，但遭遇了亲人死于降临事件的里芙。你决定学医，以医生的身份加入世界树，遇到了playername。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你是没有获得过天启，始终只是个普通人的里芙。降临事件后，你一心往上爬，最终成为了世界树的新董事，动用所有手腕和力量守护着playername。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "还有你……没有从回收舱接到playername，人生目标只剩向泰坦复仇，最后被彻底神格侵蚀的里芙……",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你们有着各种我所羡慕、憎恶的人生，让我看到了无限可能。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但你们不是我。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不是那个与他相互救赎的我。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "还有，你们感受到了吗？",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "少女的视线穿过阴影，与我相望。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是我的playername，他来接我了。",
        "disable": 0
    },
