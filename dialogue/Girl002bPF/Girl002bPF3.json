        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那是你的新能力吗？可以在心流内景看到无限的过去和未来？",
