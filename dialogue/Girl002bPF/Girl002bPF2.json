        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "高速传递的电信号将里芙的神经系统“点亮”，如一棵繁茂而绚丽的“树”。我的视线无法从眼前的影像上挪开，内心涌上某种难以明说的情绪。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
