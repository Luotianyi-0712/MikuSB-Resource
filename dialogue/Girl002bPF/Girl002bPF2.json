        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "与其说消失，不如说里芙自己的神经系统已经完成了某种进化，成为了新的更强大的神格神经。",
        "disable": 0
