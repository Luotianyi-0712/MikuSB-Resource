    {
        "Key": 78,
        "Flag": "",
        "Pos": 5,
        "Speaker": "导演",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我们是战地记者，专门在动荡的前线采访最真实的信息，不管是之前的耶洛沙还是现在的新恒提罗。",
