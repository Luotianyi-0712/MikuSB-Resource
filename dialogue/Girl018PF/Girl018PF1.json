    {
        "Key": 77,
        "Flag": "",
        "Pos": 5,
        "Speaker": "导演",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "去去去，你们先走远点，别打扰我的采访对象。",
