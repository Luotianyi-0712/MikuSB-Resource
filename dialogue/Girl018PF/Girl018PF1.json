        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 6,
        "Speaker": "龙舌兰1",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "要是在两个人独处时分析员喝醉了，能照顾他的就只有……",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "想到一些绝妙的画面，少女霞飞双颊，动人的双眼逐渐被莹润的雾气浸染，可就在她忍不住想抬起双手捧住自己的脸颊时——",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
