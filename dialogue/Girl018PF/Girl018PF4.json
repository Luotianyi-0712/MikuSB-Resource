    {
        "Key": 472.0,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "带着这份好似从分析员体内传递而来的力量，龙舌兰堵住了大厦唯一的出口。",
        "disable": 0
    },
