        "Flag": "",
        "Pos": 5,
        "Speaker": "龙舌兰1",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你做这种事情，不觉得可耻吗？",
        "disable": 0
    },
    {
