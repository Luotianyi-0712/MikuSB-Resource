        "Key": 170,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……晴？",
        "disable": 0
    },
    {
        "Key": 171,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没有人回答我。",
        "disable": 0
    },
    {
        "Key": 172,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "目光顺着门缝望进去，曲线姣好的女孩正手持剑柄，面对着冰冷的模拟战斗系统，身姿不动如山。",
        "disable": 0
    },
    {
        "Key": 173,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而下一秒，她拔剑了。",
