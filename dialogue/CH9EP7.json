    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "幸好姬辰星指挥安全部干员提前启动了隔离墙内的信号阻断装置。",
        "disable": 0
