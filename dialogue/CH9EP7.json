    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她采取了近乎疯狂的、玉石俱焚的行为，自己还未飞出爆炸的波及范围，就已经发出了引爆信号。",
        "disable": 0
