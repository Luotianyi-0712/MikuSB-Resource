        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "有没有不舒服的地方？如果没有问题，就眨两下眼睛。",
        "disable": 0
