    {
        "Key": 111,
        "Flag": "",
        "Pos": 6,
        "Speaker": "加文",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你不需要知道这些，你只需要知道我们即将离开，很快，你们将再也找不到我们的踪迹，这里所有的一切都归你们世界树——",
        "disable": 0
    },
    {
        "Key": 112,
        "Flag": "",
        "Pos": 0,
        "Speaker": "莫尔索",
        "RealSpeaker": "",
        "WwiseEventID": "",
