    },
    {
        "Key": 76,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "昏暗的房间中，坐在沙发上的男人冷脸，而在他面前不远处，摆着一张冰冷的椅子。",
        "disable": 0
    },
    {
        "Key": 77,
        "Flag": "",
        "Pos": 0,
        "Speaker": "加文",
