        "disable": 0
    },
    {
        "Key": 130,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "真卑鄙啊……无论是他，还是我。",
        "disable": 0
