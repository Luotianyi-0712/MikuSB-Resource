        "Flag": "",
        "Pos": 6,
        "Speaker": "安全部干员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "两位长官打扰了，精神治疗室刚刚发生了爆炸，有大量泰坦物质残留……",
        "disable": 0
