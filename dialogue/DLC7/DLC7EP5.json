    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "突发情况打断了会议，在安全部干员的带领下，我们火速赶往了事发地点。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 6,
        "Speaker": "安全部干员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "长官，爆炸现场并未发现人员伤亡，但是也……",
