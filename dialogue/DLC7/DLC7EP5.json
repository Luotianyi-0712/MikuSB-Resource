    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "走进一片漆黑的精神治疗室，我观察起四周。",
