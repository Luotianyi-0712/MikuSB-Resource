[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 6,
        "Speaker": "净化官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不要逃避。<snowbreak>接引使</>大人，将她们渡送至彼岸吧。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "奄奄一息的女孩",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "请……请为我们赐福吧，接引使大人。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "圣坛之上，琴诺面前的女孩们浑身长满结晶，瘫倒在地。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 3,
        "Speaker": "净化官",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "只有由您亲手赐福，她们的灵魂才能抵达净土……来吧，将权杖刺入她们的心脏，为她们解脱。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "琴诺",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我做不到……我做不到的……",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "萨特",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "啧，真弱……",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "琴诺",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "都是我的错……大主，我没有办法成为接引使……请原谅她们吧！",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 2,
        "Speaker": "凯郭尔",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是啊，都是你的错。但是琴诺你知道吗？",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "身着长袍的大主绕过人群，来到一脸惊慌的琴诺面前，在众人诧异的目光中弯下腰来。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯郭尔",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "自降生于世后，人便会与越来越多的人事物产生联系。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯郭尔",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你要记住，你所做的每个选择，都会波及到那些和你联系在一起的人。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯郭尔",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "如果你没有那个觉悟，那他们即便身死，灵魂也终不得解脱，将会成为游荡在世间的……",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "琴诺",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我知道了，大主，我知道了，但这次就饶了她们吧……求求您了……",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯郭尔",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "善良的孩子，这并不是我能左右的事，罪已降下，这理应由神明裁决。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯郭尔",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但是，此时此刻，若你能给予罪人赐福，那么便能获得祂的宽恕。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "男人打了个响指，立马就有侍女上前用白布缠住了琴诺的眼耳。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "凯郭尔",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "什么都不要去看，什么都不要去听……仅仅是听从你的内心，为他们赐福吧。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "于是，女孩颤颤巍巍地举起了手中的权杖。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但是，她始终没有勇气将其落下。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "直至——",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "凯郭尔",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "很遗憾，罪人们的灵魂将永远囚禁于此。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "身后的女人打断了她，松开了白布。",
        "disable": 0
