    {
        "Key": 84,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米娅星彩",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那……我就不再是高中生米娅，而是成为大人了，对嘛？",
        "disable": 0
    },
    {
        "Key": 85,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她的声音轻飘飘的，有那么些不真实。",
        "disable": 0
    },
    {
        "Key": 86,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你是觉得成为大人不好吗？",
        "disable": 0
    },
    {
        "Key": 87,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米娅星彩",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "倒也没觉得不好啦，只是心里好像有一点空空的感觉……",
