    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "可对于那个高中时代的结局，少女觉得自己还没有准备好去面对。",
        "disable": 0
