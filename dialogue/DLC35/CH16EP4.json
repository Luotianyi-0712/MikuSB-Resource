        "Flag": "",
        "Pos": 6,
        "Speaker": "玛德琳",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc35ep4_madelin_04",
        "zh_CN": "简单说来就是……今天的宾客数量不太对，我的意思是少了很多。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 6,
        "Speaker": "茉莉安幽潮",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc35ep4_girl005_02",
