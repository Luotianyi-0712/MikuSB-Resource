        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员白西装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯？",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 6,
        "Speaker": "玛德琳",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc35ep4_madelin_02",
