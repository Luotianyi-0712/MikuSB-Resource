        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "玛德琳刻意压低了声音，眼神不断在周围的宾客身上扫过，眸中满是警惕。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员白西装",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "奇怪的情况？",
        "disable": 0
