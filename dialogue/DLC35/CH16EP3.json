        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "和安卡希雅的亲昵结束后，轻轻的敲门声也正好响起。",
        "disable": 0
    },
    {
        "Key": 97,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "咚、咚、咚。",
        "disable": 0
    },
    {
        "Key": 98,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
