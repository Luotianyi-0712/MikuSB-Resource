        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这熟悉的歌声……一定是苏菲对她做了什么。",
        "disable": 0
