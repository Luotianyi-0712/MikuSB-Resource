        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你们把瑟茜带到安全的地方，然后去帮忙疏散民众，尽可能把她们带往高处。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 6,
        "Speaker": "大安卡希雅",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc35ep10_girl001_02",
