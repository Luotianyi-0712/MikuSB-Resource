    },
    {
        "Key": 80,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "只有两人独处的世界，亲密无间的那种滋味。",
