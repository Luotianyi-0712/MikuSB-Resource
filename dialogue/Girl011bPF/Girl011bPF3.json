[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "恩雅·墨尔菲。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是从小在蜜罐子里长大的女孩。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "从家庭到人生都是无可挑剔的完美。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她从来不缺少爱，也从来不缺少幸福。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "感受过这些温暖的恩雅觉得自己有必要让其他更需要幸福的人也收获幸福，方法便是提供力所能及的帮助。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "小到帮助老奶奶过马路，帮助迷路的小孩找到父母。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "大到用自己攒的钱成立慈善医疗基金救助弱小，作为天启者对抗险恶。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "路人",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "如果这个世界真的有天使，那她的名字一定是恩雅·墨尔菲。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "类似这样的话，已经太多次出现在她的耳中。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "虽然她自己从来不这么认为。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "只是觉得自己在做该做的事情，也从来没有想过要求任何的回报。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她也一直觉得自己对世界上的任何事物都无欲无求。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "可在与他相遇，相识，相爱后，她发现自己过往的认知是错误的。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 4,
        "Speaker": "恩雅澜风",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "想要拥有他。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要想要",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "拥有",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "占有",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "如果可以只属于我。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "第一次，这种不该属于她的想法，仿佛藤蔓一样在心底疯狂滋长。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而最让恩雅感到恐惧的是……",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她其实拥有达成自己欲望的一切能力。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "无论是手段，计谋，力量。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "甚至于……她还可以凭借过去好心积累的一切，去寻求她达成目的所需要的回报。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在认识到这一点的时候，感觉到毛骨悚然的恩雅也意识到一件事——",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她从来都不是天使。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她是一个危险的女人。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "就如同她拥有的神格——库库尔坎。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "羽蛇神。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "美丽鳞片与羽毛包裹的曼妙蛇躯，远看美艳不可方物，可内在藏着属于神灵的权柄。这份权柄可以随心所欲降下雷霆与恩泽，夺取一切的美好。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "可在悚然之后，恩雅并未退避，而是选择坦然接受这样的自己。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "因为……这就是恩雅·墨尔菲，即便这是「不足」。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而且——",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她并不会被这份欲望吞噬。",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "因为，这也是恩雅·墨尔菲，独属于她的「强大」。",
        "disable": 0
    },
