        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她仔细地嗅闻了手中的沙子，随后将它们吹散，重新直起腰来。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 6,
        "Speaker": "肴冬至",
        "RealSpeaker": "",
        "WwiseEventID": "",
