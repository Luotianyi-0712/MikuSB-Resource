    {
        "Key": 115,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她一边小声嘟囔着，一边捏合着手指，让沙盘图原地转了个角度。",
