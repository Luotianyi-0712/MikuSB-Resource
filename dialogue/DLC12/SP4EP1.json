    },
    {
        "Key": 124,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "前安全部的成员，海姆达尔的预备役，还有一些可以信任的编外人士……你不用担心她们的忠诚。",
        "disable": 0
    },
    {
