    },
    {
        "Key": 87,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哈……？",
        "disable": 0
    },
    {
        "Key": 88,
        "Flag": "",
        "Pos": 4,
        "Speaker": "芬妮辉耀",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哈哈，懂了懂了！",
        "disable": 0
    },
    {
        "Key": 89,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她不再停留，快步穿过长直的走廊，身影消失在了尽头的转角。",
        "disable": 0
    },
    {
        "Key": 90,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我说，在场的诸位有没有谁跟我一样，到现在都还搞不清楚状况的？",
