    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "卜卜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "像训练的时候那样……像那位分析员大人一样去思考！",
