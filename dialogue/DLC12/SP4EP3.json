        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她催促着同伴，连拉带扯地将对方拽着走远了。",
        "disable": 0
