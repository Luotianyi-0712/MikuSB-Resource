        "Key": 30,
        "Flag": "",
        "Pos": 5,
        "Speaker": "直率的流民",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你能想到更好的办法吗？",
        "disable": 0
    },
