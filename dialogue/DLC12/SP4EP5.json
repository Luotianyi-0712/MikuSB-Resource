        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她深吸了一口气，抓起我的手，把我带到了水塘边倒塌残破的一处石像旁。",
        "disable": 0
