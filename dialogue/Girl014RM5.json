[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "第一缕天光从窗外透来时，辰星便睁开了她的眼睛。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "昨晚凌乱的声色带着滚烫的温度闪过脑海，可很快被她主动隐去。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她枕着手臂，就趴在分析员的身边，静静凝视着他熟睡的面庞。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "无需在记忆中贪恋那些美好，她今生所有的幸福就在现实的眼前。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "手掌轻轻抚摸着分析员的脸颊，忽然之间，一双明亮的眼睛睁开了。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "怎么不多睡会。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我抓住少女触碰我脸颊的手，放在嘴边轻轻咬了一口。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "昨夜我完成了与辰星的恒约，一整个白天，我们都不曾停歇，招待姬家的宾客，按照彩排的预演，完美完成了每一个环节。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在后半夜，我和辰星更是累得够呛。我以为这一觉能睡到日上三竿。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是做了不好的梦吗？",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我伸手捏了捏她柔嫩的脸。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她摇了摇头，露出浅浅的笑，将脸颊主动贴在我的掌心。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "应该说，做了很好的梦，和郎君有关的梦……",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我梦到了过去……梦到了最初认识郎君的那段时光。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那个时候就迷上我了吗？",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星病号服",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "因为……郎君忽然就住进了我的心里啊。您是打破了牢笼，将我拽出来的人，也是说过……要给我创造更多美好的人。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她脸上染着桃花般的粉色，眼中满是莹润的水光。望着少女这般娇艳的模样，我又怎么能忍住不向她传达我的爱意。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "与辰星温存了一会，我们才慢吞吞从床上爬起。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她帮着我穿好了衣服，自己也换上了外出的衣服后，又将手轻轻递到我的面前。",
        "disable": 0
    },
    {
        "Key": "b-1",
        "Flag": "b-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "b-1-1",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "抓住她的手",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "今天，有什么想去的地方吗？",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "恒约后的这天，是独属于我和辰星的时光。我们可以选择在家悠闲地度过一整天，也可以去一些特别的地方。",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而在我脑中，对于接下来要做什么，已经有了答案。",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "有！",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "听着辰星不假思索的答复，我便明白我们想到了一块。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "要一起拿出来吗？",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我们对视一眼，然后……一齐取出了一张大头贴。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "双人合影的大头贴，我和辰星都各有一张，不过在大头贴的背面都有“恒约留影兑换券（1/2）”的文字，两张一齐取出来，才算是完整的兑换券。",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "郎君……果然记得。",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "用心记住的东西……就算没有特殊的能力，一样是永恒的。",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她的眸光闪闪发亮。",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她紧紧将我递过去的大头贴抓在手心里，忽然又踮了踮脚，拉住我的衣角，向我怀里凑近几步。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "郎君，可以背我过去吗？",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯，这是我答应的事啊。",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我在她的身前转过身去，微微蹲下。",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "也是我和郎君的默契。",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "辰星很自然地扑在了我的背后，双手环住了我的脖子。",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "还想打伞吗？",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我双手自然托住她的腿弯，缓缓起身。",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 9,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "可是外面没有下雨。",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不是得下雨才要打伞，外面太阳也挺大的。",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 9,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯。",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我和辰星说着话，就背着她走出了公司。",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "少女的体态和轻盈，轻柔地压在我的身上，可对我而言，这份重量举足轻重——这是我需要用尽一生去支撑的重量。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在街边我们偶遇了卖冰淇淋的车。在辰星开口之前，我便背着她来到了冰淇淋的窗口前。",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 0,
        "Speaker": "冰淇淋店长",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "买冰淇淋是吧？你们要几支？",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "两……",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一支。",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "郎君，我只想要一支。",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我想试试……另一种吃法。",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我笑着看了她一眼。",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "店长，我们要两支的量，但是做成一支。",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "只是一支，可不够我和辰星吃的。",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "微风吹过，我和辰星继续向着目的地走去。",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在我的眼前，是湛蓝的天空，",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在我的鼻尖，萦绕少女发丝的香味，",
        "disable": 0
    },
    {
        "Key": 71,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在我的耳边，是她活泼又动人的呼吸，",
        "disable": 0
    },
    {
        "Key": 72,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在我的口腔里，满是幸福滋味的香甜，",
        "disable": 0
    },
    {
        "Key": 73,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "与我灵魂交织在一起的，是缠绵的誓言。",
