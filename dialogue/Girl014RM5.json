        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……能够被承载一生的感觉，真好。",
        "disable": 0
    },
    {
        "Key": 88,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "什么？",
        "disable": 0
    },
    {
        "Key": 89,
        "Flag": "",
        "Pos": 6,
