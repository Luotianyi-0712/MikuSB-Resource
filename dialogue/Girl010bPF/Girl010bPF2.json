    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没有理会身后的议论声，少女早已开始闭目养神。",
