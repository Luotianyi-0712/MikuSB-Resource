        "Key": 26,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep10_npc003_06",
        "zh_CN": "我答应你。答应你的就会做到。",
        "disable": 0
