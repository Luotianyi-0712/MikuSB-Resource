[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在矜持与热情之中，总算偷得一段余暇。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "走廊的尽头是一道阳台，阳台下面又是一片露台，上面种着些花草。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在花与月亮之间，一个人影立在露台的边缘。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……克罗瑞娜？",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "人影晃了晃，转过身来。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 9,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_01",
        "zh_CN": "……分析员先生。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "里面有点闷，所以想出来透透气。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "怎么，你也一样？",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 9,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_02",
        "zh_CN": "……长辈们的兴趣广泛，我涉猎不多，留着反而让大家不自在。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯……是。太热闹了。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这里风景真好。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 9,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_03",
        "zh_CN": "您喜欢就好，小姨公务繁忙，有什么需要请随时跟我讲。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不用那么麻烦，我本来就是个随便的人。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 9,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_04",
        "zh_CN": "客人的风度可不是招待不周的理由。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 9,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_05",
        "zh_CN": "您想下来看看吗？",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "行啊。嗯……我想说的是，要怎么下去？",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "栏杆齐腰。也不知道她是怎么下去的。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 9,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_06",
        "zh_CN": "请站到那上边。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她走到墙边，指着栏杆外一处藤蔓结成的网。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 9,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_07",
        "zh_CN": "放心，不会有危险的。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我这才发现，栏杆靠墙的部分有几阶台阶。顺着台阶走到栏杆边的藤蔓网上——藤蔓粗壮有力，我站得很稳当。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她拿出一支手电筒，在藤蔓上扫着。被扫过的藤蔓慢慢放软，我便落在了克罗瑞娜所处的露台。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "真神奇……某种光合作用？",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_08",
        "zh_CN": "基因编辑的结果，一种遗传学的应用。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_09",
        "zh_CN": "从实验风险来看，植物比动物更可控，也有足够的发掘空间。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那白天怎么办？不都落在地上了吗？",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_10",
        "zh_CN": "白天……",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她看向墙边，那里有一排台阶，从露台直通刚刚看到的栏杆——只是被藤蔓盖住了。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "所以藤蔓的作用是……？",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_11",
        "zh_CN": "晚上黑，台阶容易踩空。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你不是有手电筒吗？",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_12",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "少女尴尬地抬起头看着月亮。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哎，是我唐突了。手电筒可没有月光浪漫。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好的设计当然是要兼顾实用性和审美的。",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_13",
        "zh_CN": "您也懂设计吗？",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "谈不上。但身边有一些很有格调的人，耳濡目染吧。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_14",
        "zh_CN": "您请坐这儿。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "露台的边缘垫着坐垫，还放着一个匣子。",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我在一个坐垫上盘腿坐下。她打开匣子，最上面摆着一只茶壶，壶嘴儿还冒着雾气。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "下面的抽屉里则放着几碟点心，她一一取出，在我们之间摆好。",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "两盏小巧的瓷杯，蒙着彩釉。她拈起茶壶，琥珀色的茶汤注进瓷杯里，香气在晚风中格外清晰。",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_15",
        "zh_CN": "请用。",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "谢谢。",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "夜空如洗，茶香如瀑。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一旁的克罗瑞娜小口品着茶，一样仰望着夜空。",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯……",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "真好啊。",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "偏头看她——她沉默地注视着星空。察觉到我的视线后，又拾起了微笑的样子，帮我倒上茶。",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "还是不打扰你了。",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_16",
        "zh_CN": "诶？",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这里应该算是那种“秘密基地”吧？",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "长辈管不到，别人也不知道。没有人会打扰的、安全又神秘的小空间。",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_17",
        "zh_CN": "哪里的话……",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 6,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她有点难以应对我的直白。",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我就先回去了。今晚多谢款待。",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_19",
        "zh_CN": "您……可以再陪我一会儿吗？",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那你可不能再用敬语了。",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_20",
        "zh_CN": "嗯……仅限小姨不在的时候？",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一言为定。",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她终于露出了不一样的微笑——情绪的自然流露，而不是训练有素的礼节。",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_21",
        "zh_CN": "您……你，不太像小姨的朋友。",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "确实很少接触这个圈子，但也有过这样的朋友。",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "有的人如鱼得水，有的人如履薄冰。",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_22",
        "zh_CN": "有过？……是因为圈子不同，渐渐疏远了吗？",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她死在耶洛沙了。",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_23",
        "zh_CN": "啊……抱歉。",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "所以还挺亲切的。虽然对这种氛围并不感冒，但因为这个想起她了。",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "别人把她当领袖，当旗帜，当英雄。谁知道呢，那个位置上的人不能有自己的想法。",
        "disable": 0
    },
    {
        "Key": 71,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_24",
        "zh_CN": "……奥尔洛娃女公爵。我听过她的故事。",
        "disable": 0
    },
    {
        "Key": 72,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep2_girl022_25",
        "zh_CN": "对她来说，死亡也许是种解脱吧。",
        "disable": 0
    },
    {
        "Key": 73,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "但无论如何不能放弃。不是吗？",
        "disable": 0
    },
    {
        "Key": 74,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她怔了怔，看着我颇有意味的眼神，突然笑了出来。",
        "disable": 0
    },
    {
        "Key": 75,
