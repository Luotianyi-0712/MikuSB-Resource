    {
        "Key": 125,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep7_girl022_17",
        "zh_CN": "我不想死。谁都一样。不能接受也没有办法。",
