        "disable": 0
    },
    {
        "Key": 73,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "冲动的话咽了回去。",
        "disable": 0
    },
    {
        "Key": 74,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "克罗瑞娜。",
        "disable": 0
    },
    {
        "Key": 75,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "如果有一天，你发现过去那样的生活让你厌倦了，就打我的电话。",
        "disable": 0
    },
    {
        "Key": 76,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "无论你是想改变，还是说——只是想让我陪着你去露台上坐一会儿。",
