    },
    {
        "Key": 118,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "“如果你能听得到。”",
        "disable": 0
    },
    {
        "Key": 119,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "少女看着窗外。许久，她低下头，在照片背后写下这行字。",
        "disable": 0
    },
    {
        "Key": 120,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "翻到日记本的第一页。这是唯一一件一直随身携带的东西。",
        "disable": 0
    },
    {
        "Key": 121,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep7_girl022_13",
        "zh_CN": "星期一",
        "disable": 0
    },
    {
        "Key": 122,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep7_girl022_14",
        "zh_CN": "我的病不太乐观，小姨很着急。",
        "disable": 0
    },
    {
        "Key": 123,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep7_girl022_15",
        "zh_CN": "这是最令我难过的地方。",
        "disable": 0
    },
    {
        "Key": 124,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep7_girl022_16",
        "zh_CN": "小姨好像比我更难接受这个结果，一副天要塌下来的样子。",
