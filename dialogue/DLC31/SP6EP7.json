        "Key": 142,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep7_girl022_34",
        "zh_CN": "网上查了一下，说是恋爱了。",
        "disable": 0
    },
