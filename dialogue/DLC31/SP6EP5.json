[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在这座荒岛上的废弃小镇里，我们终于找到了一个还算合适的住处。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "短时间内爆发的力量需要好好休息才能恢复。但在休息之前，我必须安置好这个藏身处。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "通讯仍然无法恢复，电子仪器依旧是周期性的失灵断电。电子干扰的范围衰减很大，在不同位置会有不同的干扰强度。可我这一路上却几乎没有感受到干扰强度的变化。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在霍尔姆到菲洛索亚的航线上竟然有这么一处海岛，也不知道陶找到我要花多久。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "（只希望她们找来的时候谨慎一些……）",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "天色渐暗，我必须做好过夜的安排。岛上的那些机器人还不知道属于什么势力，看样子会无差别攻击任何靠近的人。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "收集了一些木质的家具，准备用来生一堆火。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_01",
        "zh_CN": "有什么我能帮得上的？",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "帮我把这些拆掉吧。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她照我安排的，像撕纸一样拆掉了桌子。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_02",
        "zh_CN": "啊……这么轻松吗？",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "毕竟也是天启者了。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在通风的地方生了火，找了个三面靠墙的地方支了张简单的床。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "今晚只能凑合一下了。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "怎么样，不害怕吗？",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_03",
        "zh_CN": "害怕。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……没看出来。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她笑了笑，没有接话。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这里有些应急的食物和水，饿的话就先吃。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "可能不太合你的口味，但没办法，要补充体力。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "克罗瑞娜点了点头。没等我说完，她就自己撕开了压缩饼干的包装，咬了一小口。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我得先睡一会儿，刚刚的消耗有点大。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "你就待在我身边，如果有意外，随时叫醒我。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_04",
        "zh_CN": "？！",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_05",
        "zh_CN": "你受伤了吗？",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没有。之前遭遇风暴的时候消耗有点大。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_06",
        "zh_CN": "我、我该怎么帮你？",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没事，放心，只是睡一觉而已。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_07",
        "zh_CN": "不，别……别丢下我……",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我不会丢下你的。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哪里也不要去，就在我身边待着。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她一副紧张的样子，我只好换了个话题。",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "对你来说，这也算是一种新奇的体验？《荒岛求生》看过吧？",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "想逗她笑，她却没有笑。不说话，抓着我的手，泪汪汪的。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没事的，我只是有点脱力了。睡一觉就会好的。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "压缩饼干味道怎么样？这算是最紧急的时候才会吃的东西。",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "其实世界树的外勤补给还是很不错的，等她们来接的时候就能吃到。",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "说着说着，我再也撑不住困意，闭上了眼睛。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我先睡一会儿。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "相识的一句话。",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好像是她记住的一句话。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "？？？",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_Vernet_01",
        "zh_CN": "我的克罗瑞娜……",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 0,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_08",
        "zh_CN": "妈~妈!",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 0,
        "Speaker": "？？？",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_Vernet_02",
        "zh_CN": "没事的，妈妈只是睡一会儿。",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 0,
        "Speaker": "？？？",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_Vernet_03",
        "zh_CN": "米拉……克罗瑞娜就交给你了。",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那时候她才刚学会叫妈妈——那个年纪的孩子明明什么都不记得，但她却记得住那一句话。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这便是缘由。在playername说出那句话的时候，她只觉得自己要失去什么了。",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "只觉得压缩饼干很干、很噎、很涩。",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "想问他，偏偏咽不下去，说不出话。想吐掉，可是playername刚刚说了要补充体力。",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她拧开水瓶把嘴里的东西顺了下去。",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_09",
        "zh_CN": "醒醒，不能睡——",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她急得轻轻拍了拍playername的脸，入手却是一片滚烫。",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_10",
        "zh_CN": "这是病了吗？发烧了吗？",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "用手背贴着playername的额头，烫得几乎放不住。",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_11",
        "zh_CN": "（我得做点儿什么……）",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她想起视频里看到的，把毛巾打湿放在额头上降温。但这里没有毛巾。",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她想了想，比了比自己的衣角，扯下一圈来，用瓶子里剩下的水打湿，贴在playername的头上。",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没一会儿，布条就蒸干了。她握着playername的手，掌心也烫得厉害。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她找了些看上去会很凉的东西——石头、罐子什么的，都没什么效果。playername的手烫得连洒上水都会蒸干。",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她只好用playername的手握着自己，等烫得受不了了就往上挪一挪，一直到手臂、到另一只手……",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_12",
        "zh_CN": "（这样下去不是办法……）",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 0,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_13",
        "zh_CN": "（我该怎么办啊？）",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 0,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_14",
        "zh_CN": "（求求你，好起来……）",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她从来不相信有神明这样的东西。但这一刻，她只希望自己以往所有有关于此的坚定都是错误的。",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 0,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_15",
        "zh_CN": "如果有神明的话，求求你，让他好起来吧……",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 0,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_16",
        "zh_CN": "我什么都愿意做，只要能让他好起来……",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "只有火堆的噼啪声——当然不会有谁回应她。",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这点幻想自然而然地破灭了。她意识到，如果她想得到什么，就必须要做点什么了。",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她俯下身，吻了吻playername的嘴角。那里有一层血痂，是她在坠落时留下的痕迹。",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "从手术以后，她的身体就变得奇怪了——她迷恋上了playername的味道。而每当她品尝到playername的血液之后，就会浑身都充满力量。",
        "disable": 0
    },
    {
        "Key": 71,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "playername的嘴唇因为高温变得干而硬。他的气息又烫又热，让她又有咬上一口的欲望。",
        "disable": 0
    },
    {
        "Key": 72,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她克制住了这种欲望——playername还病着。而从刚刚的吻里，她也得到了一部分力量。",
        "disable": 0
    },
    {
        "Key": 73,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她站了起来，往夜里走去。",
        "disable": 0
    },
    {
        "Key": 74,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这是一件不在日程表，也不在计划中的事，也是和playername相处的这些日子中，她不知不觉学会的事。",
        "disable": 0
    },
    {
        "Key": 75,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "——做些想做的事。",
        "disable": 0
    },
    {
        "Key": 76,
        "Flag": "",
        "Pos": 9,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_17",
        "zh_CN": "克罗瑞娜……你可以的……",
        "disable": 0
    },
    {
        "Key": 77,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她喃喃自语着。环境暗了下来，只是走出她和playername藏身的地点，肾上腺素就开始分泌了。她只觉得血从胸口顶着脖子，手也抑制不住地颤抖。",
        "disable": 0
    },
    {
        "Key": 78,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "黑夜变得亲近了。她的眼睛很快就适应了夜的黑暗，任何一点儿光线都逃不过她的眼睛。",
        "disable": 0
    },
    {
        "Key": 79,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她渐渐没那么怕了，取而代之的是兴奋和勇气。燃油不充分燃烧的味道还未散去，在夜里格外明显。长着铁锈的机器人遵循着某种路线巡查着，也被她悄无声息地穿越过去。",
        "disable": 0
    },
    {
        "Key": 80,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她找到了飞机的残骸。驾驶室几乎完好无损，世界树公司似乎为驾驶室设计了特殊的保护措施。",
        "disable": 0
    },
    {
        "Key": 81,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在座椅的下面，她找到了应急道具箱。里面有刀具、枪械、食物和药品。",
        "disable": 0
    },
    {
        "Key": 82,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "已经成功一半了。只需要把这些都带回藏身处就好了。她装上食物和药，往回走去。",
        "disable": 0
    },
    {
        "Key": 83,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一股熟悉的味道钻进了她的鼻子——从她踏上这个荒岛开始，这种味道就一直若有若无的。",
        "disable": 0
    },
    {
        "Key": 84,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_18",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 85,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她一边走，一边下意识回忆。",
        "disable": 0
    },
    {
        "Key": 86,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "似乎是夜晚的味道。",
        "disable": 0
    },
    {
        "Key": 87,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "循着气味走去，鞋子踩在了某种植物的藤蔓上。手扶着墙体，枝叶的触感也令她感到熟悉。",
        "disable": 0
    },
    {
        "Key": 88,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "拨开树叶，褪色的围墙上依稀能看得清一个符号——",
        "disable": 0
    },
    {
        "Key": 89,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那是<snowbreak>吉诺拉生物公司</>的标志。",
        "disable": 0
    },
    {
        "Key": 90,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_19",
        "zh_CN": "……？！",
        "disable": 0
    },
    {
        "Key": 91,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她猛地想起，那种熟悉的味道正来自于四周随处可见的植物。",
        "disable": 0
    },
    {
        "Key": 92,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那是她亲手种在阳台的、经过吉诺拉生物公司的实验室创造出的独一无二的植物。顺着藤蔓，她下意识看向天空——",
        "disable": 0
    },
    {
        "Key": 93,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "白天还能看见的那座水塔，此时正被藤蔓重重缠裹着。猩红色的花开上了天，像一棵参天巨树。",
        "disable": 0
    },
    {
        "Key": 94,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_20",
        "zh_CN": "……playername还在等我。",
        "disable": 0
    },
    {
        "Key": 95,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她重新辨别方向，往藏身处走去。",
        "disable": 0
    },
    {
        "Key": 96,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那是几年前的事了。",
        "disable": 0
    },
    {
        "Key": 97,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_01",
        "zh_CN": "克罗瑞娜，我有一个好消息要告诉你。",
        "disable": 0
    },
    {
        "Key": 98,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_02",
        "zh_CN": "基因重组技术终于有进展了——在小鼠身上实验成功了。以及，我们找到了一些愿意受试的志愿者。",
        "disable": 0
    },
    {
        "Key": 99,
        "Flag": "",
        "Pos": 5,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_21",
        "zh_CN": "啊，有这么多对巴德尔抑制剂过敏的人吗？",
        "disable": 0
    },
    {
        "Key": 100,
        "Flag": "",
        "Pos": 5,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_22",
        "zh_CN": "那我们可以开一个新的方向了，从基因上找到对应的……",
        "disable": 0
    },
    {
        "Key": 101,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_03",
        "zh_CN": "哪有那么多过敏的患者。是一些穷到活不下去的人。",
        "disable": 0
    },
    {
        "Key": 102,
        "Flag": "",
        "Pos": 5,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_23",
        "zh_CN": "……小姨，我觉得这不太好。",
        "disable": 0
    },
    {
        "Key": 103,
        "Flag": "",
        "Pos": 5,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_24",
        "zh_CN": "实验失败的结果，您一定比我清楚吧？",
        "disable": 0
    },
    {
        "Key": 104,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_04",
        "zh_CN": "签的合同里已经讲清楚了风险和后果，以及公司的补偿措施。这足够了。",
        "disable": 0
    },
    {
        "Key": 105,
        "Flag": "",
        "Pos": 5,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_25",
        "zh_CN": "小姨，我不想。",
        "disable": 0
    },
    {
        "Key": 106,
        "Flag": "",
        "Pos": 5,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_26",
        "zh_CN": "应该让患者作为实验者……比如像我这样的人。",
        "disable": 0
    },
    {
        "Key": 107,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_05",
        "zh_CN": "你到底在犯哪门子倔？那些人穷得吃不起明天的饭，而你——你以为你还能活多久？",
        "disable": 0
    },
    {
        "Key": 108,
        "Flag": "",
        "Pos": 5,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_27",
        "zh_CN": "代替治疗方案还在推进，总有办法。",
        "disable": 0
    },
    {
        "Key": 109,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_06",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 110,
        "Flag": "",
        "Pos": 5,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_28",
        "zh_CN": "科学伦理是您为我讲的第一课。",
        "disable": 0
    },
    {
        "Key": 111,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_07",
        "zh_CN": "你清高。",
        "disable": 0
    },
    {
        "Key": 112,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_08",
        "zh_CN": "你真该去看看那些买不起巴德尔抑制剂的穷苦人。",
        "disable": 0
    },
    {
        "Key": 113,
        "Flag": "",
        "Pos": 5,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_29",
        "zh_CN": "这正是这个课题的意义。不用巴德尔抑制剂也能治疗成年病，这不是您和妈妈研究的初衷吗？",
        "disable": 0
    },
    {
        "Key": 114,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_09",
        "zh_CN": "你一副殉道者的样子是什么意思？你以为我会同意你做志愿者？",
        "disable": 0
    },
    {
        "Key": 115,
        "Flag": "",
        "Pos": 5,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_30",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 116,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_10",
        "zh_CN": "你那是什么表情？",
        "disable": 0
    },
    {
        "Key": 117,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_11",
        "zh_CN": "别想，门儿都没有。明天我就停掉项目解散团队，你别想背着我干。",
        "disable": 0
    },
    {
        "Key": 118,
        "Flag": "",
        "Pos": 5,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_31",
        "zh_CN": "小姨！",
        "disable": 0
    },
    {
        "Key": 119,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_12",
        "zh_CN": "生气了？体会到我现在的心情了吗？",
        "disable": 0
    },
    {
        "Key": 120,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_13",
        "zh_CN": "我可没跟你开玩笑——瞪眼也没用。",
        "disable": 0
    },
    {
        "Key": 121,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_14",
        "zh_CN": "你是不是觉得，这辈子没跟我说过什么狠话，所以这次我就会按你的意思来？",
        "disable": 0
    },
    {
        "Key": 122,
        "Flag": "",
        "Pos": 5,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_32",
        "zh_CN": "我生气是因为您因小失大。您呢？",
        "disable": 0
    },
    {
        "Key": 123,
        "Flag": "",
        "Pos": 5,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_33",
        "zh_CN": "您是因为恼羞成怒吧。",
        "disable": 0
    },
    {
        "Key": 124,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_15",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 125,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "米拉扬起了手，克罗瑞娜则沉默地看着她。",
        "disable": 0
    },
    {
        "Key": 126,
        "Flag": "",
        "Pos": 5,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_34",
        "zh_CN": "您不打吗？",
        "disable": 0
    },
    {
        "Key": 127,
        "Flag": "",
        "Pos": 5,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_girl022_35",
        "zh_CN": "如果您不打，我就去做今天的作业了。",
        "disable": 0
    },
    {
        "Key": 128,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "克罗瑞娜转身离开了，米拉在原地站了一会儿，晃了晃，瘫坐在椅子上。",
        "disable": 0
    },
    {
        "Key": 129,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那一天没有下雨，也没有出太阳。",
        "disable": 0
    },
    {
        "Key": 130,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "参加葬礼的人都走了，只剩下一个少女和摇篮里的婴孩。",
        "disable": 0
    },
    {
        "Key": 131,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_16",
        "zh_CN": "“我会把她当成我自己的女儿。”",
        "disable": 0
    },
    {
        "Key": 132,
        "Flag": "",
        "Pos": 6,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc31ep5_mira_17",
        "zh_CN": "“我发誓。我一定会治好她。无论如何都会。”",
