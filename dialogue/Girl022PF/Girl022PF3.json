[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "夜晚的风凉爽舒适，吹得人渐渐有了困意。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "转眼看向克罗瑞娜，她还坐在草丛里，不知道在想些什么。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "拿起外套走了过去，虽然踩在草地上的窸窸窣窣声十分明显，但她还是毫无反应。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "直到我把外套披在她身上，她才小声惊呼，转头看向了我。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "啊。",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "差不多也该休息了。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "少女此时脸上的热意已经褪去大半，在清冷的月光下，眼神也温柔了许多。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "房车上有两张床，克罗瑞娜先挑吧。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那就……靠窗的吧。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "滴滴滴——！",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "就在我们商量的时候，克罗瑞娜的终端突然震动起来。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她看了眼屏幕，眉头微皱，但还是按下了接听键。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "露营地四周本就寂静，再加上克罗瑞娜没有回避的意思，终端里米拉的声音清晰地传入了我的耳中。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "小……小姨。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "克罗瑞娜，最近过得怎么样？身体状况还好吗？没什么手术后的后遗症吧？",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "没有没有，世界树的技术……很厉害。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "那我就放心了。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "小姨……",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我这两天……",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "playername计划什么时候送你回来？",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一周后。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "太久了，要不我和playername谈谈，让他明天或者后天就……",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "别，这样太麻烦了，还是就按照世界树的计划来吧。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 4,
        "Speaker": "米拉",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好吧，你刚才说你这两天怎么了？",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "也没怎么，等我回来之后再慢慢告诉你吧。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好了，小姨，我准备睡了，晚安。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "还没等米拉回应，克罗瑞娜就匆匆挂断了电话，有些茫然地看向我。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "休息吧，分析员。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她从草地上站起，优雅地拍拍裙子，往房车走去。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "为什么不告诉米拉，你这两天过得很开心？",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我叫住她，问出心里的疑问。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她转过身，目光呆滞地看着我。在月光之下，她像个精致的瓷娃娃",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "与晚餐时那个鲜活灵动的少女截然不同。",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "如果告诉小姨这些，她会很担心的。",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我是指开车、露营这些事儿。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "说完，她钻入房车，只留下一地的清冷。",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "直到两人洗漱完毕，躺到床上，克罗瑞娜都没再说一句话。",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "临睡前，我看了一眼靠窗的位置，发现她连睡觉的姿势都是端庄克制的。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "枕头、被子都不偏不倚地位于床的中央。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而少女也平躺着，双手规整地放在被子上，就像童话书里的公主。",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "伴随着她平稳的呼吸声和偶尔的蝉鸣，我也进入了安稳的梦乡。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不知过了多久，靠窗的一角响起了细微的啜泣声。",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "克罗瑞娜不再像刚才那样平躺，而是侧过身子，蜷缩成一团。",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "眼泪不受控制地颗颗落下，在枕头上晕开水渍。",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "怕吵醒身边的人，她用手紧紧捂住嘴，努力不让自己发出声音。",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "少女睡不着，因为白天她一直沉浸在幸福的梦里，已经睡得够久了。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而现在，梦醒后巨大的落差感让她有些不适应。",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 0,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "（马上就要回家了……）",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "（之后，就再也见不到他了。）",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 0,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "（有些，舍不得呢……）",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "眼泪渐渐在脸上汇成细流，一滴接一滴地滑到嘴角，慢慢渗进少女的唇中。",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "又咸又苦的味道让味蕾一下子敏感起来，她舔着嘴角，开始渴望起甜味。",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而甜味的来源，就睡在离自己不远的地方。",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "克罗瑞娜的手在被子边缘犹豫了许久，最终还是悄悄掀开一角，轻手轻脚地下了床。",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她每一步都踩得极轻极慢，生怕发出一丝声响，心跳声在寂静中显得格外清晰。",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "月色在深夜时分更加皎洁明亮，透过小窗洒进车内，在墙壁和地板上投下纤弱颤抖的影子。",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "影子时而停顿，时而前进。最后轻柔地弯下腰来，直到与床边的黑暗融为一体。",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "柔软温热的唇终于轻触在一起，少女感觉自己的心跳都快要蹦出来。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "片刻之后，她缓缓起身，没有按照脑海中想象那样继续深入，反倒是蹲在床边，用脸颊轻轻摩挲着他的手掌。",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "（这样就好……已经足够了。）",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "最后一点理智告诉克罗瑞娜，太过惊艳的东西未必就是好的。",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她害怕自己的余生都将守着这个夜晚，念念不忘。",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "至少，在今天这个美梦里，自己已经没有任何遗憾了。",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "（好困……）",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "刚才的醉意还没有完全散去，满足感又让她彻底放松下来。",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "感受着指尖传来的淡淡体温，少女眼皮越来越沉重，呼吸也逐渐变得绵长平缓。",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "就在即将彻底坠入梦乡的那一刻，一滴晶莹的眼泪悄无声息地滑落。",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "泪珠在月光下闪烁着微光，像一颗小小的珍珠，落在了宽厚而温暖的掌心之中。",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "再醒来时，天已大亮。意识到自己竟然好端端地躺在床上时，克罗瑞娜猛地坐了起来。",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 6,
        "Speaker": "克罗瑞娜",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我这是？",
        "disable": 0
    },
    {
        "Key": 71,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "早上好，克罗瑞娜。",
        "disable": 0
    },
    {
        "Key": 72,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "赶紧起来收拾一下，吃过早饭，我们得抓紧往回开了。",
        "disable": 0
    },
    {
        "Key": 73,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一边说着，我一边往外搬着桌椅，做着早餐的准备。",
        "disable": 0
    },
    {
        "Key": 74,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而克罗瑞娜鬼鬼祟祟在窗边探出半个脑袋，目光锐利地盯着我的一举一动，似乎想要从中看出什么端倪。",
