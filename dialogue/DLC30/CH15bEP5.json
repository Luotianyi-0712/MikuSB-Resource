    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 4,
        "Speaker": "肴夜天光",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc30ep5_girl010_02",
        "zh_CN": "而且，就在半小时前，泰坦污染进一步加重了，现在除了海姆达尔以外的人员都已经撤出了零区。",
        "disable": 0
    },
