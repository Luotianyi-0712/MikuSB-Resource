        "Pos": 4,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc30st1_npc003_11",
        "zh_CN": "卡罗琳，你把事情的经过和他说清楚吧。",
