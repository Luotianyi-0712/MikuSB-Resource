    {
        "Key": 99,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "作为完美的人间体，自己可不会因为任务出现变故就放弃！",
