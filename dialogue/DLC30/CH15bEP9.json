    },
    {
        "Key": 86,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "就在她的眼前，本体的虚影突然消失了。",
        "disable": 0
    },
    {
        "Key": 87,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "它不仅没有提供更强的力量，相反，人间体感觉到自己身上已有的力量也在迅速消失。",
        "disable": 0
    },
    {
        "Key": 88,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她下意识朝着书库内跑去，但没跑几步，凯茜娅便拦在了她的身前。",
        "disable": 0
    },
    {
        "Key": 89,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc30ep9_girl015_06",
        "zh_CN": "真不巧，此路不通。",
        "disable": 0
    },
    {
        "Key": 90,
        "Flag": "",
        "Pos": 9,
        "Speaker": "“埃达”",
