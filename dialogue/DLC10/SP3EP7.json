        "Flag": "",
        "Pos": 0,
        "Speaker": "“幽影”",
        "RealSpeaker": "",
        "WwiseEventID": "Vo_dlc10ep7_Kaede_05",
        "zh_CN": "夜魇骑士……哈哈哈哈哈。",
