        "Flag": "",
        "Pos": 0,
        "Speaker": "“幽影”",
        "RealSpeaker": "",
        "WwiseEventID": "Vo_dlc10ep7_Kaede_03",
        "zh_CN": "呵……逃？",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 0,
        "Speaker": "“幽影”",
        "RealSpeaker": "",
        "WwiseEventID": "Vo_dlc10ep7_Kaede_04",
