        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我总算知道伊格妮丝为什么如此慌张了。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员夜魇",
        "RealSpeaker": "",
        "WwiseEventID": "",
