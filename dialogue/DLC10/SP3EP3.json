    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员夜魇",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "伊格妮丝，这次我们需要保证人质的安全，不能轻举妄动。",
