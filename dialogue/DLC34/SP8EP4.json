        "WwiseEventID": "Play_Vo_dlc34ep4_girl020_31",
        "zh_CN": "有点儿慌……",
        "disable": 0
    },
    {
        "Key": 135,
        "Flag": "",
        "Pos": 6,
        "Speaker": "卜卜灵鉴",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34ep4_girl020_32",
