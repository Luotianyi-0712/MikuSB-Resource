        "disable": 0
    },
    {
        "Key": 136,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "别着急啊。",
        "disable": 0
    },
    {
        "Key": 137,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员战斗",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "朔州话怎么说的来着？一个巴掌拍不响。",
