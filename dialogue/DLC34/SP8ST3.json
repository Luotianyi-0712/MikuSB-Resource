[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "翌日。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "直升机在世界树总部的机场降落。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "停机坪远处的大楼门口站着几道熟悉的身影。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一道黄色的身影扑了过来，到我面前站定。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮——",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她怒视着我，眼里泛着水光。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_girl008_01",
        "zh_CN": "你……",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 6,
        "Speaker": "芬妮澄意",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_girl008_02",
        "zh_CN": "每次都是这样……",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她把头别了过去。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "拉了拉她的手，她终于忍不住，靠在我的胸口，把头埋住，不想让我看见她的表情。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "里芙和凯茜娅也走了过来。凯茜娅扶着我的肩膀，在脸颊上吻了一下。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_girl015_01",
        "zh_CN": "这种事应该叫上我的。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_girl015_02",
        "zh_CN": "我知道你能解决，但下次可别忘了我。",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "嗯。东线的压力大吗？",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 6,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_girl015_03",
        "zh_CN": "像割麦子一样，轻松得很。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 9,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_girl014_01",
        "zh_CN": "你听她说得轻巧……",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "不远处的苔丝、肴以及辰星也走了过来。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_girl014_02",
        "zh_CN": "只有这么些人，却要把整个耶洛沙和军占区的战线全部兜住……",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "辛苦了。我不在的时候，你最适合调度战线、灵活增援了。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_girl014_03",
        "zh_CN": "好啦……最累的还是里芙和凯茜娅。她们两个人带着后勤团队和外勤成员，拦住了赫瓦雷纳军团的主攻阵线。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 5,
        "Speaker": "凯茜娅狂诗",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_girl015_04",
        "zh_CN": "哼，再打三天三夜我也没问题。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "凯茜娅轻笑着扬了扬头。被提到的里芙则站在我旁边，默不作声。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "这时，辰星拉起我的手，另一只手则摸着我的脸颊。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_girl014_04",
        "zh_CN": "郎君，你……",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "停了半天，也没说出话。肴则绕到我身后，头轻轻靠在了我的肩膀上。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我转身去看她，她撇着嘴，不说话，幽怨得让人愧疚。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "苔丝则拉住了我的另一只手，咬着嘴唇，一副快哭出来的样子。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "六个人把我团团围住，一副要个说法的样子。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "咳……我知道错了。",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "走吧，我们边走边说？",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "几个人像没听见似的。我也明白，她们的心情不是一两句话就能消解的。",
        "disable": 0
    },
    {
        "Key": 32,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "哎——这不是好好地回来了吗？",
        "disable": 0
    },
    {
        "Key": 33,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "让你们担心了，以后不会再这么冒险了。",
        "disable": 0
    },
    {
        "Key": 34,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_girl014_05",
        "zh_CN": "唉，算了算了……",
        "disable": 0
    },
    {
        "Key": 35,
        "Flag": "",
        "Pos": 6,
        "Speaker": "辰星琼弦",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_girl014_06",
        "zh_CN": "回来了就好。",
        "disable": 0
    },
    {
        "Key": 36,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "辰星叹了口气，摇了摇头，率先走了出去。虽然是在帮我解围，但还是隔着几个人的肩头，有点伤心地看了我一眼。",
        "disable": 0
    },
    {
        "Key": 37,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我知道这是逃不过的局面。任务录像已经传回了总部，所有人都知道我当时做出了怎样的决定。",
        "disable": 0
    },
    {
        "Key": 38,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "做出那样的选择也并不只是一腔孤勇。当时如果退了下来，后续的任何行动都会有生命危险。为了以后，为了保护她们、保护这种生活，我选择战斗。",
        "disable": 0
    },
    {
        "Key": 39,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她们也并非质疑我的安排，而是在表达一种无奈和委屈而已。",
        "disable": 0
    },
    {
        "Key": 40,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "人群慢慢往楼里走，里芙慢慢落在队伍后面，和我并肩走在一起。",
        "disable": 0
    },
    {
        "Key": 41,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她还是一句话也不说，只是沉默着。我揽住她的肩膀，她自然地把头靠在我的肩膀上。",
        "disable": 0
    },
    {
        "Key": 42,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好啦，是我不好。",
        "disable": 0
    },
    {
        "Key": 43,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她突然转身抱住了我。",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 6,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_girl002_01",
        "zh_CN": "我明白的。",
        "disable": 0
    },
    {
        "Key": 45,
        "Flag": "",
        "Pos": 6,
        "Speaker": "里芙无限之视",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_girl002_02",
        "zh_CN": "我只是……",
        "disable": 0
    },
    {
        "Key": 46,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她没接着说，环住我的双臂抱得更紧了些。",
        "disable": 0
    },
    {
        "Key": 47,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我摸了摸她的头发。",
        "disable": 0
    },
    {
        "Key": 48,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "远处的大楼门口，队员们纷纷涌了出来。",
        "disable": 0
    },
    {
        "Key": 49,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "总算是到家了。",
        "disable": 0
    },
    {
        "Key": 50,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "办公室内。",
        "disable": 0
    },
    {
        "Key": 51,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "好了……事情不是解决了嘛，别这么严肃。",
        "disable": 0
    },
    {
        "Key": 52,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_npc003_01",
        "zh_CN": "……",
        "disable": 0
    },
    {
        "Key": 53,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "陶吐了口气，无奈地看着我。",
        "disable": 0
    },
    {
        "Key": 54,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_npc003_02",
        "zh_CN": "有什么用呢？",
        "disable": 0
    },
    {
        "Key": 55,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_npc003_03",
        "zh_CN": "我强调了多少次……这次任务安全第一。我要你们三个都安全回来。",
        "disable": 0
    },
    {
        "Key": 56,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_npc003_04",
        "zh_CN": "……我说的话你不听。她们的埋怨再多，你不是也没改么。",
        "disable": 0
    },
    {
        "Key": 57,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "是想到了赢的可能性，才走上去的。",
        "disable": 0
    },
    {
        "Key": 58,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "而且……她的实力到了那个地步，一旦放虎归山，你们所有人的安全都无法保证。",
        "disable": 0
    },
    {
        "Key": 59,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_npc003_05",
        "zh_CN": "……就算用世界树所有分部和基地去换你的命，我也不会犹豫半分。",
        "disable": 0
    },
    {
        "Key": 60,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_npc003_06",
        "zh_CN": "你比我更清楚你肩上的责任有多重。",
        "disable": 0
    },
    {
        "Key": 61,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "……文明的变革和物种的进化一样，都不是平稳发展而来的。",
        "disable": 0
    },
    {
        "Key": 62,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "陶看向别处，摇了摇头。",
        "disable": 0
    },
    {
        "Key": 63,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_npc003_07",
        "zh_CN": "卜卜和猫汐尔的情况都不错。受到危机的刺激，卜卜的神格神经进一步强化了。",
        "disable": 0
    },
    {
        "Key": 64,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_npc003_08",
        "zh_CN": "猫汐尔的无痛症恢复了，但“丧钟”也完全毁掉了。制作“丧钟”已经耗尽了所有泰坦物质的适应性同位素储备，再造出来不知道要到什么时候。",
        "disable": 0
    },
    {
        "Key": 65,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_npc003_09",
        "zh_CN": "而你……你也真是命大。如果不是战斗服挡了一部分爆炸，你恐怕……",
        "disable": 0
    },
    {
        "Key": 66,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "一定会是我赢，就算没有那件战斗服也一样。",
        "disable": 0
    },
    {
        "Key": 67,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "决定战斗胜负的因素很多。但势均力敌的两个人打到那个地步，那就要看意志和觉悟了。",
        "disable": 0
    },
    {
        "Key": 68,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "所以说，我们都不会退缩。这样的胜者才有权力认同或者否定对方的理想。",
        "disable": 0
    },
    {
        "Key": 69,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "何况，你怎么知道战斗服不在我的计算之中呢？",
        "disable": 0
    },
    {
        "Key": 70,
        "Flag": "",
        "Pos": 6,
        "Speaker": "陶",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st3_npc003_10",
        "zh_CN": "行了，知道你厉害……",
        "disable": 0
    },
    {
        "Key": 71,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "至于“丧钟”……有缺陷的版本，解决掉优化问题再考虑制作吧。",
        "disable": 0
    },
    {
        "Key": 72,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "想到这，我又想到猫汐尔——她一直很重视“丧钟”，我也懂她的意思。",
        "disable": 0
    },
    {
        "Key": 73,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
