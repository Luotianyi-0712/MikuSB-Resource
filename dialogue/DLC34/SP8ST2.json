        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st2_girl020_19",
        "zh_CN": "我……准备好了。",
        "disable": 0
    },
    {
        "Key": 44,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
