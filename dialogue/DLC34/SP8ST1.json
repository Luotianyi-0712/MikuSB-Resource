        "Key": 49,
        "Flag": "",
        "Pos": 6,
        "Speaker": "猫汐尔莲驱",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st1_girl012_12",
        "zh_CN": "呜……",
        "disable": 0
    },
