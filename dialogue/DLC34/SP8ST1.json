        "Pos": 6,
        "Speaker": "猫汐尔莲驱",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st1_girl012_11",
        "zh_CN": "弄疼我。",
        "disable": 0
    },
