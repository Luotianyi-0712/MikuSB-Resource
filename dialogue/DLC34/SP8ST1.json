        "Key": 38,
        "Flag": "",
        "Pos": 6,
        "Speaker": "猫汐尔莲驱",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st1_girl012_08",
        "zh_CN": "我喜欢……我喜欢这种感觉。",
        "disable": 0
    },
