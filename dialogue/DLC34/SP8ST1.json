        "Key": 39,
        "Flag": "",
        "Pos": 6,
        "Speaker": "猫汐尔莲驱",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st1_girl012_09",
        "zh_CN": "我和你一样了。",
        "disable": 0
    },
