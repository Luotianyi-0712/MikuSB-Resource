[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "当晚，世界树的补给基地内。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "在就近的基地内休整一晚，明天就出发回总部。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我的伤势基本稳定了。猫汐尔和卜卜也得到了医治，暂无大碍。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "卜卜的身体还在复查，猫汐尔已经回到了病房内，和我躺在相邻的病床上休息。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "吱纽——吱纽——",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "正在闭目养神，却听见旁边的动静。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "猫汐尔躺在床上，正用手抵着墙——想让她的床离我的床近一点。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "分析员无帽",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "干嘛？不好好躺着？",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "手被牵住了。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 6,
        "Speaker": "猫汐尔莲驱",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st1_girl012_01",
        "zh_CN": "这样正好喵。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她躺了下来，两个人的手刚好可以彼此牵住。",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 9,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她手臂上的伤口还缠着绷带。我握着掌心里软软搭着的手指，轻轻用指尖掐了一下她的指尖。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 9,
        "Speaker": "猫汐尔莲驱",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st1_girl012_02",
        "zh_CN": "唔……",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "转过头，看见她看过来的眼睛。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "腾——",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "眨眼之间，她就落在了我的床上。",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 6,
        "Speaker": "猫汐尔莲驱",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st1_girl012_03",
        "zh_CN": "血压正常。渗透压正常。心率……上升。",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她另一只手上的监测仪器显示着我身体的各种读数。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 6,
        "Speaker": "猫汐尔莲驱",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st1_girl012_04",
        "zh_CN": "经过猫汐尔医生的评估，playername此时可以进行适当活动喵。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "说罢，她吻了下来。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她的吻凉凉的。轻巧地试探着，表达着爱意。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我看着她，她慢慢闭上眼睛，也用手遮住了我的眼睛。",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "水波摇荡，柔枝交缠。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "我睁开眼，她淡黄色的眼瞳在黑夜中闪着光，像尚未凝固的琥珀，在呼吸中摇晃。",
        "disable": 0
    },
    {
        "Key": 25,
        "Flag": "",
        "Pos": 6,
        "Speaker": "猫汐尔莲驱",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st1_girl012_05",
        "zh_CN": "咬我。",
        "disable": 0
    },
    {
        "Key": 26,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她侧躺下来，抱住我的头，把脖颈和肩膀凑到我的面前。",
        "disable": 0
    },
    {
        "Key": 27,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "像人压倒了麦浪一样，留下了印子，让人看见底下的红色的土壤。",
        "disable": 0
    },
    {
        "Key": 28,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "靠近她喉咙的耳朵听见了吹过池水的风声。",
        "disable": 0
    },
    {
        "Key": 29,
        "Flag": "",
        "Pos": 6,
        "Speaker": "猫汐尔莲驱",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc34st1_girl012_06",
        "zh_CN": "再……用力……",
        "disable": 0
    },
    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "往旁边移了移位置，力度大了一些。",
        "disable": 0
    },
    {
        "Key": 31,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她忽然抱住了我的头，再也压抑不住自己。",
        "disable": 0
    },
