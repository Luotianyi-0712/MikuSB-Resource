    {
        "Key": 30,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "拿着那本厚得能当砖头的书，念出书名时，我觉得我的语气都带上了一分敬畏。",
        "disable": 0
