[
    {
        "Key": 1,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_01",
        "zh_CN": "在旧阁楼的角落里，住着一只不会痛的玩偶猫。",
        "disable": 0
    },
    {
        "Key": 2,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_02",
        "zh_CN": "她从高处跳下不会喊“呜咪”，踩到尖刺也不会逃跑。",
        "disable": 0
    },
    {
        "Key": 3,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_03",
        "zh_CN": "其他小猫摇摇头：“她真奇怪喵。”，渐渐疏远了她。",
        "disable": 0
    },
    {
        "Key": 4,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_04",
        "zh_CN": "可玩偶猫还是大摇大摆地晃着尾巴，钻过碎玻璃，爬上歪斜的墙。",
        "disable": 0
    },
    {
        "Key": 5,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_05",
        "zh_CN": "某一天，玩偶猫遇见了一只小灰猫——",
        "disable": 0
    },
    {
        "Key": 6,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_06",
        "zh_CN": "“会受伤的！”他总是这样喊，用软软的爪子拉住她。",
        "disable": 0
    },
    {
        "Key": 7,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_07",
        "zh_CN": "哪怕玩偶猫眨着眼睛不懂“受伤”是什么模样。",
        "disable": 0
    },
    {
        "Key": 8,
        "Flag": "",
        "Pos": 6,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_08",
        "zh_CN": "不过即便如此，两只小猫还是相处得很愉快。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_09",
        "zh_CN": "他们成为了彼此的伴侣。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_10",
        "zh_CN": "但是一天夜里，火焰吞没了阁楼。",
        "disable": 0
    },
    {
        "Key": 11,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_11",
        "zh_CN": "熟睡的玩偶猫对此一无所知，直至小灰猫的叫声将其唤醒——",
        "disable": 0
    },
    {
        "Key": 12,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_12",
        "zh_CN": "她这才发现，此刻的她，正趴在他那被烟熏黑的背上。",
        "disable": 0
    },
    {
        "Key": 13,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_13",
        "zh_CN": "他背着她跌进月光里，在雪白的灰上，留下一串串脚印……",
        "disable": 0
    },
    {
        "Key": 14,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_14",
        "zh_CN": "从那天起，时光流逝。",
        "disable": 0
    },
    {
        "Key": 15,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_15",
        "zh_CN": "虽然玩偶猫依旧不知晓疼痛为何物，但在小灰猫的注目下，她也学会了轻轻走路。",
        "disable": 0
    },
    {
        "Key": 16,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_19",
        "zh_CN": "“也许，我的皮肤对世界的触碰无动于衷，但至少，可以感知到你的心。”",
        "disable": 0
    },
    {
        "Key": 17,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_20",
        "zh_CN": "“谢谢你，带走了我的孤独。”",
        "disable": 0
    },
    {
        "Key": 18,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "秋天的第一抹朝阳，与我们爬上了山顶。",
        "disable": 0
    },
    {
        "Key": 19,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "风卷起满地斑斓，花瓣在空中划出优美的弧线，将我的目光引向遥远的海平线。",
        "disable": 0
    },
    {
        "Key": 20,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "初升的朝阳将整片海域染成醉人的葡萄酒色。",
        "disable": 0
    },
    {
        "Key": 21,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "粼粼波光中，万物都沉浸在这微醺的氛围里。",
        "disable": 0
    },
    {
        "Key": 22,
        "Flag": "",
        "Pos": 9,
        "Speaker": "猫汐尔泳装",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc3ep12_girl012_23",
        "zh_CN": "哼……",
        "disable": 0
    },
    {
        "Key": 23,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "身旁的猫汐尔忽然轻哼一声，踮起脚尖褪去凉鞋。",
        "disable": 0
    },
    {
        "Key": 24,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "随后，跃入花丛，白色的纱裙被荆棘勾出细碎裂痕，长发间缀满不知名的小野花。",
