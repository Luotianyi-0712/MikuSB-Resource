    {
        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "他寻遍星球的每个角落，终于与正挥舞着光剑与变异生物激斗的女领主安卡希雅再次重逢。",
        "disable": 0
    },
    {
        "Key": 9,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "宇宙探险家不再四处流浪，他在这里停下了脚步。",
        "disable": 0
