        "Flag": "",
        "Pos": 9,
        "Speaker": "肴病号服",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc14ep1_girl010_01",
        "zh_CN": "我很好。",
        "disable": 0
    },
    {
        "Key": 10,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "肴已经从一段有些沉浸的情绪中抽离出来，摇了摇头，挤出一个笑容。",
        "disable": 0
