        "Key": 8,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "她的目光不住地瞥向肴的身边——在肴身边的另一个治疗舱里，分析员正静静躺在里面沉睡着。",
        "disable": 0
