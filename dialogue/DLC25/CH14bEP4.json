    },
    {
        "Key": 114,
        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "数分钟后，卡罗琳筋疲力尽地来到陶的办公室。",
