    },
    {
        "Key": 131,
        "Flag": "",
        "Pos": 4,
        "Speaker": "卡罗琳",
        "RealSpeaker": "",
        "WwiseEventID": "Play_Vo_dlc14ep4_npc002_19",
        "zh_CN": "我已经从战场退下来了。",
