        "Flag": "",
        "Pos": 0,
        "Speaker": "",
        "RealSpeaker": "",
        "WwiseEventID": "",
        "zh_CN": "芬妮拨了拨自己的闪耀的金色马尾，瞥了一眼辰星。",
        "disable": 0
    },
    {
        "Key": 71,
        "Flag": "",
        "Pos": 6,
